def get_default_forecast_types():
    """Get list of default forecast types"""
    return [ft for ft, config in FORECAST_CONFIG.items() if config['default']]

def generate_demand_query_temp_tables(vendor_numbers, start_date, end_date, aggregation, include_dropship=False, selected_forecasts=None):
    """Generate demand analysis query using optimized CTEs for better performance with weekly breakdown"""
    
    # Get vendor list for filtering
    vendor_list = "', '".join(vendor_numbers)
    
    # Get dynamic timeframe from session state
    import streamlit as st
    timeframe_weeks = st.session_state.get('weeks_back', 2)  # Default to 2 weeks
    
    # Calculate week dates for dynamic columns (newest to oldest for display)
    week_dates = calculate_week_dates(timeframe_weeks)
    
    # Create trailing weeks notation for aggregate columns
    trailing_weeks_suffix = f"T{timeframe_weeks}W"
    
    # Generate dynamic weekly columns for LT forecast
    def generate_weekly_forecast_columns(week_dates):
        """Generate weekly forecast column SQL and column mapping for LT forecast"""
        column_sql_parts = []
        column_mapping = {}
        
        for i, week_date_str in enumerate(week_dates, 1):
            week_date_sql = datetime.strptime(week_date_str, '%m/%d/%Y').strftime('%Y-%m-%d')
            
            # WAPE columns for LT
            wape_col = f"W{i}_LT_WAPE"
            wape_sql = f"""
                SUM(CASE WHEN DATE_TRUNC('week', f.week_date) = DATE_TRUNC('week', '{week_date_sql}'::date) 
                         THEN f.LT_blended_abs_error ELSE 0 END) / 
                NULLIFZERO(SUM(CASE WHEN DATE_TRUNC('week', f.week_date) = DATE_TRUNC('week', '{week_date_sql}'::date) 
                                    THEN f.actuals ELSE 0 END)) as {wape_col}"""
            column_sql_parts.append(wape_sql)
            column_mapping[wape_col.upper()] = f"{week_date_str} LT WAPE"
            
            # Bias columns for LT
            bias_col = f"W{i}_LT_BIAS"
            bias_sql = f"""
                (SUM(CASE WHEN DATE_TRUNC('week', f.week_date) = DATE_TRUNC('week', '{week_date_sql}'::date) 
                          THEN f.LT_blended_fcst ELSE 0 END) / 
                 NULLIFZERO(SUM(CASE WHEN DATE_TRUNC('week', f.week_date) = DATE_TRUNC('week', '{week_date_sql}'::date) 
                                     THEN f.actuals ELSE 0 END)) - 1) as {bias_col}"""
            column_sql_parts.append(bias_sql)
            column_mapping[bias_col.upper()] = f"{week_date_str} LT BIAS"
        
        return ',\n                '.join(column_sql_parts), column_mapping
    
    # Generate weekly column SQL and mapping
    weekly_columns_sql, column_mapping = generate_weekly_forecast_columns(week_dates)
    
    query = f"""
    WITH 
    -- ============================================================================
    -- VENDOR SKUS - Define the SKUs for your vendor(s)
    -- ============================================================================
    vendor_skus AS (
        SELECT DISTINCT
            v.vendor_number as vendor_number,
            v.vendor_name as vendor_name,
            p.product_part_number as product_part_number,
            p.product_manufacturer_name,
            p.product_key,
            p.product_merch_classification1,
            p.product_merch_classification2
        FROM EDLDB.CHEWYBI.vendor_agreement_line vl
        LEFT JOIN edldb.chewybi.products p ON p.product_part_number = vl.product_part_number
        LEFT JOIN edldb.chewybi.vendors v ON v.vendor_number = vl.vendor_number
        WHERE CURRENT_DATE BETWEEN COALESCE(agreement_line_start_date::DATE, CURRENT_DATE)
            AND COALESCE(agreement_line_end_date::DATE, CURRENT_DATE)
            AND COALESCE(disabled_reason_code,'') = ''
            AND COALESCE(agreement_line_status,'') NOT IN ('CANCELED')
            AND v.vendor_number IN ('{vendor_list}')
    ),

    -- ============================================================================
    -- LEAD TIME CALCULATION
    -- ============================================================================
    socrates_ilv_LT AS (
        SELECT 
            silv.ITEM_ID,
            silv.location_code,
            p.product_manufacturer_name,
            p.product_company_description,
            AVG(vl.VENDOR_LEAD_TIME_BUSINESS_DAYS) as LT_bus_days_item_FC
        FROM (
            SELECT *
            FROM EDLDB.SC_REPLENISHMENT_SANDBOX.SOCRATES_ITEM_LOCATION_VENDOR silv
            WHERE 1=1
                AND job_start_time = (SELECT MAX(job_start_time) FROM EDLDB.SC_REPLENISHMENT_SANDBOX.SOCRATES_ITEM_LOCATION_VENDOR)
                AND silv.ITEM_ID IN (SELECT product_part_number FROM vendor_skus)
        ) silv
        LEFT JOIN (
            SELECT *
            FROM edldb.chewybi.vendor_location vl 
            WHERE 1=1
                AND snapshot_date = (SELECT MAX(snapshot_date) FROM edldb.chewybi.vendor_location)
        ) vl ON vl.vendor_number = silv.VENDOR_ID AND vl.LOCATION_CODE = silv.LOCATION_CODE
        LEFT JOIN edldb.chewybi.products p ON p.product_part_number = silv.item_id
        WHERE 1=1
            AND p.product_part_number IN (SELECT product_part_number FROM vendor_skus)
        GROUP BY 1,2,3,4

        UNION ALL

        SELECT
            ilv.product_part_number,
            ilv.location_code,
            p.product_manufacturer_name,
            p.product_company_description,
            ROUND(AVG(ilv.vendor_lead_time_business_days),0) as LT_bus_days_item_FC
        FROM edldb.chewybi.item_location_vendor ilv
        LEFT JOIN edldb.chewybi.products p ON p.product_part_number = ilv.product_part_number
        WHERE 1=1
            AND ilv.snapshot_date = CURRENT_DATE
            AND p.product_company_description IN ('Chewy Canada')
            AND ilv.vendor_lead_time_business_days > 0
            AND p.product_part_number IN (SELECT product_part_number FROM vendor_skus)
        GROUP BY 1,2,3,4
    ),

    LT AS (
        SELECT
            p.product_part_number,
            p.product_key,
            p.product_company_description,
            p.product_merch_classification1,
            p.product_manufacturer_name,
            p.private_label_flag,
            p.product_dropship_flag,
            p.product_status,
            LT_bus_days_item_ntwk,
            LT_cal_days_item_ntwk,
            LT_bus_days_brand_ntwk,
            LT_cal_days_brand_ntwk,
            LEAST(COALESCE(NULLIFZERO(LT_cal_days_item_ntwk),NULLIFZERO(LT_cal_days_brand_ntwk),14),180) as adj_avg_lead_time
        FROM edldb.chewybi.products p
        JOIN vendor_skus vs ON vs.product_part_number = p.product_part_number
        LEFT JOIN (
            SELECT
                item_id,
                ROUND(AVG(LT_bus_days_item_FC),0)::INTEGER as LT_bus_days_item_ntwk,
                ROUND(AVG(LT_bus_days_item_FC) /6 *2 + AVG(LT_bus_days_item_FC),0)::INTEGER as LT_cal_days_item_ntwk
            FROM socrates_ilv_LT
            GROUP BY 1
        ) it ON it.item_id = p.product_part_number
        LEFT JOIN (
            SELECT
                product_company_description,
                product_manufacturer_name,
                ROUND(AVG(LT_bus_days_item_FC),0)::INTEGER as LT_bus_days_brand_ntwk,
                ROUND(AVG(LT_bus_days_item_FC) /6 *2 + AVG(LT_bus_days_item_FC),0)::INTEGER as LT_cal_days_brand_ntwk
            FROM socrates_ilv_LT
            GROUP BY 1,2
        ) br ON br.product_company_description = p.product_company_description AND br.product_manufacturer_name = p.product_manufacturer_name
        WHERE 1=1
            AND p.bundle_flag_type = 'Item'
            AND p.product_type = 'Item'
            AND p.product_company_description IN ('Chewy','Chewy Pharmacy','Chewy Canada')
    ),

    -- ============================================================================
    -- OUT OF STOCK DAYS TRACKING (Dynamic timeframe, max 4 weeks)
    -- ============================================================================
    pdp_oos AS (
        SELECT
            product_part_number,
            mps.activity_date,
            SUM(mps.Total_PDP_Views) as Total_PDP_Views,
            SUM(mps.OutofStock_PDP_Views) as OutofStock_PDP_Views
        FROM edldb.mrch.merch_performance_snapshot_pharmacy mps
        WHERE 1=1
            AND mps.activity_date BETWEEN DATE_TRUNC('week',CURRENT_DATE) - INTERVAL '{timeframe_weeks} weeks' AND CURRENT_DATE-1
            AND Total_PDP_Views > 0
            AND product_part_number IN (SELECT product_part_number FROM vendor_skus)
        GROUP BY 1,2
    ),
    
    inv_snapshot_oos AS (
        SELECT DISTINCT
            oos.inventory_out_of_stock_item,
            oos.inventory_out_of_stock_snapshot_date,
            TRUE as inv_snapshot_oos_flag
        FROM edldb.chewybi.inventory_out_of_stock_snapshot oos
        LEFT JOIN pdp_oos poos ON poos.product_part_number = oos.inventory_out_of_stock_item 
            AND poos.activity_date = oos.inventory_out_of_stock_snapshot_date
        WHERE 1=1
            AND (oos.inventory_out_of_stock_available_qty <= 0 OR oos.inventory_out_of_stock_reservedforsubs_flag = 'true')
            AND oos.inventory_out_of_stock_snapshot_date BETWEEN DATE_TRUNC('week',CURRENT_DATE) - INTERVAL '{timeframe_weeks} weeks' AND CURRENT_DATE-1
            AND poos.product_part_number IS NULL
            AND inventory_out_of_stock_item IN (SELECT product_part_number FROM vendor_skus)
    ),

    OOS_days AS (
        SELECT
            p.product_part_number,
            p.product_key,
            poos.product_part_number as inventory_out_of_stock_item,
            activity_date as inventory_out_of_stock_snapshot_date
        FROM pdp_oos poos
        LEFT JOIN edldb.chewybi.products p ON p.product_part_number = poos.product_part_number
        WHERE 1=1
            AND ZEROIFNULL(OutofStock_PDP_Views) / NULLIFZERO(Total_PDP_Views) >= 0.1

        UNION ALL

        SELECT
            p.product_part_number,
            p.product_key,
            inventory_out_of_stock_item,
            inventory_out_of_stock_snapshot_date
        FROM inv_snapshot_oos oos
        LEFT JOIN edldb.chewybi.products p ON p.product_part_number = oos.inventory_out_of_stock_item
    ),

    -- ============================================================================
    -- LT BLENDED FORECAST (Dynamic timeframe, max 4 weeks)
    -- ============================================================================
    LT_blended_fcst AS (
        SELECT
            fs.product_part_number,
            DATE_TRUNC('week',fs.forecast_date)::DATE as week_date,
            CASE WHEN oos.product_key IS NOT NULL THEN TRUE ELSE FALSE END as OOS_flag,
            SUM(fs.fcst_qty)::NUMERIC(38,3) as LT_blended_fcst
        FROM edldb.sc_sandbox.blended_fcst_item_day_network_colt fs
        LEFT JOIN OOS_days oos ON oos.product_part_number = fs.product_part_number 
            AND oos.inventory_out_of_stock_snapshot_date = fs.forecast_date
        LEFT JOIN LT lt ON lt.product_part_number = fs.product_part_number
        WHERE 1=1
            AND forecast_date BETWEEN DATE_TRUNC('week',CURRENT_DATE) - INTERVAL '{timeframe_weeks} weeks' AND CURRENT_DATE-1
            AND snapshot_date = LEAST(forecast_date - adj_avg_lead_time, CURRENT_DATE)
            AND fs.product_part_number IN (SELECT product_part_number FROM vendor_skus)
        GROUP BY 1,2,3
    ),

    -- ============================================================================
    -- DEMAND ACTUALS (Dynamic timeframe, max 4 weeks)
    -- ============================================================================
    demand AS (
        SELECT
            p.product_part_number,
            DATE_TRUNC('week',olm.order_placed_date)::DATE as week_date,
            CASE WHEN oos.product_key IS NOT NULL THEN TRUE ELSE FALSE END as OOS_flag,
            SUM(olm.order_line_quantity)::NUMERIC(38,3) as olm_units_ordered
        FROM edldb.chewybi.order_line_measures olm
        LEFT JOIN OOS_days oos ON oos.product_key = olm.product_key 
            AND oos.inventory_out_of_stock_snapshot_date = olm.order_placed_date
        LEFT JOIN edldb.chewybi.products p ON p.product_key = olm.product_key
        WHERE 1=1
            AND olm.order_line_each_price <> 0
            AND olm.order_order_line_status NOT IN ('X','J')
            AND olm.order_placed_date BETWEEN DATE_TRUNC('week',CURRENT_DATE) - INTERVAL '{timeframe_weeks} weeks' AND CURRENT_DATE-1
            AND p.product_part_number IN (SELECT product_part_number FROM vendor_skus)
        GROUP BY 1,2,3
    ),

    -- ============================================================================
    -- FINAL RESULTS TABLE
    -- ============================================================================
    final AS (
        SELECT
            p.product_company_description,
            p.product_part_number,
            p.product_name,
            p.parent_company,
            p.product_manufacturer_name,
            p.product_merch_classification1,
            p.product_merch_classification2,
            p.product_merch_classification3,
            p.product_category_level1,
            p.product_category_level2,
            p.product_category_level3,
            p.private_label_flag,
            CASE WHEN IFNULL(p.attribute_onetimebuy_flag,FALSE) = TRUE THEN 'OTB_current'
                 WHEN otb.product_part_number IS NOT NULL THEN 'OTB_T365'
                 ELSE NULL END as OTB_ind,
            IFNULL(p.product_is_compound,FALSE) as product_is_compound,
            p.product_discontinued_flag,
            p.demand_planner,
            p.product_published_flag,
            IFNULL(p.product_dropship_flag,FALSE) as product_dropship_flag,
            cd.week_date,
            'exclude' as OOS_ind,
            CASE WHEN p.product_discontinued_flag = TRUE AND cd.week_date >= DATE_TRUNC('week',p.product_discontinue_dttm::DATE)::DATE THEN 'disco_item'
                 WHEN cd.week_date - IFNULL(p.product_first_publication_dttm::DATE,CURRENT_DATE) <= 0 THEN 'new_item_pre_launch'
                 WHEN cd.week_date - IFNULL(p.product_first_publication_dttm::DATE,CURRENT_DATE) BETWEEN 1 AND 119 THEN 'new_item_post_launch_<120' 
                 WHEN cd.week_date - IFNULL(p.product_first_publication_dttm::DATE,CURRENT_DATE) BETWEEN 120 AND 270 THEN 'new_item_post_launch_120+'
                 ELSE 'mature_item' END as item_type_ind_time_phased,
            SUM(LT_blended_fcst) as LT_blended_fcst,
            SUM(olm_units_ordered) as actuals,
            ABS(ZEROIFNULL(SUM(LT_blended_fcst)) - ZEROIFNULL(SUM(olm_units_ordered))) as LT_blended_abs_error
        FROM vendor_skus vs
        JOIN edldb.chewybi.products p ON p.product_part_number = vs.product_part_number
        CROSS JOIN (
            SELECT DISTINCT
                DATE_TRUNC('week',common_date_dttm)::DATE as week_date
            FROM edldb.chewybi.common_date cd
            WHERE 1=1
                AND common_date_dttm BETWEEN DATE_TRUNC('week',CURRENT_DATE) - INTERVAL '{timeframe_weeks} weeks' AND CURRENT_DATE-1
        ) cd
        CROSS JOIN (
            SELECT TRUE as OOS_flag
            UNION ALL
            SELECT FALSE as OOS_flag
        ) ooscj
        LEFT JOIN (
            SELECT DISTINCT
                product_part_number,
                TRUE as OTB_flag_T365
            FROM edldb.chewybi.product_lifecycle_snapshot
            WHERE 1=1
                AND attribute_onetimebuy_flag = TRUE
                AND snapshot_date BETWEEN CURRENT_DATE-364 AND CURRENT_DATE
        ) otb ON otb.product_part_number = p.product_part_number
        LEFT JOIN demand d ON d.product_part_number = p.product_part_number 
            AND d.week_date = cd.week_date AND d.OOS_flag = ooscj.OOS_flag
        LEFT JOIN LT_blended_fcst ltblf ON ltblf.product_part_number = p.product_part_number 
            AND ltblf.week_date = cd.week_date AND ltblf.OOS_flag = ooscj.OOS_flag
        WHERE 1=1
            AND p.product_company_description IN ('Chewy','Chewy Pharmacy','Chewy Canada')
            AND p.bundle_flag_type = 'Item'
            AND p.product_type = 'Item'
        GROUP BY ALL
    ),

    -- ============================================================================
    -- FINAL QUERY - VENDOR, MC1, MC2, BRAND, AND TOP SKUS ANALYSIS WITH WEEKLY BREAKDOWN
    -- ============================================================================
    -- Total error for contribution calculations
    total_error AS (
        SELECT SUM(LT_blended_abs_error) as total_abs_error_lt
        FROM final
        WHERE 1=1
            AND oos_ind = 'exclude'
            AND OTB_ind IS NULL
            AND item_type_ind_time_phased NOT IN ('new_item_pre_launch','disco_item')
            AND product_company_description = 'Chewy'
    ),
    
    -- Vendor level summary with weekly breakdown
    vendor_summary AS (
        SELECT 
            'Total Vendor' as field,
            NULL as product_name,
            'Vendor' as cut,
            0 as priority_cut,
            (SUM(LT_blended_abs_error) / NULLIFZERO(te.total_abs_error_lt)) as weighted_error_contribution,
            SUM(LT_blended_abs_error) / NULLIFZERO(SUM(actuals)) as LT_WAPE_{trailing_weeks_suffix},
            SUM(LT_blended_fcst) / NULLIFZERO(SUM(actuals)) - 1 as LT_BIAS_{trailing_weeks_suffix},
            {weekly_columns_sql}
        FROM final f
        CROSS JOIN total_error te
        WHERE 1=1
            AND f.oos_ind = 'exclude'
            AND f.OTB_ind IS NULL
            AND f.item_type_ind_time_phased NOT IN ('new_item_pre_launch','disco_item')
            AND f.product_company_description = 'Chewy'
        GROUP BY te.total_abs_error_lt
    ),
    
    -- MC1 summary with weekly breakdown
    mc1_summary AS (
        SELECT 
            f.product_merch_classification1 as field,
            NULL as product_name,
            'MC1' as cut,
            1 as priority_cut,
            (SUM(f.LT_blended_abs_error) / NULLIFZERO(te.total_abs_error_lt)) as weighted_error_contribution,
            SUM(f.LT_blended_abs_error) / NULLIFZERO(SUM(f.actuals)) as LT_WAPE_{trailing_weeks_suffix},
            SUM(f.LT_blended_fcst) / NULLIFZERO(SUM(f.actuals)) - 1 as LT_BIAS_{trailing_weeks_suffix},
            {weekly_columns_sql}
        FROM final f
        CROSS JOIN total_error te
        WHERE 1=1
            AND f.oos_ind = 'exclude'
            AND f.OTB_ind IS NULL
            AND f.item_type_ind_time_phased NOT IN ('new_item_pre_launch','disco_item')
            AND f.product_company_description = 'Chewy'
        GROUP BY f.product_merch_classification1, te.total_abs_error_lt
    ),
    
    -- MC2 summary with weekly breakdown
    mc2_summary AS (
        SELECT 
            f.product_merch_classification2 as field,
            NULL as product_name,
            'MC2' as cut,
            2 as priority_cut,
            (SUM(f.LT_blended_abs_error) / NULLIFZERO(te.total_abs_error_lt)) as weighted_error_contribution,
            SUM(f.LT_blended_abs_error) / NULLIFZERO(SUM(f.actuals)) as LT_WAPE_{trailing_weeks_suffix},
            SUM(f.LT_blended_fcst) / NULLIFZERO(SUM(f.actuals)) - 1 as LT_BIAS_{trailing_weeks_suffix},
            {weekly_columns_sql}
        FROM final f
        CROSS JOIN total_error te
        WHERE 1=1
            AND f.oos_ind = 'exclude'
            AND f.OTB_ind IS NULL
            AND f.item_type_ind_time_phased NOT IN ('new_item_pre_launch','disco_item')
            AND f.product_company_description = 'Chewy'
        GROUP BY f.product_merch_classification2, te.total_abs_error_lt
    ),
    
    -- Brand summary (top brands by demand) with weekly breakdown
    top_brands AS (
        SELECT product_manufacturer_name
        FROM final
        WHERE 1=1
            AND oos_ind = 'exclude'
            AND OTB_ind IS NULL
            AND item_type_ind_time_phased NOT IN ('new_item_pre_launch','disco_item')
            AND product_company_description = 'Chewy'
        GROUP BY product_manufacturer_name
        ORDER BY SUM(actuals) DESC
        LIMIT 10
    ),
    
    brand_summary AS (
        SELECT 
            f.product_manufacturer_name as field,
            NULL as product_name,
            'Top by Demand' as cut,
            3 as priority_cut,
            (SUM(f.LT_blended_abs_error) / NULLIFZERO(te.total_abs_error_lt)) as weighted_error_contribution,
            SUM(f.LT_blended_abs_error) / NULLIFZERO(SUM(f.actuals)) as LT_WAPE_{trailing_weeks_suffix},
            SUM(f.LT_blended_fcst) / NULLIFZERO(SUM(f.actuals)) - 1 as LT_BIAS_{trailing_weeks_suffix},
            {weekly_columns_sql}
        FROM final f
        JOIN top_brands tb ON f.product_manufacturer_name = tb.product_manufacturer_name
        CROSS JOIN total_error te
        WHERE 1=1
            AND f.oos_ind = 'exclude'
            AND f.OTB_ind IS NULL
            AND f.item_type_ind_time_phased NOT IN ('new_item_pre_launch','disco_item')
            AND f.product_company_description = 'Chewy'
        GROUP BY f.product_manufacturer_name, te.total_abs_error_lt
    ),
    
    -- Top 30 SKUs by error contribution with weekly breakdown
    item_base AS (
        SELECT 
            f.product_part_number as field,
            p.product_name as product_name,
            'Top Item Error Contribution' as cut,
            4 as priority_cut,
            (SUM(f.LT_blended_abs_error) / NULLIFZERO(te.total_abs_error_lt)) as weighted_error_contribution,
            SUM(f.LT_blended_abs_error) / NULLIFZERO(SUM(f.actuals)) as LT_WAPE_{trailing_weeks_suffix},
            SUM(f.LT_blended_fcst) / NULLIFZERO(SUM(f.actuals)) - 1 as LT_BIAS_{trailing_weeks_suffix},
            {weekly_columns_sql}
        FROM final f
        JOIN edldb.chewybi.products p ON p.product_part_number = f.product_part_number
        CROSS JOIN total_error te
        WHERE 1=1
            AND f.oos_ind = 'exclude'
            AND f.OTB_ind IS NULL
            AND f.item_type_ind_time_phased NOT IN ('new_item_pre_launch','disco_item')
            AND f.product_company_description = 'Chewy'
        GROUP BY f.product_part_number, p.product_name, te.total_abs_error_lt
    ),
    
    item_ranked AS (
        SELECT *
        FROM item_base
        WHERE weighted_error_contribution IS NOT NULL
            AND weighted_error_contribution > 0
        ORDER BY weighted_error_contribution DESC
        LIMIT 30
    )

    -- Combine all results
    SELECT * FROM vendor_summary
    UNION ALL
    SELECT * FROM mc1_summary  
    UNION ALL
    SELECT * FROM mc2_summary
    UNION ALL
    SELECT * FROM brand_summary
    UNION ALL
    SELECT * FROM item_ranked
    ORDER BY priority_cut, COALESCE(weighted_error_contribution, 0) DESC
    """
    
    # Return query with column mapping for weekly columns
    return query, column_mapping


def generate_demand_query(vendor_numbers, start_date, end_date, aggregation, include_dropship=False, selected_forecasts=None):
    """Generate comprehensive demand analysis query with configurable forecast types"""
    
    # Focus on LT_blended only for now
    if selected_forecasts is None:
        selected_forecasts = ['LT_blended']  # Only LT_blended for focused optimization
    
    # Get dynamic timeframe from session state
    timeframe_weeks = st.session_state.get('weeks_back', 2)  # Default to 2 weeks for backward compatibility
    
    # Calculate week dates for dynamic columns
    week_dates = calculate_week_dates(timeframe_weeks)
    
    # Calculate actual start and end dates from week_dates
    end_date_str = week_dates[0]  # Most recent week (Monday)
    start_date_str = week_dates[-1]  # Oldest week (Monday)
    
    # Convert to datetime objects for SQL date format
    from datetime import datetime, timedelta
    start_date_actual = datetime.strptime(start_date_str, '%m/%d/%Y').strftime('%Y-%m-%d')
    
    # For end_date, we need to include the full week (Monday through Sunday)
    # Add 6 days to the Monday to get the Sunday of that week
    end_date_monday = datetime.strptime(end_date_str, '%m/%d/%Y')
    end_date_sunday = end_date_monday + timedelta(days=6)
    end_date_actual = end_date_sunday.strftime('%Y-%m-%d')
    
    # Generate dynamic weekly columns for selected forecast types
    def generate_weekly_forecast_columns(week_dates, enabled_forecast_types):
        """Generate weekly forecast column SQL and column mapping for enabled forecast types"""
        column_sql_parts = []
        column_mapping = {}
        
        for i, week_date_str in enumerate(week_dates, 1):
            week_date_sql = datetime.strptime(week_date_str, '%m/%d/%Y').strftime('%Y-%m-%d')
            
            for forecast_type in enabled_forecast_types:
                # WAPE columns
                wape_col = f"W{i}_{forecast_type}_WAPE"
                wape_sql = f"""
                    SUM(CASE WHEN DATE_TRUNC('week', fd.week_date) = DATE_TRUNC('week', '{week_date_sql}'::date) 
                             THEN fd.{forecast_type}_abs_error ELSE 0 END) / 
                    NULLIFZERO(SUM(CASE WHEN DATE_TRUNC('week', fd.week_date) = DATE_TRUNC('week', '{week_date_sql}'::date) 
                                        THEN fd.actuals ELSE 0 END)) as {wape_col}"""
                column_sql_parts.append(wape_sql)
                column_mapping[wape_col.upper()] = f"{week_date_str}_{forecast_type}_WAPE"
                
                # Bias columns  
                bias_col = f"W{i}_{forecast_type}_Bias"
                bias_sql = f"""
                    (SUM(CASE WHEN DATE_TRUNC('week', fd.week_date) = DATE_TRUNC('week', '{week_date_sql}'::date) 
                              THEN fd.{forecast_type}_fcst ELSE 0 END) / 
                     NULLIFZERO(SUM(CASE WHEN DATE_TRUNC('week', fd.week_date) = DATE_TRUNC('week', '{week_date_sql}'::date) 
                                         THEN fd.actuals ELSE 0 END)) - 1) as {bias_col}"""
                column_sql_parts.append(bias_sql)
                column_mapping[bias_col.upper()] = f"{week_date_str}_{forecast_type}_Bias"
        
        return ',\n                '.join(column_sql_parts), column_mapping
    
    # Generate weekly column SQL and mapping
    weekly_columns_sql, column_mapping = generate_weekly_forecast_columns(week_dates, selected_forecasts)
    
    # Get vendor list for filtering
    vendor_list = "', '".join(vendor_numbers)
    
    # Dropship filter logic
    dropship_filter = ""
    if not include_dropship:
        dropship_filter = "AND p.product_dropship_flag = false"
    
    # Calculate actual lead times for this vendor using Python query
    def calculate_vendor_lead_times():
        """Calculate actual lead times for the selected vendor(s) to use as constants"""
        try:
            session = get_snowflake_session()
            if not session:
                return {'min_lt': 1, 'max_lt': 14, 'avg_lt': 14, 'sku_count': 0}
            lead_time_query = f"""
            WITH vendor_skus AS (
                SELECT DISTINCT
                    v.vendor_number as vendor_number,
                    v.vendor_name as vendor_name,
                    p.product_part_number as product_part_number,
                    p.product_manufacturer_name
                FROM EDLDB.CHEWYBI.vendor_agreement_line vl
                LEFT JOIN edldb.chewybi.products p ON p.product_part_number = vl.product_part_number
                LEFT JOIN edldb.chewybi.vendors v ON v.vendor_number = vl.vendor_number
                WHERE CURRENT_DATE BETWEEN COALESCE(agreement_line_start_date::DATE, CURRENT_DATE)
                    AND COALESCE(agreement_line_end_date::DATE, CURRENT_DATE)
                    AND COALESCE(disabled_reason_code,'') = ''
                    AND COALESCE(agreement_line_status,'') NOT IN ('CANCELED')
                    AND v.vendor_number IN ({','.join([f"'{v}'" for v in vendor_numbers])})
                    {dropship_filter}
            ),
            
            LT_calc AS (
                SELECT
                    p.product_part_number,
                    least(coalesce(nullifzero(it.LT_cal_days_item_ntwk), nullifzero(br.LT_cal_days_brand_ntwk), 14), 180) as adj_avg_lead_time
                FROM edldb.chewybi.products p
                JOIN vendor_skus vs ON vs.product_part_number = p.product_part_number
                LEFT JOIN (
                    SELECT
                        item_id,
                        round(avg(LT_bus_days_item_FC), 0)::integer as LT_bus_days_item_ntwk,
                        round(avg(LT_bus_days_item_FC) / 6 * 2 + avg(LT_bus_days_item_FC), 0)::integer as LT_cal_days_item_ntwk
                    FROM (
                        -- US data from SOCRATES
                        SELECT 
                            silv.ITEM_ID,
                            avg(vl.VENDOR_LEAD_TIME_BUSINESS_DAYS) as LT_bus_days_item_FC
                        FROM EDLDB.SC_REPLENISHMENT_SANDBOX.SOCRATES_ITEM_LOCATION_VENDOR silv
                        LEFT JOIN edldb.chewybi.vendor_location vl ON vl.vendor_number = silv.VENDOR_ID AND vl.LOCATION_CODE = silv.LOCATION_CODE
                        WHERE silv.job_start_time = (SELECT max(job_start_time) FROM EDLDB.SC_REPLENISHMENT_SANDBOX.SOCRATES_ITEM_LOCATION_VENDOR)
                            AND silv.ITEM_ID IN (SELECT product_part_number FROM vendor_skus)
                        GROUP BY silv.ITEM_ID
                        
                        UNION ALL
                        
                        -- Canada data from item_location_vendor
                        SELECT
                            ilv.product_part_number as ITEM_ID,
                            round(avg(ilv.vendor_lead_time_business_days),0) as LT_bus_days_item_FC
                        FROM edldb.chewybi.item_location_vendor ilv
                        LEFT JOIN edldb.chewybi.products p ON p.product_part_number = ilv.product_part_number
                        WHERE ilv.snapshot_date = current_date
                            AND p.product_company_description IN ('Chewy Canada')
                            AND ilv.vendor_lead_time_business_days > 0
                            AND p.product_part_number IN (SELECT product_part_number FROM vendor_skus)
                        GROUP BY ilv.product_part_number
                    ) socrates_data
                    GROUP BY item_id
                ) it ON it.item_id = p.product_part_number
                LEFT JOIN (
                    SELECT
                        product_company_description,
                        product_manufacturer_name,
                        round(avg(LT_bus_days_item_FC), 0)::integer as LT_bus_days_brand_ntwk,
                        round(avg(LT_bus_days_item_FC) / 6 * 2 + avg(LT_bus_days_item_FC), 0)::integer as LT_cal_days_brand_ntwk
                    FROM (
                        -- US brand data from SOCRATES
                        SELECT 
                            p.product_manufacturer_name,
                            p.product_company_description,
                            avg(vl.VENDOR_LEAD_TIME_BUSINESS_DAYS) as LT_bus_days_item_FC
                        FROM EDLDB.SC_REPLENISHMENT_SANDBOX.SOCRATES_ITEM_LOCATION_VENDOR silv
                        LEFT JOIN edldb.chewybi.vendor_location vl ON vl.vendor_number = silv.VENDOR_ID AND vl.LOCATION_CODE = silv.LOCATION_CODE
                        LEFT JOIN edldb.chewybi.products p ON p.product_part_number = silv.item_id
                        WHERE silv.job_start_time = (SELECT max(job_start_time) FROM EDLDB.SC_REPLENISHMENT_SANDBOX.SOCRATES_ITEM_LOCATION_VENDOR)
                            AND silv.ITEM_ID IN (SELECT product_part_number FROM vendor_skus)
                        GROUP BY p.product_manufacturer_name, p.product_company_description
                        
                        UNION ALL
                        
                        -- Canada brand data from item_location_vendor
                        SELECT
                            p.product_manufacturer_name,
                            p.product_company_description,
                            round(avg(ilv.vendor_lead_time_business_days),0) as LT_bus_days_item_FC
                        FROM edldb.chewybi.item_location_vendor ilv
                        LEFT JOIN edldb.chewybi.products p ON p.product_part_number = ilv.product_part_number
                        WHERE ilv.snapshot_date = current_date
                            AND p.product_company_description IN ('Chewy Canada')
                            AND ilv.vendor_lead_time_business_days > 0
                            AND p.product_part_number IN (SELECT product_part_number FROM vendor_skus)
                        GROUP BY p.product_manufacturer_name, p.product_company_description
                    ) socrates_brand_data
                    GROUP BY product_company_description, product_manufacturer_name
                ) br ON br.product_company_description = p.product_company_description AND br.product_manufacturer_name = p.product_manufacturer_name
                WHERE p.bundle_flag_type = 'Item'
                    AND p.product_type = 'Item'
                    AND p.product_company_description IN ('Chewy', 'Chewy Pharmacy', 'Chewy Canada')
            )
            
            SELECT 
                MIN(adj_avg_lead_time) as min_lt,
                MAX(adj_avg_lead_time) as max_lt,
                ROUND(AVG(adj_avg_lead_time)) as avg_lt,
                COUNT(*) as sku_count
            FROM LT_calc
            """
            
            result = session.sql(lead_time_query).to_pandas()
            if len(result) > 0 and not result.iloc[0].isnull().all():
                min_lt = int(result.iloc[0]['MIN_LT']) if result.iloc[0]['MIN_LT'] else 1
                max_lt = int(result.iloc[0]['MAX_LT']) if result.iloc[0]['MAX_LT'] else 14
                avg_lt = int(result.iloc[0]['AVG_LT']) if result.iloc[0]['AVG_LT'] else 14
                sku_count = int(result.iloc[0]['SKU_COUNT']) if result.iloc[0]['SKU_COUNT'] else 0
                
                return {
                    'min_lt': min_lt,
                    'max_lt': max_lt, 
                    'avg_lt': avg_lt,
                    'sku_count': sku_count
                }
            else:
                # Fallback values if no data
                return {'min_lt': 1, 'max_lt': 14, 'avg_lt': 14, 'sku_count': 0}
                
        except Exception as e:
            st.warning(f"Could not calculate vendor lead times, using defaults: {e}")
            return {'min_lt': 1, 'max_lt': 14, 'avg_lt': 14, 'sku_count': 0}
    
    # Calculate actual lead times for this vendor
    lead_times = calculate_vendor_lead_times()
    min_lead_time = lead_times['min_lt']
    max_lead_time = lead_times['max_lt'] 
    avg_lead_time = lead_times['avg_lt']
    
    query = f"""
        WITH vendor_skus AS (
            SELECT DISTINCT
                v.vendor_number as vendor_number,
                v.vendor_name as vendor_name,
                p.product_part_number as product_part_number,
                p.product_manufacturer_name
            FROM EDLDB.CHEWYBI.vendor_agreement_line vl
            LEFT JOIN edldb.chewybi.products p ON p.product_part_number = vl.product_part_number
            LEFT JOIN edldb.chewybi.vendors v ON v.vendor_number = vl.vendor_number
            WHERE CURRENT_DATE BETWEEN COALESCE(agreement_line_start_date::DATE, CURRENT_DATE)
                AND COALESCE(agreement_line_end_date::DATE, CURRENT_DATE)
                AND COALESCE(disabled_reason_code,'') = ''
                AND COALESCE(agreement_line_status,'') NOT IN ('CANCELED')
                AND v.vendor_number IN ('{vendor_list}')
                {dropship_filter}
        ),
        
        -- Lead Time calculation using Steven's comprehensive approach
        socrates_ilv_LT AS (
            SELECT 
                silv.ITEM_ID,
                silv.location_code,
                p.product_manufacturer_name,
                p.product_company_description,
                avg(vl.VENDOR_LEAD_TIME_BUSINESS_DAYS) as LT_bus_days_item_FC
            FROM (
                SELECT *
                FROM EDLDB.SC_REPLENISHMENT_SANDBOX.SOCRATES_ITEM_LOCATION_VENDOR silv
                WHERE job_start_time = (SELECT max(job_start_time) FROM EDLDB.SC_REPLENISHMENT_SANDBOX.SOCRATES_ITEM_LOCATION_VENDOR)
                    AND silv.ITEM_ID IN (SELECT product_part_number FROM vendor_skus)
            ) silv
            LEFT JOIN (
                SELECT *
                FROM edldb.chewybi.vendor_location vl 
                WHERE snapshot_date = (SELECT max(snapshot_date) FROM edldb.chewybi.vendor_location)
            ) vl ON vl.vendor_number = silv.VENDOR_ID AND vl.LOCATION_CODE = silv.LOCATION_CODE
            LEFT JOIN edldb.chewybi.products p ON p.product_part_number = silv.item_id
            WHERE p.product_part_number IN (SELECT product_part_number FROM vendor_skus)
            GROUP BY silv.ITEM_ID, silv.location_code, p.product_manufacturer_name, p.product_company_description

            UNION ALL

            SELECT
                ilv.product_part_number,
                ilv.location_code,
                p.product_manufacturer_name,
                p.product_company_description,
                round(avg(ilv.vendor_lead_time_business_days),0) as LT_bus_days_item_FC
            FROM edldb.chewybi.item_location_vendor ilv
            LEFT JOIN edldb.chewybi.products p ON p.product_part_number = ilv.product_part_number
            WHERE ilv.snapshot_date = current_date
                AND p.product_company_description IN ('Chewy Canada')
                AND ilv.vendor_lead_time_business_days > 0
                AND p.product_part_number IN (SELECT product_part_number FROM vendor_skus)
            GROUP BY ilv.product_part_number, ilv.location_code, p.product_manufacturer_name, p.product_company_description
        ),
        
        -- Lead Time aggregation and fallback logic
        LT AS (
            SELECT
                p.product_part_number,
                p.product_key,
                p.product_company_description,
                p.product_merch_classification1,
                p.product_manufacturer_name,
                p.private_label_flag,
                p.product_dropship_flag,
                p.product_status,
                it.LT_bus_days_item_ntwk,
                it.LT_cal_days_item_ntwk,
                br.LT_bus_days_brand_ntwk,
                br.LT_cal_days_brand_ntwk,
                least(coalesce(nullifzero(it.LT_cal_days_item_ntwk), nullifzero(br.LT_cal_days_brand_ntwk), 14), 180) as adj_avg_lead_time
            FROM edldb.chewybi.products p
            JOIN vendor_skus vs ON vs.product_part_number = p.product_part_number
            LEFT JOIN (
                SELECT
                    item_id,
                    round(avg(LT_bus_days_item_FC), 0)::integer as LT_bus_days_item_ntwk,
                    round(avg(LT_bus_days_item_FC) / 6 * 2 + avg(LT_bus_days_item_FC), 0)::integer as LT_cal_days_item_ntwk
                FROM socrates_ilv_LT
                GROUP BY item_id
            ) it ON it.item_id = p.product_part_number
            LEFT JOIN (
                SELECT
                    product_company_description,
                    product_manufacturer_name,
                    round(avg(LT_bus_days_item_FC), 0)::integer as LT_bus_days_brand_ntwk,
                    round(avg(LT_bus_days_item_FC) / 6 * 2 + avg(LT_bus_days_item_FC), 0)::integer as LT_cal_days_brand_ntwk
                FROM socrates_ilv_LT
                GROUP BY product_company_description, product_manufacturer_name
            ) br ON br.product_company_description = p.product_company_description AND br.product_manufacturer_name = p.product_manufacturer_name
            WHERE p.bundle_flag_type = 'Item'
                AND p.product_type = 'Item'
                AND p.product_company_description IN ('Chewy', 'Chewy Pharmacy', 'Chewy Canada')
        ),
        
        -- Out of Stock days tracking using user's date ranges
        OOS_days AS (
            WITH pdp_oos AS (
                SELECT
                    product_part_number,
                    mps.activity_date,
                    sum(mps.Total_PDP_Views) as Total_PDP_Views,
                    sum(mps.OutofStock_PDP_Views) as OutofStock_PDP_Views
                FROM edldb.mrch.merch_performance_snapshot_pharmacy mps
                WHERE mps.activity_date BETWEEN '{start_date_actual}'::date AND '{end_date_actual}'::date
                    AND Total_PDP_Views > 0
                    AND product_part_number IN (SELECT product_part_number FROM vendor_skus)
                GROUP BY product_part_number, mps.activity_date
            ),
            
            inv_snapshot_oos AS (
                SELECT DISTINCT
                    oos.inventory_out_of_stock_item,
                    oos.inventory_out_of_stock_snapshot_date,
                    true as inv_snapshot_oos_flag
                FROM edldb.chewybi.inventory_out_of_stock_snapshot oos
                LEFT JOIN pdp_oos poos ON poos.product_part_number = oos.inventory_out_of_stock_item 
                    AND poos.activity_date = oos.inventory_out_of_stock_snapshot_date
                WHERE (oos.inventory_out_of_stock_available_qty <= 0 OR oos.inventory_out_of_stock_reservedforsubs_flag = 'true')
                    AND oos.inventory_out_of_stock_snapshot_date BETWEEN '{start_date_actual}'::date AND '{end_date_actual}'::date
                    AND poos.product_part_number IS NULL
                    AND oos.inventory_out_of_stock_item IN (SELECT product_part_number FROM vendor_skus)
            )
            
            SELECT
                p.product_part_number,
                p.product_key,
                poos.product_part_number as inventory_out_of_stock_item,
                activity_date as inventory_out_of_stock_snapshot_date
            FROM pdp_oos poos
            LEFT JOIN edldb.chewybi.products p ON p.product_part_number = poos.product_part_number
            WHERE zeroifnull(OutofStock_PDP_Views) / nullifzero(Total_PDP_Views) >= 0.1

            UNION ALL

            SELECT
                p.product_part_number,
                p.product_key,
                inventory_out_of_stock_item,
                inventory_out_of_stock_snapshot_date
            FROM inv_snapshot_oos oos
            LEFT JOIN edldb.chewybi.products p ON p.product_part_number = oos.inventory_out_of_stock_item
        ),
        
        -- STEVEN'S CORRECT CTE: Proper structure with optimized date filtering
        LT_blended_fcst AS (
            SELECT
                fs.product_part_number,
                date_trunc('week', fs.forecast_date)::date as week_date,
                CASE WHEN oos.product_key IS NOT NULL THEN true ELSE false END as OOS_flag,
                sum(fs.fcst_qty)::numeric(38,3) as LT_blended_fcst
            FROM edldb.sc_sandbox.blended_fcst_item_day_network_colt fs
            LEFT JOIN OOS_days oos ON oos.product_part_number = fs.product_part_number 
                AND oos.inventory_out_of_stock_snapshot_date = fs.forecast_date
            LEFT JOIN LT lt ON lt.product_part_number = fs.product_part_number
            WHERE fs.forecast_date BETWEEN '{start_date_actual}'::date AND '{end_date_actual}'::date
                -- OPTIMIZED: Use Python-calculated lead time constant for performance
                AND fs.snapshot_date = least(fs.forecast_date - {avg_lead_time}, current_date)
                AND fs.product_part_number IN (SELECT product_part_number FROM vendor_skus)
            GROUP BY fs.product_part_number, date_trunc('week', fs.forecast_date)::date,
                     CASE WHEN oos.product_key IS NOT NULL THEN true ELSE false END
        ),

        -- Steven's demand actuals with OOS tracking
        demand AS (
            SELECT
                p.product_part_number,
                date_trunc('week', olm.order_placed_date)::date as week_date,
                CASE WHEN oos.product_key IS NOT NULL THEN true ELSE false END as OOS_flag,
                sum(olm.order_line_quantity)::numeric(38,3) as actuals
            FROM edldb.chewybi.order_line_measures olm
            LEFT JOIN OOS_days oos ON oos.product_key = olm.product_key 
                AND oos.inventory_out_of_stock_snapshot_date = olm.order_placed_date
            LEFT JOIN edldb.chewybi.products p ON p.product_key = olm.product_key
            WHERE olm.order_line_each_price <> 0  -- Exclude replacements
                AND olm.order_order_line_status NOT IN ('X','J')  -- Exclude cancelled and dummy orders
                AND olm.order_placed_date BETWEEN '{start_date_actual}'::date AND '{end_date_actual}'::date
                AND p.product_part_number IN (SELECT product_part_number FROM vendor_skus)
            GROUP BY p.product_part_number, date_trunc('week', olm.order_placed_date)::date,
                     CASE WHEN oos.product_key IS NOT NULL THEN true ELSE false END
        ),

        -- Steven's comprehensive final dataset excluding OOS and NULL forecasts
        forecast_demand_base AS (
            SELECT
                p.product_part_number,
                p.product_manufacturer_name,
                p.product_merch_classification1,
                p.product_merch_classification2,
                d.week_date,
                false as oos_flag,  -- Exclude OOS as per Steven's requirement
                d.actuals,
                
                -- LT_blended forecast only (keep NULLs as NULLs, don't convert to 0)
                ltb.LT_blended_fcst as LT_blended_fcst,
                
                -- Calculate absolute error for LT_blended (NULLs will be excluded from SUM)
                ABS(ltb.LT_blended_fcst - d.actuals) as LT_blended_abs_error
                
            FROM demand d
            LEFT JOIN edldb.chewybi.products p ON p.product_part_number = d.product_part_number
            LEFT JOIN LT_blended_fcst ltb ON ltb.product_part_number = d.product_part_number 
                AND ltb.week_date = d.week_date AND ltb.OOS_flag = d.OOS_flag
            WHERE d.OOS_flag = false  -- Steven's OOS exclusion requirement
                AND ltb.LT_blended_fcst IS NOT NULL  -- Exclude records with NULL forecasts
                AND d.actuals IS NOT NULL  -- Exclude records with NULL actuals
        ),
        
        -- Top brands by demand for prioritization
        top_brands AS (
            SELECT 
                fd.product_manufacturer_name,
                SUM(fd.actuals) as total_demand
            FROM forecast_demand_base fd
            GROUP BY fd.product_manufacturer_name
            ORDER BY total_demand DESC 
            LIMIT 10
        ),
        
        -- Calculate total absolute error for weighted contribution calculation
        total_error AS (
            SELECT 
                SUM(fd.LT_blended_abs_error) as total_abs_error_lt
            FROM forecast_demand_base fd
        ),
        
        vendor_summary AS (
            SELECT 
                vs.vendor_name as field,
                NULL as product_name,
                'Vendor' as cut,
                0 as priority_cut,
                -- Weighted Error Contribution for LT_blended (primary metric) - as percentage
                (SUM(fd.LT_blended_abs_error) / NULLIFZERO(te.total_abs_error_lt)) as weighted_error_contribution,
                {weekly_columns_sql}
            FROM forecast_demand_base fd
            JOIN vendor_skus vs ON fd.product_part_number = vs.product_part_number
            CROSS JOIN total_error te
            GROUP BY vs.vendor_name, te.total_abs_error_lt
        ),
        
        mc1_summary AS (
            SELECT 
                fd.product_merch_classification1 as field,
                NULL as product_name,
                'MC1' as cut,
                1 as priority_cut,
                (SUM(fd.LT_blended_abs_error) / NULLIFZERO(te.total_abs_error_lt)) as weighted_error_contribution,
                {weekly_columns_sql}
            FROM forecast_demand_base fd
            CROSS JOIN total_error te
            GROUP BY fd.product_merch_classification1, te.total_abs_error_lt
        ),
        
        mc2_summary AS (
            SELECT 
                fd.product_merch_classification2 as field,
                NULL as product_name,
                'MC2' as cut,
                2 as priority_cut,
                (SUM(fd.LT_blended_abs_error) / NULLIFZERO(te.total_abs_error_lt)) as weighted_error_contribution,
                {weekly_columns_sql}
            FROM forecast_demand_base fd
            CROSS JOIN total_error te
            GROUP BY fd.product_merch_classification2, te.total_abs_error_lt
        ),
        
        brand_summary AS (
            SELECT 
                fd.product_manufacturer_name as field,
                NULL as product_name,
                'Top by Demand' as cut,
                3 as priority_cut,
                (SUM(fd.LT_blended_abs_error) / NULLIFZERO(te.total_abs_error_lt)) as weighted_error_contribution,
                {weekly_columns_sql}
            FROM forecast_demand_base fd
            JOIN top_brands tb ON fd.product_manufacturer_name = tb.product_manufacturer_name
            CROSS JOIN total_error te
            GROUP BY fd.product_manufacturer_name, te.total_abs_error_lt
        ),
        
        item_base AS (
            SELECT 
                fd.product_part_number as field,
                p.product_name as product_name,
                'Top Item Error Contribution' as cut,
                4 as priority_cut,
                -- Weighted Error Contribution: (Individual SKU absolute error) / (Total absolute error across all SKUs)
                (SUM(fd.LT_blended_abs_error) / NULLIFZERO(te.total_abs_error_lt)) as weighted_error_contribution,
                {weekly_columns_sql}
            FROM forecast_demand_base fd
            JOIN edldb.chewybi.products p ON p.product_part_number = fd.product_part_number
            CROSS JOIN total_error te
            GROUP BY fd.product_part_number, p.product_name, te.total_abs_error_lt
        ),
        
        item_ranked AS (
            SELECT *
            FROM item_base
            WHERE weighted_error_contribution IS NOT NULL
            ORDER BY weighted_error_contribution DESC
            LIMIT 30
        )
        
        SELECT * FROM vendor_summary
        UNION ALL
        SELECT * FROM mc1_summary
        UNION ALL
        SELECT * FROM mc2_summary  
        UNION ALL
        SELECT * FROM brand_summary
        UNION ALL
        SELECT * FROM item_ranked
        ORDER BY priority_cut, COALESCE(weighted_error_contribution, 0) DESC
    """
    
    return query, column_mapping


