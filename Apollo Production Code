def create_ontime_trend_charts(ontime_data, column_mapping):
    """Create trend charts for On Time data"""
    
    def format_contribution_safe(value):
        """Safely format contribution values, handling N/A and string percentages"""
        if pd.isna(value) or value == 'N/A' or value == '':
            return "0%"
        if isinstance(value, str):
            if value.endswith('%'):
                try:
                    return value  # Already formatted as percentage
                except:
                    return "0%"
            else:
                try:
                    return f"{float(value) * 100:.1f}%"
                except ValueError:
                    return "0%"
        else:
            try:
                return f"{float(value) * 100:.1f}%"
            except:
                return "0%"
    
    try:
        import altair as alt
        
        # Get on time rate columns (weekly data) - check both original and mapped column names
        ontime_rate_cols = [col for col in ontime_data.columns if col.startswith('W') and col.endswith('_ONTIME_RATE')]
        
        # Also check for mapped column names (after column mapping is applied)
        if not ontime_rate_cols:
            ontime_rate_cols = [col for col in ontime_data.columns if 'ONTIME_RATE' in col and any(char.isdigit() for char in col)]
        
        # Check for the actual format we have: "MM/DD ONTIME RATE" (with space, not underscore)
        if not ontime_rate_cols:
            ontime_rate_cols = [col for col in ontime_data.columns if 'ONTIME RATE' in col and any(char.isdigit() for char in col)]
        
        if not ontime_rate_cols:
            st.warning("No weekly On Time Rate data found for charting.")
            return
        
        # Get available cut types
        available_cuts = ontime_data['CUT'].unique() if 'CUT' in ontime_data.columns else []
        
        # Filter to include vendor, MC1/MC2, brand, and freight terms data
        preferred_cuts = ['Vendor', 'MC1', 'MC2', 'Top On Time Issues by Brand', 'Freight Terms Analysis']
        available_preferred_cuts = [cut for cut in preferred_cuts if cut in available_cuts]
        
        if available_preferred_cuts:
            viz_data = ontime_data[ontime_data['CUT'].isin(available_preferred_cuts)].copy()
        else:
            # Fallback to any non-SKU cuts
            trend_cuts = [cut for cut in available_cuts if not any(x in cut.lower() for x in ['sku', 'top sku', 'item'])][:4]
            if trend_cuts:
                viz_data = ontime_data[ontime_data['CUT'].isin(trend_cuts)].copy()
            else:
                st.info("No aggregated data available for trend visualization.")
                return
        
        if viz_data.empty:
            st.info("No data available for trend visualization.")
            return
        
        # Create trend chart for each available cut type
        available_cut_types = viz_data['CUT'].unique()
        for cut_type in available_cut_types:
            cut_data = viz_data[viz_data['CUT'] == cut_type].copy()
            
            if cut_data.empty:
                continue
            
            # Prepare data for charting
            chart_data = []
            for _, row in cut_data.iterrows():
                entity = row['Product/Brand'] if pd.notna(row['Product/Brand']) else f'Unknown {cut_type}'
                
                for col in ontime_rate_cols:
                    if col in row and pd.notna(row[col]):
                        # Extract week date from column name
                        if col.startswith('W') and '_ONTIME_RATE' in col:
                            # Original format: W1_ONTIME_RATE -> use column mapping if available
                            week_date = column_mapping.get(col, col).replace('_ONTIME_RATE', '')
                        elif 'ONTIME RATE' in col:
                            # Space format: 10/13 ONTIME RATE -> extract date part
                            week_date = col.replace(' ONTIME RATE', '')
                        else:
                            # Fallback: try underscore format: 10/13_ONTIME_RATE -> extract date part
                            week_date = col.replace('_ONTIME_RATE', '')
                        
                        # Convert percentage string back to decimal for charting
                        rate_value = row[col]
                        skip_data_point = False
                        
                        if isinstance(rate_value, str):
                            if rate_value == 'N/A' or rate_value == '':
                                skip_data_point = True  # No POs for this period, skip entirely
                            elif rate_value.endswith('%'):
                                rate_value = float(rate_value.replace('%', '')) / 100
                            else:
                                try:
                                    rate_value = float(rate_value)
                                except ValueError:
                                    skip_data_point = True  # Invalid data, skip
                        else:
                            rate_value = float(rate_value) if pd.notna(rate_value) else None
                            if rate_value is None:
                                skip_data_point = True
                        
                        # Only add data point if we have valid data (not N/A)
                        if not skip_data_point:
                            chart_data.append({
                                'Entity': entity,
                                'Week': week_date,
                                'OnTime_Rate': rate_value,
                                'OnTime_Rate_Pct': rate_value * 100,
                                'Late_Contribution': format_contribution_safe(row['WEIGHTED LATE CONTRIBUTION']) if 'WEIGHTED LATE CONTRIBUTION' in row else "0%"
                            })
            
            if chart_data:
                chart_df = pd.DataFrame(chart_data)
                
                # Look for aggregate columns (e.g., T2W, T4W aggregate on time rates)
                aggregate_ontime_cols = [col for col in cut_data.columns if 'ONTIME_RATE' in col and any(suffix in col for suffix in ['_T2W', '_T4W', '_T13W', '_T26W', '_T52W'])]
                # Also check for space format: "On Time Rate T4W"
                if not aggregate_ontime_cols:
                    aggregate_ontime_cols = [col for col in cut_data.columns if 'On Time Rate' in col and any(suffix in col for suffix in ['T2W', 'T4W', 'T13W', 'T26W', 'T52W'])]
                
                aggregate_ontime_col = aggregate_ontime_cols[0] if aggregate_ontime_cols else None
                
                # Calculate aggregate On Time Rate for reference line
                if aggregate_ontime_col:
                    # Get the aggregate rate from the first row (should be same for all entities in this cut)
                    first_row = cut_data.iloc[0]
                    if aggregate_ontime_col in first_row and pd.notna(first_row[aggregate_ontime_col]):
                        rate_val = first_row[aggregate_ontime_col]
                        if isinstance(rate_val, str):
                            if rate_val != 'N/A' and rate_val != '':
                                if rate_val.endswith('%'):
                                    avg_aggregate_rate = float(rate_val.replace('%', ''))
                                else:
                                    try:
                                        avg_aggregate_rate = float(rate_val) * 100
                                    except ValueError:
                                        avg_aggregate_rate = None
                            else:
                                avg_aggregate_rate = None
                        else:
                            try:
                                avg_aggregate_rate = float(rate_val) * 100
                            except:
                                avg_aggregate_rate = None
                    else:
                        avg_aggregate_rate = None
                else:
                    avg_aggregate_rate = None
                
                # Create the trend chart
                base_chart = alt.Chart(chart_df).add_selection(
                    alt.selection_single(on='mouseover', empty='all')
                )
                
                # Line chart
                line_chart = base_chart.mark_line(point=True, strokeWidth=2).encode(
                    x=alt.X('Week:O', title='Week', sort=list(chart_df['Week'].unique())),
                    y=alt.Y('OnTime_Rate_Pct:Q', title='On Time Rate (%)', scale=alt.Scale(domain=[0, 100])),
                    color=alt.Color('Entity:N', title=cut_type, scale=alt.Scale(scheme='category10')),
                    tooltip=['Entity:N', 'Week:O', 'OnTime_Rate_Pct:Q', 'Late_Contribution:N']
                ).properties(
                    width=600,
                    height=300,
                    title=f"On Time Rate Trends - {cut_type} Level"
                ).configure_axis(
                    labelAngle=0,
                    labelFontSize=10
                ).configure_view(
                    stroke=None
                ).configure(
                    padding={"left": 50, "top": 50, "right": 50, "bottom": 80}
                )
                
                # Add aggregate reference line (T4W average) if available
                if avg_aggregate_rate is not None:
                    reference_line = alt.Chart(pd.DataFrame({
                        'y': [avg_aggregate_rate]
                    })).mark_rule(
                        color='red',
                        strokeDash=[5, 5],
                        strokeWidth=2,
                        opacity=0.8
                    ).encode(
                        y=alt.Y('y:Q'),
                        tooltip=alt.value(f'T4W Avg: {avg_aggregate_rate:.1f}%')
                    )
                    
                    # Combine line chart and reference line
                    final_chart = line_chart + reference_line
                else:
                    final_chart = line_chart
                
                st.altair_chart(final_chart, use_container_width=True)
        
    except Exception as e:
        st.error(f"Error creating On Time trend charts: {e}")


