def get_actuals_data_aggregated(sku_list: List[str], period_mapping: Dict[str, Any]) -> pd.DataFrame:
    """
    Get trailing actuals data aggregated to vendor periods (database-level aggregation).
    
    Args:
        sku_list: List of Chewy SKUs to get actuals for
        period_mapping: Period mapping from map_forecast_periods()
        
    Returns:
        DataFrame with actuals aggregated by SKU and trailing period
        
    Raises:
        ValueError: If Snowflake connection fails or data cannot be retrieved
    """
    try:
        session = snowflake_get_active_session()
        
        # Convert SKU list to SQL IN clause (handle both string and numeric SKUs)
        sku_in_clause = "', '".join([str(sku) for sku in sku_list])
        
        # Get periods from period mapping
        periods = period_mapping['periods']
        
        all_actuals = []
        
        # Generate one aggregated query per vendor period (for YoY actuals)
        for period in periods:
            period_start = period[0]
            period_end = period[1]
            
            # Calculate YoY period (same period, previous year)
            yoy_start = period_start.replace(year=period_start.year - 1)
            yoy_end = period_end.replace(year=period_end.year - 1)
            
            # Query actuals data with database-level aggregation (YoY comparison)
            actuals_query = f"""
            SELECT
                p.product_part_number as chewy_sku,
                '{period_start.strftime('%Y-%m-%d')}' as period_start_date,
                '{period_end.strftime('%Y-%m-%d')}' as period_end_date,
                SUM(olm.order_line_quantity)::NUMERIC(38,3) as yoy_actual_units
            FROM edldb.chewybi.order_line_measures olm
            LEFT JOIN edldb.chewybi.products p ON p.product_key = olm.product_key
            WHERE p.product_part_number IN ('{sku_in_clause}')
            AND olm.order_line_each_price <> 0
            AND olm.order_order_line_status NOT IN ('X','J')
            AND olm.order_placed_date BETWEEN '{yoy_start.strftime('%Y-%m-%d')}' AND '{yoy_end.strftime('%Y-%m-%d')}'
            GROUP BY p.product_part_number
            """
            
            result = session.sql(actuals_query).collect()
            
            if result:
                period_actuals = pd.DataFrame([row.asDict() for row in result])
                # Debug: Show what columns Snowflake actually returns
                print(f"DEBUG - Actuals Snowflake returned columns: {period_actuals.columns.tolist()}")
                all_actuals.append(period_actuals)
        
        # Combine all periods
        print(f"DEBUG - all_actuals length: {len(all_actuals)}")
        if all_actuals:
            actuals_df = pd.concat(all_actuals, ignore_index=True)
            print(f"DEBUG - Combined actuals_df columns: {actuals_df.columns.tolist()}")
            print(f"DEBUG - Combined actuals_df shape: {actuals_df.shape}")
            
            # Convert date columns to datetime (handle case sensitivity)
            if 'period_start_date' in actuals_df.columns:
                actuals_df['period_start_date'] = pd.to_datetime(actuals_df['period_start_date'])
                actuals_df['period_end_date'] = pd.to_datetime(actuals_df['period_end_date'])
            elif 'PERIOD_START_DATE' in actuals_df.columns:
                actuals_df['period_start_date'] = pd.to_datetime(actuals_df['PERIOD_START_DATE'])
                actuals_df['period_end_date'] = pd.to_datetime(actuals_df['PERIOD_END_DATE'])
                # Drop the uppercase columns to avoid confusion
                actuals_df = actuals_df.drop(columns=['PERIOD_START_DATE', 'PERIOD_END_DATE'])
            
            # Handle chewy_sku column case sensitivity
            if 'chewy_sku' in actuals_df.columns:
                actuals_df['chewy_sku'] = actuals_df['chewy_sku'].astype(str)
            elif 'CHEWY_SKU' in actuals_df.columns:
                actuals_df['chewy_sku'] = actuals_df['CHEWY_SKU'].astype(str)
                actuals_df = actuals_df.drop(columns=['CHEWY_SKU'])
            
            # Handle yoy_actual_units column case sensitivity
            if 'YOY_ACTUAL_UNITS' in actuals_df.columns:
                actuals_df['yoy_actual_units'] = actuals_df['YOY_ACTUAL_UNITS']
                actuals_df = actuals_df.drop(columns=['YOY_ACTUAL_UNITS'])
        else:
            print("DEBUG - No actuals data returned from Snowflake")
            # Return empty DataFrame with correct structure
            actuals_df = pd.DataFrame(columns=['chewy_sku', 'period_start_date', 'period_end_date', 'yoy_actual_units'])
        
        return actuals_df
        
    except Exception as e:
        error_msg = f"Unable to retrieve actuals data from Snowflake: {str(e)}"
        raise ValueError(error_msg)

def process_vendor_forecast_data(vendor_df: pd.DataFrame, period_validation: Dict[str, Any]) -> pd.DataFrame:
    """
    Process and reshape vendor forecast data from CSV format to long format.
    
    Args:
        vendor_df: Raw vendor forecast DataFrame from CSV
        period_validation: Period validation from validate_period_mapping()
        
    Returns:
        DataFrame with vendor forecasts in long format (SKU, period, forecast_units)
    """
    try:
        # Debug: Show input data structure
        if st.session_state.get('debug_mode', False):
            st.write("**Debug - Input vendor_df columns:**", vendor_df.columns.tolist())
            st.write("**Debug - Input vendor_df shape:**", vendor_df.shape)
            st.write("**Debug - period_validation keys:**", list(period_validation.keys()))
        
        # Get column mappings
        column_mapping = period_validation['column_mapping']
        if st.session_state.get('debug_mode', False):
            st.write("**Debug - column_mapping:**", column_mapping)
        
        # Identify the non-forecast columns (first 3 columns)
        vendor_col = vendor_df.columns[0]
        chewy_sku_col = vendor_df.columns[1] 
        vendor_sku_col = vendor_df.columns[2]
        
        if st.session_state.get('debug_mode', False):
            st.write(f"**Debug - Column assignments:** vendor={vendor_col}, chewy_sku={chewy_sku_col}, vendor_sku={vendor_sku_col}")
        
        # Create long format data
        vendor_long_data = []
        
        for _, row in vendor_df.iterrows():
            vendor_number = row[vendor_col]
            chewy_sku = row[chewy_sku_col]
            vendor_sku = row[vendor_sku_col]
            
            # Process each forecast column
            for csv_col, period_info in column_mapping.items():
                forecast_value = row[csv_col]
                
                # Clean and convert forecast value (handle commas, spaces, blanks, zeros)
                try:
                    if pd.isna(forecast_value) or forecast_value == '':
                        # Blank/empty is valid - means 0 forecast
                        forecast_units = 0
                    elif isinstance(forecast_value, str):
                        # Remove spaces, commas, and other formatting
                        clean_value = forecast_value.strip().replace(',', '').replace(' ', '')
                        forecast_units = float(clean_value) if clean_value != '' else 0
                    else:
                        forecast_units = float(forecast_value)
                except (ValueError, TypeError):
                    # Convert invalid values to 0 silently
                    forecast_units = 0
                
                vendor_long_data.append({
                    'vendor_number': vendor_number,
                    'chewy_sku': chewy_sku,
                    'vendor_sku': vendor_sku,
                    'period_name': period_info['period_name'],
                    'period_start_date': period_info['start_date'],
                    'period_end_date': period_info['end_date'],
                    'days_in_period': period_info['days_in_period'],
                    'vendor_forecast_units': forecast_units
                })
        
        vendor_long_df = pd.DataFrame(vendor_long_data)
        
        return vendor_long_df
        
    except Exception as e:
        error_msg = f"Unable to process vendor forecast data: {str(e)}"
        raise ValueError(error_msg)

def aggregate_chewy_data_to_periods(master_df: pd.DataFrame, chewy_forecasts_df: pd.DataFrame, actuals_df: pd.DataFrame) -> pd.DataFrame:
    """
    Aggregate daily Chewy forecasts and actuals to match vendor forecast periods.
    
    Args:
        master_df: Master dataset with vendor forecasts and SKU attributes
        chewy_forecasts_df: Daily Chewy forecasts from Snowflake
        actuals_df: Daily actuals from Snowflake
        
    Returns:
        Master DataFrame with aggregated Chewy data added
    """
    try:
        # Process Chewy forecasts
        if not chewy_forecasts_df.empty:
            # Convert forecast_date to datetime and SKU to string for consistent data types
            chewy_forecasts_df['FORECAST_DATE'] = pd.to_datetime(chewy_forecasts_df['FORECAST_DATE'])
            chewy_forecasts_df['CHEWY_SKU'] = chewy_forecasts_df['CHEWY_SKU'].astype(str)
            
            # For each row in master_df, aggregate Chewy forecasts for that period
            chewy_forecast_aggregated = []
            
            for _, row in master_df.iterrows():
                sku = row['chewy_sku']
                period_start = pd.to_datetime(row['period_start_date'])
                period_end = pd.to_datetime(row['period_end_date'])
                
                # Filter Chewy forecasts for this SKU and period (handle uppercase column names)
                sku_forecasts = chewy_forecasts_df[
                    (chewy_forecasts_df['CHEWY_SKU'] == sku) &
                    (chewy_forecasts_df['FORECAST_DATE'] >= period_start) &
                    (chewy_forecasts_df['FORECAST_DATE'] <= period_end)
                ]
                
                # Sum forecast units for the period
                chewy_forecast_units = sku_forecasts['FORECAST_UNITS'].sum() if not sku_forecasts.empty else 0
                
                chewy_forecast_aggregated.append({
                    'chewy_sku': sku,
                    'period_start_date': period_start,
                    'period_end_date': period_end,
                    'chewy_forecast_units': chewy_forecast_units
                })
            
            # Convert to DataFrame and merge with master
            chewy_agg_df = pd.DataFrame(chewy_forecast_aggregated)
            # Ensure consistent data types for merge
            chewy_agg_df['period_start_date'] = pd.to_datetime(chewy_agg_df['period_start_date'])
            chewy_agg_df['period_end_date'] = pd.to_datetime(chewy_agg_df['period_end_date'])
            
            master_df = master_df.merge(
                chewy_agg_df[['chewy_sku', 'period_start_date', 'period_end_date', 'chewy_forecast_units']],
                on=['chewy_sku', 'period_start_date', 'period_end_date'],
                how='left'
            )
        else:
            master_df['chewy_forecast_units'] = 0
        
        # Process actuals data
        if not actuals_df.empty:
            # Convert order_date to datetime and SKU to string for consistent data types
            actuals_df['ORDER_DATE'] = pd.to_datetime(actuals_df['ORDER_DATE'])
            actuals_df['CHEWY_SKU'] = actuals_df['CHEWY_SKU'].astype(str)
            
            # For each row in master_df, aggregate actuals for the trailing period
            actuals_aggregated = []
            
            for _, row in master_df.iterrows():
                sku = row['chewy_sku']
                period_start = pd.to_datetime(row['period_start_date'])
                period_end = pd.to_datetime(row['period_end_date'])
                
                # Calculate trailing period (same length as forecast period, ending day before forecast starts)
                period_length = (period_end - period_start).days + 1
                trailing_end = period_start - timedelta(days=1)
                trailing_start = trailing_end - timedelta(days=period_length - 1)
                
                # Filter actuals for this SKU and trailing period (handle uppercase column names)
                sku_actuals = actuals_df[
                    (actuals_df['CHEWY_SKU'] == sku) &
                    (actuals_df['ORDER_DATE'] >= trailing_start) &
                    (actuals_df['ORDER_DATE'] <= trailing_end)
                ]
                
                # Sum actual units for the trailing period
                trailing_actual_units = sku_actuals['ACTUAL_UNITS'].sum() if not sku_actuals.empty else 0
                trailing_actual_sales = 0  # We don't have sales data in actuals query
                
                actuals_aggregated.append({
                    'chewy_sku': sku,
                    'period_start_date': period_start,
                    'period_end_date': period_end,
                    'trailing_actual_units': trailing_actual_units,
                    'trailing_actual_sales': trailing_actual_sales
                })
            
            # Convert to DataFrame and merge with master
            actuals_agg_df = pd.DataFrame(actuals_aggregated)
            # Ensure consistent data types for merge
            actuals_agg_df['period_start_date'] = pd.to_datetime(actuals_agg_df['period_start_date'])
            actuals_agg_df['period_end_date'] = pd.to_datetime(actuals_agg_df['period_end_date'])
            
            master_df = master_df.merge(
                actuals_agg_df[['chewy_sku', 'period_start_date', 'period_end_date', 'trailing_actual_units', 'trailing_actual_sales']],
                on=['chewy_sku', 'period_start_date', 'period_end_date'],
                how='left'
            )
        else:
            master_df['yoy_actual_units'] = 0
            master_df['trailing_actual_sales'] = 0
        
        # Fill NaN values with 0
        master_df['chewy_forecast_units'] = master_df['chewy_forecast_units'].fillna(0)
        master_df['yoy_actual_units'] = master_df['yoy_actual_units'].fillna(0)
        master_df['trailing_actual_sales'] = master_df['trailing_actual_sales'].fillna(0)
        
        return master_df
        
    except Exception as e:
        error_msg = f"Failed to aggregate Chewy data: {str(e)}"
        raise ValueError(error_msg)

def calculate_variance_metrics(master_df: pd.DataFrame, skip_actuals: bool = False) -> pd.DataFrame:
    """
    Calculate variance metrics and forecast accuracy (WAPE, Bias) for all comparisons.
    
    METRICS CALCULATED:
    
    This function now only ensures numeric data types for the core forecast columns.
    All variance calculations, accuracy metrics, and comparison flags are computed 
    real-time during analysis to maintain data cleanliness and ensure accuracy.
    
    Core columns maintained:
    - vendor_forecast_units: Raw vendor forecast data
    - chewy_forecast_units: Raw Chewy forecast data  
    - yoy_actual_units: Year-over-year actual units (for Current Analysis mode)
    
    All calculated metrics (variances, WAPE, Bias, accuracy flags) are computed
    on-demand during Forward-Looking and Historical Accuracy analysis.
    
    Args:
        master_df: Master dataset with vendor forecasts, Chewy forecasts, and actuals
        
    Returns:
        Master DataFrame with variance metrics added
    """
    try:
        # Ensure numeric columns
        master_df['vendor_forecast_units'] = pd.to_numeric(master_df['vendor_forecast_units'], errors='coerce').fillna(0)
        master_df['chewy_forecast_units'] = pd.to_numeric(master_df['chewy_forecast_units'], errors='coerce').fillna(0)
        master_df['yoy_actual_units'] = pd.to_numeric(master_df['yoy_actual_units'], errors='coerce').fillna(0)
        
        # All calculated metrics are now computed real-time during analysis
        # This keeps the master dataset clean with only raw forecast data and SKU attributes
        
        
        return master_df
        
    except Exception as e:
        error_msg = f"Failed to calculate variance metrics: {str(e)}"
        raise ValueError(error_msg)

def create_master_dataset(vendor_df: pd.DataFrame, period_mapping: Dict[str, Any], period_validation: Dict[str, Any], upload_mode: str = "Current Analysis", snapshot_date: date = None) -> pd.DataFrame:
    """
    Create the master reconciliation dataset by combining all data sources.
    
    Args:
        vendor_df: Raw vendor forecast DataFrame from CSV
        period_mapping: Period mapping from map_forecast_periods()
        period_validation: Period validation from validate_period_mapping()
        
    Returns:
        Master DataFrame with all reconciliation data
        
    Raises:
        ValueError: If any data retrieval or processing fails
    """
    try:
        # Step 1: Process vendor forecast data
        vendor_long_df = process_vendor_forecast_data(vendor_df, period_validation)
        
        # Debug: Show column names
        if st.session_state.get('debug_mode', False):
            st.write("**Debug - Vendor Long DF Columns:**", vendor_long_df.columns.tolist())
            st.write("**Debug - First few rows:**")
            st.dataframe(vendor_long_df.head())
        
        # Get unique SKU-vendor pairs from vendor data
        sku_vendor_pairs = vendor_long_df[['chewy_sku', 'vendor_number']].drop_duplicates()
        sku_vendor_tuples = [(row['chewy_sku'], row['vendor_number']) for _, row in sku_vendor_pairs.iterrows()]
        unique_skus = vendor_long_df['chewy_sku'].unique().tolist()
        
        # Step 2: Get SKU attributes (filtered by vendor)
        sku_attributes_df = get_sku_attributes(sku_vendor_tuples)
        
        # Step 3: Get Chewy forecasts (mode-dependent)
        if upload_mode == "Historical Upload":
            if not snapshot_date:
                raise ValueError("Snapshot date is required for Historical Upload mode")
            chewy_forecasts_df = get_chewy_forecasts_historical(unique_skus, period_mapping, snapshot_date)
        else:
            chewy_forecasts_df = get_chewy_forecasts_aggregated(unique_skus, period_mapping)
        
        # Step 4: Get actuals data (now fetched for ALL modes including Historical Upload)
        # This ensures YoY data is saved to snapshots for future viewing
        actuals_df = get_actuals_data_aggregated(unique_skus, period_mapping)
        
        # Step 5: Merge all data sources
        
        # Debug: Show all DataFrame columns before merging
        if st.session_state.get('debug_mode', False):
            st.write("**Debug - vendor_long_df columns:**", vendor_long_df.columns.tolist())
            st.write("**Debug - sku_attributes_df columns:**", sku_attributes_df.columns.tolist())
            st.write("**Debug - chewy_forecasts_df columns:**", chewy_forecasts_df.columns.tolist())
            st.write("**Debug - actuals_df columns:**", actuals_df.columns.tolist())
        
        # Start with vendor data as the base
        master_df = vendor_long_df.copy()
        
        # Convert SKU columns to strings to ensure consistent data types for merging
        master_df['chewy_sku'] = master_df['chewy_sku'].astype(str)
        sku_attributes_df['CHEWY_SKU'] = sku_attributes_df['CHEWY_SKU'].astype(str)
        
        # Add SKU attributes (handle case mismatch between lowercase and uppercase column names)
        master_df = master_df.merge(
            sku_attributes_df,
            left_on='chewy_sku',
            right_on='CHEWY_SKU',
            how='left'
        )
        
        # Replace NULL attribute values with "N/A" to make missing data visible and filterable
        attribute_columns = [
            'VENDOR_NAME', 'PRODUCT_NAME', 'PARENT_COMPANY', 'BRAND_NAME',
            'MC1_CATEGORY', 'MC2_CATEGORY', 'MC3_CATEGORY',
            'PC1_CATEGORY', 'PC2_CATEGORY', 'PC3_CATEGORY', 'SKU_VELOCITY'
        ]
        
        for col in attribute_columns:
            if col in master_df.columns:
                master_df[col] = master_df[col].fillna('N/A')
        
        # Step 6: Merge pre-aggregated Chewy forecasts and actuals
        
        # Convert date columns to datetime for consistent data types
        master_df['period_start_date'] = pd.to_datetime(master_df['period_start_date'])
        master_df['period_end_date'] = pd.to_datetime(master_df['period_end_date'])
        
        # Merge Chewy forecasts (already aggregated to vendor periods)
        if not chewy_forecasts_df.empty:
            master_df = master_df.merge(
                chewy_forecasts_df[['chewy_sku', 'period_start_date', 'period_end_date', 'chewy_forecast_units']],
                on=['chewy_sku', 'period_start_date', 'period_end_date'],
                how='left'
            )
        else:
            master_df['chewy_forecast_units'] = 0
        
        # Merge actuals (already aggregated to YoY periods)
        if not actuals_df.empty:
            master_df = master_df.merge(
                actuals_df[['chewy_sku', 'period_start_date', 'period_end_date', 'yoy_actual_units']],
                on=['chewy_sku', 'period_start_date', 'period_end_date'],
                how='left'
            )
        else:
            master_df['yoy_actual_units'] = 0
        
        # Fill NaN values with 0
        master_df['chewy_forecast_units'] = master_df['chewy_forecast_units'].fillna(0)
        master_df['yoy_actual_units'] = master_df['yoy_actual_units'].fillna(0)
        
        # Step 7: Calculate variance metrics (mode-dependent)
        if upload_mode == "Historical Upload":
            master_df = calculate_variance_metrics(master_df, skip_actuals=True)
        else:
            master_df = calculate_variance_metrics(master_df, skip_actuals=False)
        
        
        return master_df
        
    except Exception as e:
        error_msg = f"Failed to create master dataset: {str(e)}"
        raise ValueError(error_msg)

