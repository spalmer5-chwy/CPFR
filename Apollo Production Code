            session = get_snowflake_session()
            if session:
                with st.spinner("🔄 Running Demand Analysis..."):
                    try:
                        # Generate and execute demand query based on region
                        region = st.session_state.get('region', 'Chewy US')
                        if region == "Chewy Canada":
                            demand_query, column_mapping = generate_demand_query_canada(
                                vendor_numbers, 
                                start_date, 
                                end_date, 
                                aggregation,
                                st.session_state.get('include_dropship', False)
                            )
                        else:
                            # Use optimized temp table query for better performance
                            demand_query, column_mapping = generate_demand_query_temp_tables(
                                vendor_numbers, 
                                start_date, 
                                end_date, 
                                aggregation,
                                st.session_state.get('include_dropship', False)
                            )
                            
                            
                            
                        # Execute query with timing
                        start_time = datetime.now()
                        demand_data = session.sql(demand_query).to_pandas()
                        end_time = datetime.now()
                        query_duration = int((end_time - start_time).total_seconds() * 1000)
                        
                        # Track query execution
                        track_query_execution(
                            section_name='Demand',
                            vendor_numbers=vendor_numbers,
                            date_range_start=start_date if isinstance(start_date, date) else datetime.strptime(start_date, '%m/%d/%Y').date(),
                            date_range_end=end_date if isinstance(end_date, date) else datetime.strptime(end_date, '%m/%d/%Y').date(),
                            region=region,
                            query_duration_ms=query_duration,
                            row_count=len(demand_data) if not demand_data.empty else 0
                        )
                        
                        if not demand_data.empty:
                            st.session_state['demand_data'] = demand_data
                            # Store column mapping for display/export formatting
                            if column_mapping:
                                st.session_state['demand_column_mapping'] = column_mapping
                            st.rerun()  # Refresh to show download button
                        else:
                            st.error("❌ No demand data found for the selected criteria.")
                        
                    except Exception as e:
                        track_error('Demand', str(e), 'query_execution_error')
                        st.error(f"❌ Error executing demand query: {str(e)}")
            else:
                st.error("❌ Unable to connect to Snowflake")
    
    # Display demand data if available
    if 'demand_data' in st.session_state:
        demand_data = st.session_state['demand_data']
        
        
        # Demand forecast accuracy table
        st.subheader("Demand Forecast Accuracy by Category")
        
        # Format the data for display (similar to cover sheet)
        display_data = demand_data.copy()
        
        # Rename columns from generic names to date-based names if mapping exists
        if 'demand_column_mapping' in st.session_state:
            column_mapping = st.session_state['demand_column_mapping']
            # Rename columns using the mapping (generic -> date-based)
            display_data = display_data.rename(columns=column_mapping)
        
        # Helper function to convert potential Decimal strings to float
        def convert_decimal_string(val):
            if pd.isna(val):
                return None
            if isinstance(val, str) and val.startswith("Decimal('") and val.endswith("')"):
                decimal_str = val[9:-2]
                return float(decimal_str)
            return float(val) if val is not None else None
        
        # Helper function to format percentage with conditional +/- sign
        def format_percentage_with_sign(val):
            if val is None:
                return "N/A"
            converted_val = convert_decimal_string(val)
            if converted_val is None:
                return "N/A"
            formatted = f"{converted_val:.2%}"
            if formatted == "0.00%":
                return "0.00%"
            elif converted_val >= 0:
                return f"+{formatted}"
            else:
                return formatted
        
        # Remove priority columns from display
        columns_to_drop = ['CUT_PRIORITY', 'PRIORITY_CUT', 'RN']
        for col in columns_to_drop:
            if col in display_data.columns:
                display_data = display_data.drop(col, axis=1)
        
        # Format WAPE and Bias percentage columns (these are decimals that need .2% formatting)
        wape_bias_columns = [col for col in display_data.columns if 'WAPE' in col or 'BIAS' in col]
        
        for col in wape_bias_columns:
            if col in display_data.columns:
                if 'WOW' in col:  # Week-over-week columns get +/- sign
                    display_data[col] = display_data[col].apply(format_percentage_with_sign)
                else:  # Last week columns don't get +/- sign
                    display_data[col] = display_data[col].apply(
                        lambda x: f"{convert_decimal_string(x):.2%}" if convert_decimal_string(x) is not None else "N/A"
                    )
        
        # Format contribution columns (these are decimals that need .2% formatting)
        contribution_columns = [col for col in display_data.columns if 'WEIGHTED_ERROR_CONTRIBUTION' in col.upper()]
        
        for col in contribution_columns:
            if col in display_data.columns:
                def format_percentage_with_rounding(x):
                    converted_val = convert_decimal_string(x)
                    if converted_val is None:
                        return "N/A"
                    # Round very small percentages to 0.00%
                    if abs(converted_val) < 0.0001:  # Less than 0.01%
                        return "0.00%"
                    formatted = f"{converted_val:.2%}"
                    # Remove negative sign if it rounds to exactly 0.00%
                    if formatted == "-0.00%":
                        return "0.00%"
                    return formatted
                display_data[col] = display_data[col].apply(format_percentage_with_rounding)
        
        # Final table formatting
        # Rename Field1 to Aggregate
        if 'FIELD1' in display_data.columns:
            display_data = display_data.rename(columns={'FIELD1': 'Aggregate'})
        
        # Replace underscores with spaces in column names
        display_data.columns = [col.replace('_', ' ') for col in display_data.columns]
        
        # Reset index to start from 1
        display_data.reset_index(drop=True, inplace=True)
        display_data.index = display_data.index + 1
        
        # Display the formatted data
        st.dataframe(display_data, use_container_width=True)
        
        # Add data visualization section
        st.markdown("---")
        st.subheader("📊 Data Visualizations")
        
        # Automatically show trend charts
        track_chart_interaction('Demand', 'trend_charts')
        create_demand_trend_charts()
        
    else:

        
        # Show what the demand analysis will include
        st.subheader("Demand Analysis Will Include:")
        st.write("""
        **NOTE - Demand queries may take multiple minutes to run**
        
        **Forecast Accuracy Metrics by Category:**
        - **Total Vendor**: WAPE and Bias aggregated for the entire vendor
        - **MC1 (Merch Classification 1)**: WAPE and Bias by primary product category
        - **MC2 (Merch Classification 2)**: WAPE and Bias by secondary product category
        - **Top by Demand**: WAPE and Bias for top-demand manufacturers
        - **Top 30 SKUs**: Individual SKU WAPE and Bias for highest LW_WAPE_LT_BLENDED items
        
        **Key Metrics:**
        - **WAPE LT Blended**: Weighted Absolute Percentage Error for long-term blended forecast
        - **Bias LT Blended**: Forecast bias for long-term blended forecast
        - **WAPE DS LT**: Weighted Absolute Percentage Error for demand sensing long-term
        - **Bias DS LT**: Forecast bias for demand sensing long-term
        - **OOS vs In-Stock**: Separate metrics for out-of-stock vs in-stock scenarios
        - **Week-over-Week Changes**: Comparison between current and previous week
        """)

def create_demand_trend_charts():
    """Create time series trend charts for demand analysis"""
    try:
        # Get column mapping if available for proper date labels
        column_mapping = st.session_state.get('demand_column_mapping', {})
        
        if 'demand_data' not in st.session_state:
            st.error("❌ No demand data available. Please run the demand analysis first.")
            return
        
        demand_data = st.session_state['demand_data']
        
        # Identify weekly WAPE LT columns (format: W1_LT_BLENDED_WAPE, W2_LT_BLENDED_WAPE, etc.)
        wape_lt_cols = [col for col in demand_data.columns if ('LT_WAPE' in col or 'LT_BLENDED_WAPE' in col) and col.startswith('W') and not col.endswith('_T2W') and not col.endswith('_T4W') and not col.endswith('_T13W') and not col.endswith('_T26W') and not col.endswith('_T52W')]
        
        if not wape_lt_cols:
            st.warning("No weekly WAPE LT data found for visualization.")
            return
        
        # Filter to vendor-level and category-level data (exclude individual SKUs for main trends)
        viz_data = demand_data[demand_data['CUT'].isin(['Vendor', 'MC1', 'MC2', 'Brand'])].copy()
        
        if viz_data.empty:
            # Try to use any available data for trend analysis
            available_cuts = demand_data['CUT'].unique() if 'CUT' in demand_data.columns else []
            
            if len(available_cuts) > 0:
                # Use the first few available cuts, excluding SKU-level data for trend clarity
                trend_cuts = [cut for cut in available_cuts if not any(x in cut.lower() for x in ['sku', 'top item', 'item'])][:4]
                if trend_cuts:
                    viz_data = demand_data[demand_data['CUT'].isin(trend_cuts)].copy()
                else:
                    st.info("No aggregated data available for trend visualization.")
                    return
            else:
                st.info("No data available for trend visualization.")
                return
        
        # Create trend chart for each available cut type
        available_cut_types = viz_data['CUT'].unique()
        for cut_type in available_cut_types:
            
            # Special handling for "Top Item Error Contribution" - show top 10 individual items instead
            if "Item Error Contribution" in cut_type:
                st.markdown("**📈 Top 10 Individual Demand Items Trend**")
                create_top_demand_items_trend_chart(demand_data, wape_lt_cols, column_mapping)
                st.markdown("---")
                continue
            
            cut_data = viz_data[viz_data['CUT'] == cut_type]
            
            if cut_data.empty:
                continue
                
            st.markdown(f"**📈 {cut_type} WAPE LT Trends**")
            
            # Prepare data for line chart
            chart_data = []
            
            # Get the aggregate WAPE column (T2W, T4W, etc.)
            aggregate_wape_cols = [col for col in cut_data.columns if ('LT_WAPE_T' in col or 'LT_BLENDED_WAPE_T' in col)]
            aggregate_wape_col = aggregate_wape_cols[0] if aggregate_wape_cols else None
            
            for _, row in cut_data.iterrows():
                entity_name = row.get('FIELD', row.get('PRODUCT_NAME', 'Unknown'))
                
                # Add aggregate WAPE as a reference line if available
                if aggregate_wape_col:
                    aggregate_value = row[aggregate_wape_col]
                    if pd.notna(aggregate_value):
                        # Extract the trailing weeks notation (e.g., T2W, T4W)
                        tw_notation = aggregate_wape_col.split('_')[-1]  # Gets T2W, T4W, etc.
                        chart_data.append({
                            'Date': f'Aggregate ({tw_notation})',
                            'Entity': entity_name,
                            'WAPE LT': float(aggregate_value) if not pd.isna(aggregate_value) else 0,
                            'Type': 'Aggregate'
                        })
                
                # Add weekly data points
                for col in wape_lt_cols:
                    # Get display date from column mapping, or use column name (try both cases)
                    date_label = column_mapping.get(col.upper(), column_mapping.get(col, col))
                    # Clean up the date label to show only the date part - extract just the date from patterns like "10/13/2025_LT_BLENDED_WAPE"
                    if '_' in date_label:
                        # Split by underscore and take the first part (the date)
                        date_label = date_label.split('_')[0]
                    # Additional cleanup for any remaining suffixes
                    date_label = date_label.replace(' LT WAPE', '').replace(' LT BLENDED WAPE', '').replace(' LT_WAPE', '').replace(' LT_BLENDED_WAPE', '').replace(' WAPE', '').replace(' BIAS', '').replace('/LT/', '/').replace('/LT', '').strip()
                    
                    value = row[col]
                    if pd.notna(value):  # Include 0% values - they're valid WAPE rates
                        chart_data.append({
                            'Date': date_label,
                            'Entity': entity_name,
                            'WAPE LT': float(value) if not pd.isna(value) else 0,
                            'Type': 'Weekly'
                        })
            
            if chart_data:
                chart_df = pd.DataFrame(chart_data)
                
                # Create line chart with interactive selection
                import altair as alt
                
                # Separate weekly and aggregate data for different styling
                weekly_data = chart_df[chart_df['Type'] == 'Weekly']
                aggregate_data = chart_df[chart_df['Type'] == 'Aggregate'] if 'Type' in chart_df.columns else pd.DataFrame()
                
                # Convert date strings to datetime for proper sorting
                try:
                    weekly_data['Date_Sort'] = pd.to_datetime(weekly_data['Date'], format='%m/%d/%Y', errors='coerce')
                    # Sort dates chronologically and convert back to string for display
                    date_order = weekly_data.sort_values('Date_Sort')['Date'].unique().tolist()
                except:
                    # Fallback to string sorting if date conversion fails
                    date_order = sorted(list(weekly_data['Date'].unique()))
                
                # Create base chart for weekly data only
                base_chart = alt.Chart(weekly_data)
                
                # Weekly trend lines (separate line and point layers like working OOS charts)
                # Lines layer with legend
                weekly_lines = base_chart.mark_line(strokeWidth=2).encode(
                    x=alt.X('Date:N', title='Week Starting', sort=date_order),
                    y=alt.Y('WAPE LT:Q', title='WAPE LT (%)', axis=alt.Axis(format='.1%')),
                    color=alt.Color('Entity:N', title=f'{cut_type}'),
                    tooltip=['Date:N', 'Entity:N', alt.Tooltip('WAPE LT:Q', format='.2%')]
                )
                
                # Points layer without legend (to avoid duplicates)
                weekly_points = base_chart.mark_circle(size=60).encode(
                    x=alt.X('Date:N', sort=date_order),
                    y=alt.Y('WAPE LT:Q'),
                    color=alt.Color('Entity:N', legend=None),  # No legend for points
                    tooltip=['Date:N', 'Entity:N', alt.Tooltip('WAPE LT:Q', format='.2%')]
                )
                
                # Combine lines and points
                weekly_combined = weekly_lines + weekly_points
                
                # Create horizontal aggregate reference line if available
                final_chart = weekly_combined
                if not aggregate_data.empty:
                    # Get the aggregate value (should be same for all entities in this cut)
                    aggregate_value = aggregate_data['WAPE LT'].iloc[0]
                    
                    # Create horizontal rule for aggregate
                    aggregate_rule = alt.Chart(pd.DataFrame({'y': [aggregate_value]})).mark_rule(
                        color='red', 
                        strokeDash=[5, 5], 
                        strokeWidth=2,
                        opacity=0.8
                    ).encode(
                        y=alt.Y('y:Q'),
                        tooltip=alt.value(f'Aggregate: {aggregate_value:.2%}')
                    )
                    
                    # Combine weekly lines+points with aggregate rule
                    final_chart = weekly_combined + aggregate_rule
                
                # Set chart properties with proper padding to prevent cutoff
                chart = final_chart.properties(
                    width=600,
                    height=300,
                    title=f'{cut_type} WAPE LT Trends' + (' (Red line = Aggregate)' if not aggregate_data.empty else '')
                ).resolve_scale(
                    color='independent'
                ).configure_axis(
                    labelAngle=0,
                    labelFontSize=10
                ).configure_view(
                    stroke=None
                ).configure(
                    padding={"left": 50, "top": 50, "right": 50, "bottom": 80}
                )
                
                st.altair_chart(chart, use_container_width=True)
            else:
                st.info(f"No data available for {cut_type} trend chart.")
            
            st.markdown("---")
        
        # Add Top 10 Individual Items Trend at the end
        st.markdown("**📈 Top 10 Individual Demand Items Trend**")
        create_top_demand_items_trend_chart(demand_data, wape_lt_cols, column_mapping)
    
    except Exception as e:
        st.error(f"Error creating trend charts: {str(e)}")


