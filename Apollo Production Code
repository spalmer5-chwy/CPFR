            value = row[col]
            if pd.notna(value):  # Include 0% values - they're valid WAPE rates
                chart_data.append({
                    'Date': date_label,
                    'Entity': entity_name,
                    'WAPE LT': float(value) if not pd.isna(value) else 0,
                    'Weighted_Error_Contribution': float(row['WEIGHTED_ERROR_CONTRIBUTION']) if pd.notna(row['WEIGHTED_ERROR_CONTRIBUTION']) else 0
