        latest_date = datetime.strptime(latest_date, '%m/%d/%Y').date()
    
    latest_date = latest_date + timedelta(days=6)  # Add 6 days for end of week
    
    # Get vendor list for filtering (removed circular SKU dependency)
    vendor_list = "', '".join(vendor_numbers)
    
    query = f"""
        WITH vendor_skus AS (
