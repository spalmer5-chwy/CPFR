            LEFT JOIN edldb.sc_sandbox.non_replenishable_items nr ON nr.snapshot_date = mps.activity_date AND mps.product_part_number = nr.product_part_number
            JOIN chewybi.products p ON p.product_part_number = mps.product_part_number
            JOIN vendor_skus vs ON p.product_part_number = vs.product_part_number
            WHERE 1=1
                AND mps.product_merch_classification2 <> 'Pharmacy'
                AND mps.product_merch_classification1 NOT IN ('Virtual Bundle','Gift Cards')
                AND date_trunc('week', mps.activity_date) BETWEEN 
                    date_trunc('week', '{start_date_str}'::date) AND 
                    date_trunc('week', '{end_date_str}'::date)
                AND nr.product_part_number IS NULL
                {dropship_filter}
                AND mps.product_is_compound = false
                AND mps.product_published_flag = true
                AND mps.product_merch_classification1 IS NOT NULL
                AND mps.product_merch_classification2 IS NOT NULL
                AND mps.product_merch_classification3 IS NOT NULL
                AND mps.brand IS NOT NULL
                AND mps.product_discontinued_flag = false
            GROUP BY p.product_merch_classification1
        ),
        
        mc1_contribution_with_weekly_calc AS (
            SELECT 
                mc1.product_merch_classification1 as field,
                NULL as product_name,
                'MC1' as cut,
                1 as priority_cut,
                mc1.{weekly_column_refs},
                COALESCE(mc1.total_oos_views / NULLIFZERO(SUM(mc1.total_oos_views) OVER()), 0) as oos_contribution
            FROM mc1_base mc1
            -- Removed WHERE filter to show all MC1 categories, even with 0% contribution
        ),
        
        mc1_contribution_with_weekly AS (
            SELECT *,
                ROW_NUMBER() OVER(ORDER BY oos_contribution DESC) as rn
            FROM mc1_contribution_with_weekly_calc
        ),
        
        -- MC2 Analysis
        mc2_base AS (
            SELECT 
                p.product_merch_classification2,
                {pdp_oos_columns},
                {oos_views_columns},
                {total_views_columns},
                {aggregate_pdp_oos},
                -- Computed averages for backward compatibility with downstream CTEs
                AVG(CASE WHEN date_trunc('week', mps.activity_date) BETWEEN date_trunc('week', '{start_date_str}'::date) AND date_trunc('week', '{end_date_str}'::date)
                    THEN mps.OutofStock_Distinct_PDP_Views / NULLIFZERO(mps.Distinct_PDP_Views) ELSE NULL END) as avg_pdp_oos,
                SUM(CASE WHEN date_trunc('week', mps.activity_date) BETWEEN date_trunc('week', '{start_date_str}'::date) AND date_trunc('week', '{end_date_str}'::date)
                    THEN mps.OutofStock_Distinct_PDP_Views ELSE 0 END) as total_oos_views,
                SUM(CASE WHEN date_trunc('week', mps.activity_date) BETWEEN date_trunc('week', '{start_date_str}'::date) AND date_trunc('week', '{end_date_str}'::date)
                    THEN mps.Distinct_PDP_Views ELSE 0 END) as total_views
            FROM mrch.merch_performance_snapshot_pharmacy mps
            LEFT JOIN edldb.sc_sandbox.non_replenishable_items nr ON nr.snapshot_date = mps.activity_date AND mps.product_part_number = nr.product_part_number
            JOIN chewybi.products p ON p.product_part_number = mps.product_part_number
            JOIN vendor_skus vs ON p.product_part_number = vs.product_part_number
            WHERE 1=1
                AND mps.product_merch_classification2 <> 'Pharmacy'
                AND mps.product_merch_classification1 NOT IN ('Virtual Bundle','Gift Cards')
                AND date_trunc('week', mps.activity_date) BETWEEN 
                    date_trunc('week', '{start_date_str}'::date) AND 
                    date_trunc('week', '{end_date_str}'::date)
                AND nr.product_part_number IS NULL
                {dropship_filter}
                AND mps.product_is_compound = false
                AND mps.product_published_flag = true
                AND mps.product_merch_classification1 IS NOT NULL
                AND mps.product_merch_classification2 IS NOT NULL
                AND mps.product_merch_classification3 IS NOT NULL
                AND mps.brand IS NOT NULL
                AND mps.product_discontinued_flag = false
            GROUP BY p.product_merch_classification2
        ),
        
        mc2_contribution_with_weekly_calc AS (
            SELECT 
                mc2.product_merch_classification2 as field,
                NULL as product_name,
                'MC2' as cut,
                2 as priority_cut,
                mc2.{weekly_column_refs},
                COALESCE(mc2.total_oos_views / NULLIFZERO(SUM(mc2.total_oos_views) OVER()), 0) as oos_contribution
            FROM mc2_base mc2
            -- Removed WHERE filter to show all MC2 categories, even with 0% contribution
        ),
        
        mc2_contribution_with_weekly AS (
            SELECT *,
                ROW_NUMBER() OVER(ORDER BY oos_contribution DESC) as rn
            FROM mc2_contribution_with_weekly_calc
        ),
        
        item_contribution_with_weekly_calc AS (
            SELECT 
                ib.sku as field,
                ib.product_name,
                'Top SKU OOS Contribution' as cut,
                5 as priority_cut,
                ib.{weekly_column_refs},
                COALESCE(ib.total_oos_views / NULLIFZERO(SUM(ib.total_oos_views) OVER()), 0) as oos_contribution
            FROM item_base ib
            WHERE ib.total_views > 0
        ),
        
        item_contribution_with_weekly AS (
            SELECT *,
                ROW_NUMBER() OVER(ORDER BY oos_contribution DESC) as rn
            FROM item_contribution_with_weekly_calc
        ),
        
        final_result AS (
            -- Vendor Summary with weekly breakdown
            SELECT 
                vs.field, vs.product_name, vs.cut, vs.priority_cut,
                {weekly_column_refs},
                vs.oos_contribution, vs.rn
            FROM vendor_summary vs
            
            UNION ALL
            
            -- MC1 Contributions
            SELECT 
                field, product_name, cut, priority_cut,
                {weekly_column_refs},
                oos_contribution, rn
            FROM mc1_contribution_with_weekly
            
            UNION ALL
            
            -- MC2 Contributions
            SELECT 
                field, product_name, cut, priority_cut,
                {weekly_column_refs},
                oos_contribution, rn
            FROM mc2_contribution_with_weekly
            
            UNION ALL
            
            -- Top 10 Brand Contributions
            SELECT 
                field, product_name, cut, priority_cut,
                {weekly_column_refs},
                oos_contribution, rn
            FROM brand_contribution_with_weekly
            WHERE rn <= 10
            
            UNION ALL
            
            -- All SKU Contributions (show only contributing SKUs)
            SELECT 
                field, product_name, cut, priority_cut,
                {weekly_column_refs},
                oos_contribution, rn
            FROM item_contribution_with_weekly
            WHERE oos_contribution > 0
        )
        
        SELECT 
            field, product_name, cut, oos_contribution,
            PDP_OOS_{trailing_weeks_suffix},
            {weekly_column_refs_without_aggregate}
        FROM final_result
        ORDER BY priority_cut, rn
    """
    
    return query, column_mapping


def create_oos_trend_charts(oos_data):
    """Create time series trend charts for OOS analysis"""
    try:
        # Get column mapping if available for proper date labels
        column_mapping = st.session_state.get('oos_column_mapping', {})
        
        # Identify weekly PDP OOS columns (exclude aggregate columns like T2W, T4W, T13W, etc.)
        pdp_oos_cols = [col for col in oos_data.columns 
                       if 'PDP_OOS' in col 
                       and not col.startswith('WOW')
                       and not any(suffix in col for suffix in ['_T2W', '_T4W', '_T13W', '_T26W', '_T52W'])]
        
        if not pdp_oos_cols:
            st.warning("No weekly PDP OOS data found for visualization.")
            return
        
        # Filter to vendor-level and category-level data (exclude individual SKUs)
        # Include Total Vendor, MC1/MC2, and brand contribution charts
        preferred_cuts = ['Total Vendor', 'MC1', 'MC2', 'Top PDP OOS Contribution']
        available_cuts = oos_data['CUT'].unique() if 'CUT' in oos_data.columns else []
        available_preferred_cuts = [cut for cut in preferred_cuts if cut in available_cuts]
        
        if available_preferred_cuts:
            viz_data = oos_data[oos_data['CUT'].isin(available_preferred_cuts)].copy()
        else:
            # Fallback to any non-SKU cuts
            trend_cuts = [cut for cut in available_cuts if not any(x in cut.lower() for x in ['sku', 'top sku', 'item'])][:5]
            if trend_cuts:
                viz_data = oos_data[oos_data['CUT'].isin(trend_cuts)].copy()
            else:
                viz_data = oos_data[oos_data['CUT'].isin(['Total Vendor'])].copy()
        
        if viz_data.empty:
            # Try to use any available data for trend analysis
            available_cuts = oos_data['CUT'].unique() if 'CUT' in oos_data.columns else []
            
            if len(available_cuts) > 0:
                # Use the first few available cuts, excluding SKU-level data for trend clarity
                trend_cuts = [cut for cut in available_cuts if not any(x in cut.lower() for x in ['sku', 'top sku', 'item'])][:3]
                if trend_cuts:
                    viz_data = oos_data[oos_data['CUT'].isin(trend_cuts)].copy()
                else:
                    st.info("No aggregated data available for trend visualization.")
                    return
            else:
                st.info("No data available for trend visualization.")
                return
        
        # Create trend chart for each available cut type
        available_cut_types = viz_data['CUT'].unique()
        for cut_type in available_cut_types:
            
            cut_data = viz_data[viz_data['CUT'] == cut_type]
            
            if cut_data.empty:
                continue
                
            st.markdown(f"**📈 {cut_type} OOS Rate Trends**")
            
            # Prepare data for line chart
            chart_data = []
            
            # Look for aggregate columns (e.g., T2W, T4W aggregate OOS rates)
            aggregate_oos_cols = [col for col in cut_data.columns if 'OOS' in col and any(suffix in col for suffix in ['_T2W', '_T4W', '_T13W', '_T26W', '_T52W'])]
            aggregate_oos_col = aggregate_oos_cols[0] if aggregate_oos_cols else None
            
            for _, row in cut_data.iterrows():
                entity_name = row.get('FIELD', row.get('PRODUCT_NAME', 'Unknown'))
                
                # Add aggregate OOS as reference data if available
                if aggregate_oos_col:
                    aggregate_value = row[aggregate_oos_col]
                    if pd.notna(aggregate_value):
                        chart_data.append({
                            'Date': 'Aggregate',
                            'Entity': entity_name,
                            'OOS Rate': float(aggregate_value),
                            'Type': 'Aggregate'
                        })
                
                # Add weekly data points
                for col in pdp_oos_cols:
                    # Get display date from column mapping, or use column name
                    date_label = column_mapping.get(col, col).replace('_PDP_OOS', '').replace('_', '/')
                    
                    value = row[col]
                    if pd.notna(value):  # Include 0% values - they're valid OOS rates
                        chart_data.append({
                            'Date': date_label,
                            'Entity': entity_name,
                            'OOS Rate': float(value) if not pd.isna(value) else 0,
                            'Type': 'Weekly'
                        })
            
            if chart_data:
                chart_df = pd.DataFrame(chart_data)
                
                # Create line chart with interactive selection
                import altair as alt
                
                # Separate weekly and aggregate data for different styling
                weekly_data = chart_df[chart_df['Type'] == 'Weekly']
                aggregate_data = chart_df[chart_df['Type'] == 'Aggregate'] if 'Type' in chart_df.columns else pd.DataFrame()
                
                # Convert date strings to datetime for proper sorting
                try:
                    weekly_data['Date_Sort'] = pd.to_datetime(weekly_data['Date'], format='%m/%d/%Y', errors='coerce')
                    # Sort dates chronologically and convert back to string for display
                    date_order = weekly_data.sort_values('Date_Sort')['Date'].unique().tolist()
                except:
                    # Fallback to string sorting if date conversion fails
                    date_order = sorted(list(weekly_data['Date'].unique()))
                
                # Create base chart for weekly data only
                base_chart = alt.Chart(weekly_data)
                
                # Weekly trend lines (solid lines with points) - keep cut-level legend
                weekly_lines = base_chart.mark_line(point=True, strokeWidth=2).encode(
                    x=alt.X('Date:N', title='Week Starting', sort=date_order),
                    y=alt.Y('OOS Rate:Q', title='OOS Rate', axis=alt.Axis(format='.1%')),
                    color=alt.Color('Entity:N', title=f'{cut_type}'),
                    tooltip=['Date:N', 'Entity:N', alt.Tooltip('OOS Rate:Q', format='.2%')]
                )
                
                # Create horizontal aggregate reference line if available
                final_chart = weekly_lines
                if not aggregate_data.empty:
                    # Get the aggregate value (should be same for all entities in this cut)
                    aggregate_value = aggregate_data['OOS Rate'].iloc[0]
                    
                    # Create horizontal rule for aggregate
                    aggregate_rule = alt.Chart(pd.DataFrame({'y': [aggregate_value]})).mark_rule(
                        color='red', 
                        strokeDash=[5, 5], 
                        strokeWidth=2,
                        opacity=0.8
                    ).encode(
                        y=alt.Y('y:Q'),
                        tooltip=alt.value(f'Aggregate: {aggregate_value:.2%}')
                    )
                    
                    # Combine weekly lines with aggregate rule
                    final_chart = weekly_lines + aggregate_rule
                
                # Set chart properties with proper padding to prevent cutoff
                chart = final_chart.properties(
                    width=600,
                    height=300,
                    title=f'{cut_type} OOS Rate Trends' + (' (Red line = Aggregate)' if not aggregate_data.empty else '')
                ).resolve_scale(
                    color='independent'
                ).configure_axis(
                    labelAngle=0,
                    labelFontSize=10
                ).configure_view(
                    stroke=None
                ).configure(
                    padding={"left": 50, "top": 50, "right": 50, "bottom": 80}
                )
                
                st.altair_chart(chart, use_container_width=True)
            else:
                st.info(f"No data available for {cut_type} trend chart.")
            
            st.markdown("---")
    
    except Exception as e:
        st.error(f"Error creating trend charts: {str(e)}")

def create_top_items_trend_chart(oos_data, pdp_oos_cols, column_mapping):
    """Create trend chart for top 10 individual OOS items"""
    try:
        # Get individual item data (SKUs/products, not aggregated)
        item_data = oos_data[
            oos_data['CUT'].str.contains('SKU|Item', case=False, na=False)
        ].copy()
        
        # If no SKU data, try product-level data
        if item_data.empty:
            item_data = oos_data[
                (~oos_data['CUT'].isin(['Total Vendor', 'MC1', 'MC2'])) &
                (~oos_data['CUT'].str.contains('PDP OOS Contribution', case=False, na=False))
            ].copy()
        
        if item_data.empty:
            st.info("No individual item data available for trend analysis.")
            return
        
        # Filter out contributions > 100% for quality
        item_data = item_data[item_data['OOS_CONTRIBUTION'] <= 1.0]
        
        # Get top 10 items by OOS contribution
        top_items = item_data.nlargest(10, 'OOS_CONTRIBUTION')
        
        if top_items.empty:
            st.info("No valid item data found for trend analysis.")
            return
        
        # Prepare data for line chart
        chart_data = []
        
        for _, row in top_items.iterrows():
            # Use FIELD for SKU/product identifier, fallback to PRODUCT_NAME
            entity_name = row.get('FIELD', row.get('PRODUCT_NAME', 'Unknown'))
            # Truncate long names for readability
            entity_display = entity_name[:25] + '...' if len(entity_name) > 25 else entity_name
            
            for col in pdp_oos_cols:
                # Skip aggregate columns for individual SKU charts - only show weekly data
                if 'T2W' in col or 'T4W' in col or 'T13W' in col or 'T26W' in col or 'T52W' in col:
                    continue
                    
                # Get display date from column mapping
                date_label = column_mapping.get(col, col).replace('_PDP_OOS', '').replace('_', '/')
                
                value = row[col]
                if pd.notna(value) and value > 0:  # Only show positive OOS rates
                    chart_data.append({
                        'Date': date_label,
                        'Item': entity_display,
                        'OOS Rate': float(value),
                        'OOS Contribution': f"{float(row['OOS_CONTRIBUTION']):.1%}"
                    })
        
        if chart_data:
            chart_df = pd.DataFrame(chart_data)
            
            import altair as alt
            
            # Convert date strings to datetime for proper sorting
            try:
                chart_df['Date_Sort'] = pd.to_datetime(chart_df['Date'], format='%m/%d/%Y', errors='coerce')
                # Sort dates chronologically and convert back to string for display
                date_order = chart_df.sort_values('Date_Sort')['Date'].unique().tolist()
            except:
                # Fallback to string sorting if date conversion fails
                date_order = sorted(list(chart_df['Date'].unique()))
            
            # Create interactive selection
            click_selection = alt.selection_multi(fields=['Item'])
            
            # Base chart with click selection
            base_chart = alt.Chart(chart_df).add_selection(click_selection)
            
            # Lines only (clean, no filling)
            lines = base_chart.mark_line(
                point=False,
                strokeWidth=2,
                interpolate='linear'
            ).encode(
                x=alt.X('Date:N', title='Week Starting', sort=date_order),
                y=alt.Y('OOS Rate:Q', title='OOS Rate', axis=alt.Axis(format='.1%')),
                color=alt.Color('Item:N', title='Top OOS Items (Click to Select)', scale=alt.Scale(scheme='category20')),
                opacity=alt.condition(click_selection, alt.value(1.0), alt.value(0.7)),
                strokeWidth=alt.condition(click_selection, alt.value(4), alt.value(2))
            )
            
            # Subtle points (much smaller, just for interaction)
            points = base_chart.mark_circle().encode(
                x=alt.X('Date:N', sort=date_order),
                y=alt.Y('OOS Rate:Q'),
                color=alt.Color('Item:N', scale=alt.Scale(scheme='category20'), legend=None),
                opacity=alt.condition(click_selection, alt.value(1.0), alt.value(0.7)),
                size=alt.condition(click_selection, alt.value(60), alt.value(30)),
                tooltip=['Date:N', 'Item:N', alt.Tooltip('OOS Rate:Q', format='.2%'), 'OOS Contribution:N']
            )
            
            chart = (lines + points).resolve_scale(
                color='independent'
            ).properties(
                width=700,
                height=400,
                title='Top 10 Individual OOS Items - Rate Trends Over Time (Click legend to highlight)'
            ).configure_axis(
                labelAngle=0,
                labelFontSize=10
            ).configure_view(
                stroke=None
            ).configure(
                padding={"left": 50, "top": 50, "right": 50, "bottom": 80}
            )
            
            st.altair_chart(chart, use_container_width=True)
            
            # Add summary info
            total_contribution = top_items['OOS_CONTRIBUTION'].sum()
            st.info(f"📊 Top {len(top_items)} SKUs account for {total_contribution:.1%} of total OOS contribution")
            
        else:
            st.info("No valid trend data available for individual items.")
    
    except Exception as e:
        st.error(f"Error creating top items trend chart: {str(e)}")

