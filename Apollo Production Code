def get_chewy_period_dates(start_date: date, num_periods: int = 12) -> List[Tuple[date, date]]:
    """
    Get Chewy period date ranges based on start date using actual Chewy financial calendar.
    
    This function looks up the start_date in the COMMON_DATE table to find which Chewy period
    it falls into, then returns that period and subsequent periods with their actual dates.
    
    IMPORTANT: This function will raise an error if it cannot connect to Snowflake or retrieve
    accurate period data. No approximations or fallbacks are used to ensure data accuracy
    for vendor sharing.
    
    Args:
        start_date: Starting date provided by ISM
        num_periods: Number of periods to generate
        
    Returns:
        List of (start_date, end_date) tuples for each period
        
    Raises:
        ValueError: If Snowflake connection fails or period data cannot be retrieved
    """
    try:
        # Get Snowflake session
        session = snowflake_get_active_session()
        
        # Query to find the Chewy period that contains the start_date
        lookup_query = f"""
        SELECT 
            FINANCIAL_CALENDAR_REPORTING_PERIOD,
            FIRST_DAY_OF_FINANCIAL_CALENDAR_REPORTING_PERIOD,
            LAST_DAY_OF_FINANCIAL_CALENDAR_REPORTING_PERIOD
        FROM EDLDB.CHEWYBI.COMMON_DATE
        WHERE COMMON_DATE_DTTM::DATE = '{start_date.strftime('%Y-%m-%d')}'
        LIMIT 1
        """
        
        result = session.sql(lookup_query).collect()
        
        if not result:
            # Fallback: find the closest date if exact match not found
            closest_query = f"""
            SELECT 
                FINANCIAL_CALENDAR_REPORTING_PERIOD,
                FIRST_DAY_OF_FINANCIAL_CALENDAR_REPORTING_PERIOD,
                LAST_DAY_OF_FINANCIAL_CALENDAR_REPORTING_PERIOD
            FROM EDLDB.CHEWYBI.COMMON_DATE
            WHERE COMMON_DATE_DTTM::DATE >= '{start_date.strftime('%Y-%m-%d')}'
            ORDER BY COMMON_DATE_DTTM::DATE ASC
            LIMIT 1
            """
            result = session.sql(closest_query).collect()
        
        if not result:
            raise ValueError(f"Could not find Chewy period for date {start_date}")
        
        # Get the starting period info
        starting_period = result[0]['FINANCIAL_CALENDAR_REPORTING_PERIOD']
        
        # Now get the sequence of periods starting from this period
        periods_query = f"""
        WITH period_sequence AS (
            SELECT DISTINCT
                FINANCIAL_CALENDAR_REPORTING_PERIOD,
                FIRST_DAY_OF_FINANCIAL_CALENDAR_REPORTING_PERIOD::DATE as period_start,
                LAST_DAY_OF_FINANCIAL_CALENDAR_REPORTING_PERIOD::DATE as period_end,
                ROW_NUMBER() OVER (ORDER BY FIRST_DAY_OF_FINANCIAL_CALENDAR_REPORTING_PERIOD) as period_rank
            FROM EDLDB.CHEWYBI.COMMON_DATE
            WHERE FIRST_DAY_OF_FINANCIAL_CALENDAR_REPORTING_PERIOD >= 
                (SELECT FIRST_DAY_OF_FINANCIAL_CALENDAR_REPORTING_PERIOD 
                 FROM EDLDB.CHEWYBI.COMMON_DATE 
                 WHERE FINANCIAL_CALENDAR_REPORTING_PERIOD = '{starting_period}'
                 LIMIT 1)
        )
        SELECT 
            FINANCIAL_CALENDAR_REPORTING_PERIOD,
            period_start,
            period_end
        FROM period_sequence
        WHERE period_rank <= {num_periods}
        ORDER BY period_start
        """
        
        periods_result = session.sql(periods_query).collect()
        
        # Convert to list of tuples
        periods = []
        for row in periods_result:
            start = row['PERIOD_START']
            end = row['PERIOD_END']
            periods.append((start, end))
        
        return periods
        
    except Exception as e:
        # No fallback - raise error to ensure data accuracy for vendor sharing
        error_msg = f"Unable to retrieve Chewy period data from Snowflake: {str(e)}"
        raise ValueError(error_msg)

def get_weekly_periods(start_date: date, num_periods: int = 12) -> List[Tuple[date, date]]:
    """
    Get weekly period date ranges (Monday to Sunday).
    
    Args:
        start_date: Starting date (will find the Monday of that week or use as-is if it's a Monday)
        num_periods: Number of weeks to generate
        
    Returns:
        List of (start_date, end_date) tuples for each week
    """
    periods = []
    
    # Find the Monday of the start_date week
    # Monday = 0, Tuesday = 1, ..., Sunday = 6
    days_since_monday = start_date.weekday()
    
    # If start_date is already a Monday, use it as-is, otherwise find the Monday of that week
    week_start = start_date - timedelta(days=days_since_monday)
    
    for i in range(num_periods):
        week_end = week_start + timedelta(days=6)  # Sunday
        periods.append((week_start, week_end))
        week_start = week_end + timedelta(days=1)  # Next Monday
    
    return periods

def get_monthly_periods(start_date: date, num_periods: int = 12) -> List[Tuple[date, date]]:
    """
    Get monthly period date ranges (first day to last day of month).
    
    Args:
        start_date: Starting date (will use the first day of that month)
        num_periods: Number of months to generate
        
    Returns:
        List of (start_date, end_date) tuples for each month
    """
    periods = []
    
    # Start from the first day of the start_date month
    current_date = start_date.replace(day=1)
    
    for i in range(num_periods):
        # Find the last day of the current month
        if current_date.month == 12:
            next_month = current_date.replace(year=current_date.year + 1, month=1)
        else:
            next_month = current_date.replace(month=current_date.month + 1)
        
        month_end = next_month - timedelta(days=1)
        
        periods.append((current_date, month_end))
        current_date = next_month
    
    return periods

def get_custom_periods(start_date: date, custom_days: Dict[str, int]) -> List[Tuple[date, date]]:
    """
    Get custom period date ranges based on user-defined day counts.
    
    Args:
        start_date: Starting date for the first period
        custom_days: Dictionary with period names and day counts (e.g., {'Month_1': 28, 'Month_2': 35})
        
    Returns:
        List of (start_date, end_date) tuples for each custom period
    """
    periods = []
    current_start = start_date
    
    # Sort by period name to ensure correct order (Month_1, Month_2, etc.)
    sorted_periods = sorted(custom_days.items(), key=lambda x: int(x[0].split('_')[1]))
    
    for period_name, days in sorted_periods:
        current_end = current_start + timedelta(days=days - 1)
        periods.append((current_start, current_end))
        current_start = current_end + timedelta(days=1)
    
    return periods

def map_forecast_periods(period_type: str, start_date: date, num_periods: int = None, custom_days: Dict[str, int] = None) -> Dict[str, Any]:
    """
    Main function to map forecast periods to actual date ranges.
    
    The ISM provides a forecast start date, and this function converts it based on period type:
    - Month: Uses the first day of the start_date month
    - Week: Snaps to the Monday of the start_date week
    - Custom: Uses start_date as-is (exact start of first period)
    
    Args:
        period_type: 'Month', 'Week', or 'Custom'
        start_date: Starting date provided by ISM for the forecast
        num_periods: Number of periods (for Month and Week types)
        custom_days: Dictionary of custom period lengths (for Custom type)
        
    Returns:
        Dictionary containing:
        - 'periods': List of (start_date, end_date) tuples
        - 'period_names': List of human-readable period names
        - 'total_days': Total number of days covered
        - 'date_range': Overall (start_date, end_date) tuple
        - 'period_type': The period type used
        - 'num_periods': Number of periods generated
    """
    
    if period_type == "Month":
        periods = get_monthly_periods(start_date, num_periods or 12)
        period_names = [f"{start.strftime('%B %Y')}" for start, end in periods]
        
        # Debug: Show what monthly periods were generated (in Streamlit)
        import streamlit as st
        if st.session_state.get('debug_mode', False):
            st.write(f"**DEBUG - Monthly periods for start_date {start_date}, num_periods {num_periods or 12}:**")
            for i, (start, end) in enumerate(periods):
                st.write(f"  Period {i}: {start} to {end} ({start.strftime('%B %Y')})")
            st.write(f"**DEBUG - Period names:** {period_names}")
    
    elif period_type == "Week":
        periods = get_weekly_periods(start_date, num_periods or 12)
        period_names = [f"Week of {start.strftime('%b %d, %Y')}" for start, end in periods]
        
        # Debug: Show what weekly periods were generated (in Streamlit)
        import streamlit as st
        if st.session_state.get('debug_mode', False):
            st.write(f"**DEBUG - Weekly periods for start_date {start_date}, num_periods {num_periods or 12}:**")
            for i, (start, end) in enumerate(periods):
                st.write(f"  Period {i}: {start} to {end} (Week of {start.strftime('%b %d, %Y')})")
            st.write(f"**DEBUG - Period names:** {period_names}")
    
    elif period_type == "Custom":
        if not custom_days:
            raise ValueError("Custom period type requires custom_days parameter")
        periods = get_custom_periods(start_date, custom_days)
        
        # Use custom names from session state if available, fallback to generic names
        # Note: We need to import streamlit here since it's not in global scope
        try:
            import streamlit as st
            custom_names = st.session_state.get('custom_period_names', {})
        except:
            # Fallback if streamlit not available (shouldn't happen in normal use)
            custom_names = {}
        
        period_names = []
        
        sorted_period_keys = sorted(custom_days.keys(), key=lambda x: int(x.split('_')[1]))
        for period_key, (start, end) in zip(sorted_period_keys, periods):
            # Get custom name or fallback to cleaned generic name
            custom_name = custom_names.get(period_key, period_key.replace('_', ' '))
            period_names.append(f"{custom_name} ({start.strftime('%m/%d')} - {end.strftime('%m/%d')})")
    
    else:
        raise ValueError(f"Unknown period type: {period_type}")
    
    # Calculate total days and overall date range
    if periods:
        total_days = sum((end - start).days + 1 for start, end in periods)
        overall_start = periods[0][0]
        overall_end = periods[-1][1]
        date_range = (overall_start, overall_end)
    else:
        total_days = 0
        date_range = (start_date, start_date)
    
    return {
        'periods': periods,
        'period_names': period_names,
        'total_days': total_days,
        'date_range': date_range,
        'period_type': period_type,
        'num_periods': len(periods)
    }

def validate_period_mapping(period_mapping: Dict[str, Any], forecast_columns: List[str]) -> Dict[str, Any]:
    """
    Validate that the period mapping aligns with the forecast columns from the CSV.
    
    Args:
        period_mapping: Result from map_forecast_periods()
        forecast_columns: List of forecast column names from the uploaded CSV
        
    Returns:
        Dictionary containing:
        - 'is_valid': Boolean indicating if mapping is valid
        - 'warnings': List of warning messages
        - 'column_mapping': Dictionary mapping CSV columns to period dates
    """
    warnings = []
    column_mapping = {}
    
    num_csv_columns = len(forecast_columns)
    num_mapped_periods = len(period_mapping['periods'])
    
    # Check if we have more CSV columns than mapped periods
    if num_csv_columns > num_mapped_periods:
        warnings.append(f"CSV has {num_csv_columns} forecast columns but only {num_mapped_periods} periods mapped. Extra columns will be ignored.")
        # Use only the first N periods that match CSV columns
        used_periods = period_mapping['periods'][:num_csv_columns]
        used_names = period_mapping['period_names'][:num_csv_columns]
    
    # Check if we have fewer CSV columns than mapped periods
    elif num_csv_columns < num_mapped_periods:
        warnings.append(f"CSV has only {num_csv_columns} forecast columns but {num_mapped_periods} periods were mapped. Some periods will have no data.")
        # Use all CSV columns and map to first N periods
        used_periods = period_mapping['periods'][:num_csv_columns]
        used_names = period_mapping['period_names'][:num_csv_columns]
    
    else:
        # Perfect match
        used_periods = period_mapping['periods']
        used_names = period_mapping['period_names']
    
    # Create column mapping
    for i, (col_name, period_dates, period_name) in enumerate(zip(forecast_columns, used_periods, used_names)):
        column_mapping[col_name] = {
            'period_index': i,
            'start_date': period_dates[0],
            'end_date': period_dates[1],
            'period_name': period_name,
            'days_in_period': (period_dates[1] - period_dates[0]).days + 1
        }
    
    is_valid = len(warnings) == 0 or all('ignored' in w or 'no data' in w for w in warnings)
    
    return {
        'is_valid': is_valid,
        'warnings': warnings,
        'column_mapping': column_mapping,
        'used_periods': used_periods,
        'used_period_names': used_names
    }

