def create_top_nop_items_trend_chart(nop_data, nop_rate_cols, column_mapping):
    """Create trend chart for top 10 individual NOP items"""
    try:
        import altair as alt
        # Get individual item data (SKUs/products, not aggregated)
        item_data = nop_data[
            nop_data['CUT'].str.contains('SKU|Item|Top NOP SKU', case=False, na=False)
        ].copy()
        
        # If no SKU data, try product-level data
        if item_data.empty:
            item_data = nop_data[
                (~nop_data['CUT'].isin(['Total Vendor', 'MC1', 'MC2'])) &
                (~nop_data['CUT'].str.contains('NOP Contribution', case=False, na=False))
            ].copy()
        
        if item_data.empty:
            st.info("No individual item data available for trend analysis.")
            return
        
        # Filter out contributions > 100% for quality
        item_data = item_data[item_data['NOP_CONTRIBUTION'] <= 1.0]
        
        # Get top 10 items by NOP contribution
        top_items = item_data.nlargest(10, 'NOP_CONTRIBUTION')
        
        if top_items.empty:
            st.info("No valid item data found for trend analysis.")
            return
        
        # Prepare data for line chart
        chart_data = []
        
        for _, row in top_items.iterrows():
            # Use FIELD for SKU/product identifier, fallback to PRODUCT_NAME
            entity_name = row.get('FIELD', row.get('PRODUCT_NAME', 'Unknown'))
            # Truncate long names for readability
            entity_display = entity_name[:25] + '...' if len(entity_name) > 25 else entity_name
            
            for col in nop_rate_cols:
                # Get display date from column mapping
                date_label = column_mapping.get(col, col).replace('_NOP', '').replace('_', '/')
                
                value = row[col]
                if pd.notna(value):  # Include 0 values, just exclude NaN/null
                    # Handle both raw decimal values and formatted percentage strings
                    if isinstance(value, str) and '%' in value:
                        # If it's already a formatted percentage string, convert back to decimal
                        numeric_value = float(value.replace('%', '')) / 100
                    else:
                        # If it's a raw decimal value, use as-is
                        numeric_value = float(value)
                    
                    chart_data.append({
                        'Date': date_label,
                        'Item': entity_display,
                        'NOP Rate': numeric_value,
                        'NOP Contribution': f"{float(row['NOP_CONTRIBUTION']) if isinstance(row['NOP_CONTRIBUTION'], (int, float)) else float(str(row['NOP_CONTRIBUTION']).replace('%', '')) / 100:.1%}"
                    })
        
        if chart_data:
            chart_df = pd.DataFrame(chart_data)
            
            unique_items = chart_df['Item'].unique()
            if len(unique_items) > 10:
                st.warning(f"Found {len(unique_items)} unique items, limiting to top 10 by contribution")
                # Get the top 10 items by max NOP contribution in the chart data
                item_contributions = chart_df.groupby('Item')['NOP Contribution'].first().str.rstrip('%').astype(float)
                top_10_items = item_contributions.nlargest(10).index.tolist()
                chart_df = chart_df[chart_df['Item'].isin(top_10_items)]
            
            # Convert date strings to datetime for proper sorting
            try:
                chart_df['Date_Sort'] = pd.to_datetime(chart_df['Date'], format='%m/%d/%Y', errors='coerce')
                # Sort dates chronologically and convert back to string for display
                date_order = chart_df.sort_values('Date_Sort')['Date'].unique().tolist()
            except:
                # Fallback to string sorting if date conversion fails
                date_order = sorted(list(chart_df['Date'].unique()))
            
            import altair as alt
            
            # Create interactive selection
            click_selection = alt.selection_multi(fields=['Item'])
            
            # Base chart with selections
            base_chart = alt.Chart(chart_df).add_selection(click_selection)
            
            # Lines only (clean, no filling)
            lines = base_chart.mark_line(
                point=False,
                strokeWidth=2,
                interpolate='linear'
            ).encode(
                x=alt.X('Date:N', title='Week Starting', sort=date_order),
                y=alt.Y('NOP Rate:Q', title='NOP Rate', 
                       axis=alt.Axis(format='.2%', tickCount=10), 
                       scale=alt.Scale(zero=False, nice=True)),
                color=alt.Color('Item:N', title='Top 10 NOP Items (Click to Select)', scale=alt.Scale(scheme='category20')),
                opacity=alt.condition(click_selection, alt.value(1.0), alt.value(0.7)),
                strokeWidth=alt.condition(click_selection, alt.value(4), alt.value(2))
            )
            
            # Subtle points (much smaller, just for interaction)
            points = base_chart.mark_circle().encode(
                x=alt.X('Date:N'),
                y=alt.Y('NOP Rate:Q'),
                color=alt.Color('Item:N', scale=alt.Scale(scheme='category20'), legend=None),
                opacity=alt.condition(click_selection, alt.value(1.0), alt.value(0.7)),
                size=alt.condition(click_selection, alt.value(60), alt.value(30)),
                tooltip=['Date:N', 'Item:N', alt.Tooltip('NOP Rate:Q', format='.2%'), 'NOP Contribution:N']
            )
            
            chart = (lines + points).resolve_scale(
                color='independent'
            ).properties(
                width=700,
                height=400,
                title='Top 10 Individual NOP Items - Rate Trends Over Time (Click legend to highlight)'
            ).configure_axis(
                labelAngle=0,
                labelFontSize=10
            ).configure_view(
                stroke=None
            ).configure(
                padding={"left": 50, "top": 50, "right": 50, "bottom": 80}
            )
            
            st.altair_chart(chart, use_container_width=True)
            
            # Add summary info
            total_contribution = top_items['NOP_CONTRIBUTION'].sum()
            st.info(f"**Top 10 NOP Items Summary:** Combined contribution of {total_contribution:.1%} to total non-optimal units")
        else:
            st.info("No trend data available for individual items.")
    
    except Exception as e:
        st.error(f"Error creating top NOP items trend chart: {str(e)}")


