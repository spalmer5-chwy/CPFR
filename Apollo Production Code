def create_vendor_search_lookup_query(region="US"):
    """Create a comprehensive vendor lookup table for name search using vendor config data"""
    
    # Note: Using vendor config table eliminates the need for region filtering
    # as it provides clean vendor-to-parent relationships without product noise
    
    query = """
    WITH vendor_search_base AS (
        SELECT DISTINCT
            v.vendor_number,
            v.vendor_name,
            vc.PARENT_VENDOR as parent_company,
            -- Create searchable variations
            LOWER(TRIM(v.vendor_name)) as vendor_name_clean,
            LOWER(TRIM(vc.PARENT_VENDOR)) as parent_company_clean
        FROM EDLDB.CHEWYBI.vendor_agreement_line vl
        JOIN EDLDB.CHEWYBI.vendors v ON v.vendor_number = vl.vendor_number
        JOIN EDLDB.SC_INVENTORY_MANAGEMENT_SANDBOX.VC_SPARK_VENDOR_CONFIG_DATA vc ON vc.VENDOR_ID = v.vendor_number
        WHERE CURRENT_DATE BETWEEN COALESCE(vl.agreement_line_start_date::DATE, CURRENT_DATE)
            AND COALESCE(vl.agreement_line_end_date::DATE, CURRENT_DATE)
            AND COALESCE(vl.disabled_reason_code,'') = ''
            AND COALESCE(vl.agreement_line_status,'') NOT IN ('CANCELED')
            AND vl.active_agreement = 1
    ),
    
    -- Create unified search index with vendor names and parent companies only
    search_index AS (
        -- Vendor names
        SELECT 
            vendor_number,
            vendor_name as display_name,
            vendor_name_clean as search_term,
            'Vendor Name' as search_type,
            1 as priority_score,
            parent_company
        FROM vendor_search_base
        WHERE vendor_name_clean IS NOT NULL AND vendor_name_clean != ''
        
        UNION ALL
        
        -- Parent companies
        SELECT 
            vendor_number,
            vendor_name as display_name, 
            parent_company_clean as search_term,
            'Parent Company' as search_type,
            2 as priority_score,
            parent_company
        FROM vendor_search_base
        WHERE parent_company_clean IS NOT NULL AND parent_company_clean != ''
    )
    
    SELECT 
        vendor_number,
        display_name,
        search_term,
        search_type,
        priority_score,
        parent_company,
        -- Create match scoring for relevance
        CASE 
            WHEN search_type = 'Vendor Name' THEN 100
            WHEN search_type = 'Parent Company' THEN 80
        END as base_relevance_score
    FROM search_index
    ORDER BY search_term, priority_score
    """
    
    return query


@st.cache_data(ttl=1800)  # Cache for 30 minutes
def get_cached_vendor_lookup(region: str):
    """Cached vendor lookup data to improve name search performance"""
    session = get_snowflake_session()
    if session:
        try:
            query = create_vendor_search_lookup_query(region)
            result = session.sql(query).collect()
            return [row.as_dict() for row in result]
        except Exception as e:
            st.error(f"Error loading vendor lookup data: {e}")
            return []
    return []


def get_search_suggestions(search_term: str, region: str = "US", max_suggestions: int = 5) -> list:
    """Get search suggestions for autocomplete-like functionality"""
    if not search_term or len(search_term.strip()) < 1:
        return []
    
    search_term_clean = search_term.lower().strip()
    lookup_data = get_cached_vendor_lookup(region)
    
    suggestions = set()
    
    for item in lookup_data:
        search_target = item.get('SEARCH_TERM', '')
        if search_target and search_target.startswith(search_term_clean):
            suggestions.add(search_target.title())  # Capitalize for display
            
    return sorted(list(suggestions))[:max_suggestions]


def perform_vendor_name_search(search_term: str, region: str = "US", max_results: int = 15) -> list:
    """
    Perform intelligent vendor search with tightened fuzzy matching
    
    Args:
        search_term: User's search input (e.g., "clorox", "nestl", "hills")
        region: Business region (US/Canada)
        max_results: Maximum number of results to return
    
    Returns:
        List of matching vendors with relevance scores
    """
    import difflib
    import re
    
    if not search_term or len(search_term.strip()) < 2:
        return []
    
    search_term_clean = search_term.lower().strip()
    search_length = len(search_term_clean)
    
    # Create normalized versions for better matching of and/&/+ variations
    def normalize_text(text):
        """Normalize text for better fuzzy matching"""
        import re
        # Replace common variations
        text = re.sub(r'\b(and|&|\+)\b', ' and ', text, flags=re.IGNORECASE)
        # Remove extra spaces
        text = re.sub(r'\s+', ' ', text).strip()
        return text
    
    search_term_normalized = normalize_text(search_term_clean)
    
    # Get cached lookup data
    lookup_data = get_cached_vendor_lookup(region)
    
    if not lookup_data:
        return []
    
    matches = []
    
    for item in lookup_data:
        search_target = item.get('SEARCH_TERM', '')
        if not search_target:
            continue
            
        target_length = len(search_target)
        search_target_normalized = normalize_text(search_target)
        
        # Skip targets that are too short or too different in length
        if target_length < 2:
            continue
            
        # Length difference filter - avoid wildly different length matches
        length_ratio = min(search_length, target_length) / max(search_length, target_length)
        if length_ratio < 0.2:  # Skip if one is more than 5x longer than the other
            continue
        
        # Calculate match score using multiple methods with tighter constraints
        scores = []
        match_quality = None
        similarity_ratio = 0  # Initialize similarity ratio
        
        # 1. Exact match (highest score) - check both original and normalized
        if (search_term_clean == search_target or 
            search_term_normalized == search_target_normalized):
            scores.append(1000)
            match_quality = "exact"
            similarity_ratio = 1.0
        
        # 2. Starts with match (high score) - check both versions
        elif (search_target.startswith(search_term_clean) or 
            search_target_normalized.startswith(search_term_normalized)):
            # Give higher score if the search term is a substantial portion
            portion_ratio = search_length / target_length
            if portion_ratio >= 0.3:  # Search term is at least 30% of target
                scores.append(800)
                match_quality = "prefix_strong"
            elif portion_ratio >= 0.15:  # At least 15% of target (more generous)
                scores.append(650)
                match_quality = "prefix_medium"
            elif search_length >= 3:  # For 3+ character searches, allow smaller ratios
                scores.append(500)
                match_quality = "prefix_weak"
            # Skip very small prefix matches only for 1-2 character searches
            similarity_ratio = 0.9  # High similarity for prefix matches
            
        # 3. Contains match with word boundary preference - check both versions  
        elif (search_term_clean in search_target or 
            search_term_normalized in search_target_normalized):
            # Check if it's a word boundary match (better quality) - try both versions
            word_boundary_pattern = r'\b' + re.escape(search_term_clean) + r'\b'
            word_boundary_pattern_norm = r'\b' + re.escape(search_term_normalized) + r'\b'
            
            if (re.search(word_boundary_pattern, search_target) or 
                re.search(word_boundary_pattern_norm, search_target_normalized)):
                scores.append(700)  # Higher score for word boundary
                match_quality = "word_boundary"
                similarity_ratio = 0.9  # High similarity for word boundary
            else:
                # Regular contains match, but check portion size
                portion_ratio = search_length / target_length
                if portion_ratio >= 0.25:  # Search term is at least 25% of target
                    scores.append(550)
                    match_quality = "contains_substantial"
                    similarity_ratio = 0.8
                elif portion_ratio >= 0.15:  # At least 15% of target (more generous)
                    scores.append(400)
                    match_quality = "contains_medium"
                    similarity_ratio = 0.7
                elif search_length >= 4:  # For longer searches, be more lenient
                    scores.append(300)
                    match_quality = "contains_weak"
                    similarity_ratio = 0.6
                # Skip very small substring matches for short terms only
        
        # 4. Enhanced fuzzy matching with normalization for "and"/"&"/"+" handling
        else:
            # Do fuzzy matching for reasonable length terms
            if search_length >= 3:
                # Calculate similarity for both original and normalized versions
                similarity_original = difflib.SequenceMatcher(None, search_term_clean, search_target).ratio()
                similarity_normalized = difflib.SequenceMatcher(None, search_term_normalized, search_target_normalized).ratio()
                
                # Use the better of the two similarities
                similarity_ratio = max(similarity_original, similarity_normalized)
                
                # More balanced similarity thresholds
                if similarity_ratio >= 0.8:  # Very high similarity
                    scores.append(int(similarity_ratio * 500))
                    match_quality = "fuzzy_high"
                elif similarity_ratio >= 0.7:  # Good similarity
                    scores.append(int(similarity_ratio * 400))
                    match_quality = "fuzzy_medium"
                elif similarity_ratio >= 0.6 and search_length >= 4:  # Moderate similarity for longer terms
                    scores.append(int(similarity_ratio * 300))
                    match_quality = "fuzzy_low"
                elif similarity_ratio >= 0.55 and search_length >= 5:  # Weaker similarity for 5+ character terms
                    scores.append(int(similarity_ratio * 200))
                    match_quality = "fuzzy_weak"
        
        # If we found any matches, calculate final score
        if scores:
            match_score = max(scores)
            search_type = item.get('SEARCH_TYPE', '')
            
            # Apply stricter quality filter for both vendor names and parent companies
            if similarity_ratio < 0.85:
                # Skip this match if it's below 85% similarity
                continue
            
            # Apply additional quality filters
            base_relevance = item.get('BASE_RELEVANCE_SCORE', 0)
            
            # Boost scores for vendor names over parent companies for exact/strong matches
            if match_quality in ["exact", "prefix_strong", "word_boundary"]:
                final_score = match_score + base_relevance
            else:
                # Slightly reduce scores for weaker matches on parent companies
                if search_type != 'Vendor Name':
                    final_score = match_score + (base_relevance * 0.8)
                else:
                    final_score = match_score + base_relevance
            
            matches.append({
                'vendor_number': item.get('VENDOR_NUMBER'),
                'display_name': item.get('DISPLAY_NAME'), 
                'search_term': search_target,
                'search_type': item.get('SEARCH_TYPE'),
                'match_score': match_score,
                'final_score': final_score,
                'matched_text': search_target,
                'match_quality': match_quality,
                'similarity_ratio': similarity_ratio,
                'parent_company': item.get('PARENT_COMPANY', '')
            })
    
    # First sort by relevance to get the best matches
    matches.sort(key=lambda x: x['final_score'], reverse=True)
    
    # Enhanced deduplication with quality preference
    seen_vendors = set()
    unique_matches = []
    
    for match in matches:
        vendor_num = match['vendor_number']
        if vendor_num not in seen_vendors:
            seen_vendors.add(vendor_num)
            unique_matches.append(match)
    
    # Now sort the unique matches by: Parent Company, Vendor Name
    def get_sort_key(match):
        parent_company = (match.get('parent_company') or '').strip()
        vendor_name = (match.get('display_name') or '').strip()
        
        # Handle empty parent companies by putting them at the end
        if not parent_company:
            parent_company = 'zzz_no_parent'
        
        return (parent_company.lower(), vendor_name.lower())
    
    unique_matches.sort(key=get_sort_key)
            
    # Additional quality filter - more lenient to show relevant results
    if len(unique_matches) > 10:
        # Only filter if we have too many matches
        filtered_matches = []
        for match in unique_matches:
            # Keep all good quality matches
            if match['match_quality'] in ['exact', 'prefix_strong', 'prefix_medium', 'prefix_weak', 'word_boundary', 'contains_substantial', 'contains_medium']:
                filtered_matches.append(match)
            # Keep fuzzy matches that are reasonably good
            elif match['match_quality'] in ['fuzzy_high', 'fuzzy_medium'] and len(filtered_matches) < 12:
                filtered_matches.append(match)
            # Keep weaker matches if we don't have many results yet
            elif match['match_quality'] in ['fuzzy_low', 'contains_weak'] and len(filtered_matches) < 8:
                filtered_matches.append(match)
            # Only exclude the very weakest matches
            elif match['match_quality'] == 'fuzzy_weak' and len(filtered_matches) < 6:
                filtered_matches.append(match)
        
        unique_matches = filtered_matches
    
    return unique_matches[:max_results]


def format_search_results(matches: list) -> list:
    """Format search results for display in selectbox with match quality"""
    formatted = []
    
    for match in matches:
        # Create clear, informative display text with match quality indicator
        match_quality = match.get('match_quality', 'unknown')
        
        # Add quality indicators for better user understanding
        quality_indicators = {
            'exact': '🎯',
            'prefix_strong': '✅', 
            'prefix_medium': '✅',
            'prefix_weak': '✅',
            'word_boundary': '🔍',
            'contains_substantial': '📍',
            'contains_medium': '📍',
            'contains_weak': '📍',
            'fuzzy_high': '🔀',
            'fuzzy_medium': '🔀',
            'fuzzy_low': '⚡',
            'fuzzy_weak': '⚡'
        }
        
        quality_icon = quality_indicators.get(match_quality, '🔍')
        
        # Show similarity ratio for fuzzy matches
        if 'fuzzy' in match_quality and match.get('similarity_ratio'):
            similarity_percent = int(match['similarity_ratio'] * 100)
            quality_info = f" ({similarity_percent}% match)"
        else:
            quality_info = ""
        
        # Add parent company information for context
        parent_company = match.get('parent_company', '').strip()
        
        context_info = ""
        if parent_company and parent_company != match['display_name']:
            context_info += f" | Parent: {parent_company}"
        
        display_text = f"{quality_icon} {match['display_name']} ({match['vendor_number']}) - Found via {match['search_type']}: '{match['matched_text']}'{quality_info}{context_info}"
        formatted.append(display_text)
    
    return formatted


def extract_vendor_numbers_from_selection(selected_items: list) -> list:
    """Extract vendor numbers from formatted search results"""
    import re
    vendor_numbers = []
    
    for item in selected_items:
        # Extract vendor number from format: "Name (VENDOR123) - Found via..."
        match = re.search(r'\(([^)]+)\)', item)
        if match:
            vendor_numbers.append(match.group(1))
    
    return vendor_numbers


