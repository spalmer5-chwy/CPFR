            GROUP BY p.product_merch_classification2
        ),
        
        mc2_totals AS (
            SELECT 
                SUM(W1_NON_OPT_UNITS) AS total_w1_non_optimal_demand
            FROM mc2_base
        ),
        
        mc2_contribution AS (
            SELECT 
                mc2.product_merch_classification2 AS field,
                NULL as product_name,
                'MC2' AS cut,
                2 AS priority_cut,
                mc2.W1_NON_OPT_UNITS / NULLIFZERO(mt.total_w1_non_optimal_demand) AS nop_contribution,
                ROW_NUMBER() OVER(ORDER BY mc2.W1_NON_OPT_UNITS / NULLIFZERO(mt.total_w1_non_optimal_demand) DESC) AS rn,
                {','.join([f'mc2.W{i}_NOP, mc2.W{i}_NON_OPT_UNITS, mc2.W{i}_TOTAL_UNITS' for i in range(1, timeframe_weeks + 1)])},
                mc2.NOP_{f"T{timeframe_weeks}W"}
            FROM mc2_base mc2
