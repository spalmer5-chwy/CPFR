def get_dropship_filter(include_dropship=False):
    """Return dropship filter SQL based on include_dropship setting"""
    if include_dropship:
        return ""  # No filter - include all products
    else:
        return "AND mps.product_dropship_flag = false"

def generate_cover_sheet_query(vendor_numbers, start_date, end_date, include_dropship=False):
    """Generate the cover sheet query with independent vendor_skus CTE"""
    
    # Convert vendor numbers list to SQL IN clause
    vendor_list = "', '".join(vendor_numbers)
    
    # Get dropship filter
    dropship_filter = get_dropship_filter(include_dropship)
    
    # Use original date logic: previous two completed weeks from current date
    # For backward compatibility with f-string references, define dates as current week logic
    from datetime import datetime
    current_date = datetime.now().date()
    # Most recent completed week (last week)
    end_date_str = (current_date - timedelta(days=current_date.weekday() + 1)).strftime('%Y-%m-%d')
    # Second most recent completed week (week before last) 
    start_date_str = (current_date - timedelta(days=current_date.weekday() + 8)).strftime('%Y-%m-%d')
    
    query = f"""
    WITH vendor_skus AS (
        SELECT DISTINCT 
            p.product_part_number, 
            p.product_key, 
            p.product_manufacturer_name,
            v.vendor_number,
            v.vendor_name
        FROM EDLDB.CHEWYBI.products p
        JOIN EDLDB.CHEWYBI.vendor_agreement_line vl ON p.product_part_number = vl.product_part_number
        JOIN EDLDB.CHEWYBI.vendors v ON v.vendor_number = vl.vendor_number
        WHERE CURRENT_DATE BETWEEN COALESCE(agreement_line_start_date::DATE, CURRENT_DATE)
                AND COALESCE(agreement_line_end_date::DATE, CURRENT_DATE)
            AND COALESCE(disabled_reason_code,'') = ''
            AND COALESCE(agreement_line_status,'') NOT IN ('CANCELED')
            AND v.vendor_number IN ('{vendor_list}')
    ),
    
    top AS (
        SELECT 
            p.product_manufacturer_name,
            SUM(olm.order_line_quantity) as qty
        FROM EDLDB.CHEWYBI.order_line_measures olm 
        JOIN EDLDB.CHEWYBI.products p USING(product_key)
        JOIN vendor_skus vs ON p.product_part_number = vs.product_part_number
        WHERE 1=1
            AND date_trunc('week', olm.order_line_released_dttm::date) IN (
                date_trunc('week', current_date) - interval '1 week', 
                date_trunc('week', current_date) - interval '2 week'
            )
            AND p.product_company_description = 'Chewy'
            -- AND p.product_merch_classification1 = 'Cat Consumables'  -- Commented out merch class filter
        GROUP BY 1
        ORDER BY 2 DESC 
        LIMIT 25
    ),
    
    oos AS (
        SELECT  
            vs.vendor_name as field1,
            'Vendor Summary' as cut,
            0 as cut_priority,
            date_trunc('week', mps.activity_date) as week,
            COALESCE(SUM(mps.OutofStock_Distinct_PDP_Views) / NULLIFZERO(SUM(mps.Distinct_PDP_Views)), 0) as oos_rate
        FROM mrch.merch_performance_snapshot_pharmacy mps
        LEFT JOIN edldb.sc_sandbox.non_replenishable_items nr ON nr.snapshot_date = mps.activity_date AND mps.product_part_number = nr.product_part_number
        JOIN chewybi.products p ON p.product_part_number = mps.product_part_number
        JOIN vendor_skus vs ON p.product_part_number = vs.product_part_number
        WHERE 1=1
            AND mps.product_merch_classification2 <> 'Pharmacy'
            AND mps.product_merch_classification1 NOT IN ('Virtual Bundle','Gift Cards')
            AND date_trunc('week', mps.activity_date) IN (
                date_trunc('week', current_date) - interval '1 week', 
                date_trunc('week', current_date) - interval '2 week'
            )
            AND vs.vendor_number IN ('{vendor_list}')
            AND nr.product_part_number IS NULL
            {dropship_filter}
            AND mps.product_is_compound = false
            AND mps.product_published_flag = true
            AND mps.product_discontinued_flag = false
        GROUP BY vs.vendor_name,2,3,4
        
        UNION
        
        SELECT  
            p.product_merch_classification1 as field1,
            'MC1' as cut,
            1 as cut_priority,
            date_trunc('week', mps.activity_date) as week,
            COALESCE(SUM(mps.OutofStock_Distinct_PDP_Views) / NULLIFZERO(SUM(mps.Distinct_PDP_Views)), 0) as oos_rate
        FROM mrch.merch_performance_snapshot_pharmacy mps
        LEFT JOIN edldb.sc_sandbox.non_replenishable_items nr ON nr.snapshot_date = mps.activity_date AND mps.product_part_number = nr.product_part_number
        JOIN chewybi.products p ON p.product_part_number = mps.product_part_number
        JOIN vendor_skus vs ON p.product_part_number = vs.product_part_number
        WHERE 1=1
            AND mps.product_merch_classification2 <> 'Pharmacy'
            AND mps.product_merch_classification1 NOT IN ('Virtual Bundle','Gift Cards')
            AND date_trunc('week', mps.activity_date) IN (
                date_trunc('week', current_date) - interval '1 week', 
                date_trunc('week', current_date) - interval '2 week'
            )
            AND nr.product_part_number IS NULL
            {dropship_filter}
            AND mps.product_is_compound = false
            AND mps.product_published_flag = true
            AND mps.product_discontinued_flag = false
        GROUP BY 1,2,3,4
        
        UNION
        
        SELECT  
            p.product_merch_classification2 as field1,
            'MC2' as cut,
            2 as cut_priority,
            date_trunc('week', mps.activity_date) as week,
            COALESCE(SUM(mps.OutofStock_Distinct_PDP_Views) / NULLIFZERO(SUM(mps.Distinct_PDP_Views)), 0) as oos_rate
        FROM mrch.merch_performance_snapshot_pharmacy mps
        LEFT JOIN edldb.sc_sandbox.non_replenishable_items nr ON nr.snapshot_date = mps.activity_date AND mps.product_part_number = nr.product_part_number
        JOIN chewybi.products p ON p.product_part_number = mps.product_part_number
        JOIN vendor_skus vs ON p.product_part_number = vs.product_part_number
        WHERE 1=1
            AND mps.product_merch_classification2 <> 'Pharmacy'
            AND mps.product_merch_classification1 NOT IN ('Virtual Bundle','Gift Cards')
            AND date_trunc('week', mps.activity_date) IN (
                date_trunc('week', current_date) - interval '1 week', 
                date_trunc('week', current_date) - interval '2 week'
            )
            AND nr.product_part_number IS NULL
            {dropship_filter}
            AND mps.product_is_compound = false
            AND mps.product_published_flag = true
            AND mps.product_discontinued_flag = false
        GROUP BY 1,2,3,4
        
        UNION
        
        SELECT  
            p.product_manufacturer_name as field1,
            'Top by Demand' as cut,
            4 as cut_priority,
            date_trunc('week', mps.activity_date) as week,
            COALESCE(SUM(mps.OutofStock_Distinct_PDP_Views) / NULLIFZERO(SUM(mps.Distinct_PDP_Views)), 0) as oos_rate
        FROM mrch.merch_performance_snapshot_pharmacy mps
        LEFT JOIN edldb.sc_sandbox.non_replenishable_items nr ON nr.snapshot_date = mps.activity_date AND mps.product_part_number = nr.product_part_number
        JOIN chewybi.products p ON p.product_part_number = mps.product_part_number
        JOIN vendor_skus vs ON p.product_part_number = vs.product_part_number
        JOIN top ON p.product_manufacturer_name = top.product_manufacturer_name
        WHERE 1=1
            AND mps.product_merch_classification2 <> 'Pharmacy'
            AND mps.product_merch_classification1 NOT IN ('Virtual Bundle','Gift Cards')
            AND date_trunc('week', mps.activity_date) IN (
                date_trunc('week', current_date) - interval '1 week', 
                date_trunc('week', current_date) - interval '2 week'
            )
            AND nr.product_part_number IS NULL
            {dropship_filter}
            AND mps.product_is_compound = false
            AND mps.product_published_flag = true
            AND mps.product_discontinued_flag = false
        GROUP BY 1,2,3,4
        
        UNION
        
        SELECT  
            p.product_manufacturer_name as field1,
            'Top by PDP OOS WoW Contribution' as cut,
            5 as cut_priority,
            date_trunc('week', mps.activity_date) as week,
            COALESCE(SUM(mps.OutofStock_Distinct_PDP_Views) / NULLIFZERO(SUM(mps.Distinct_PDP_Views)), 0) as oos_rate
        FROM mrch.merch_performance_snapshot_pharmacy mps
        LEFT JOIN edldb.sc_sandbox.non_replenishable_items nr ON nr.snapshot_date = mps.activity_date AND mps.product_part_number = nr.product_part_number
        JOIN chewybi.products p ON p.product_part_number = mps.product_part_number
        JOIN vendor_skus vs ON p.product_part_number = vs.product_part_number
        WHERE 1=1
            AND mps.product_merch_classification2 <> 'Pharmacy'
            AND mps.product_merch_classification1 NOT IN ('Virtual Bundle','Gift Cards')
            AND date_trunc('week', mps.activity_date) IN (
                date_trunc('week', current_date) - interval '1 week', 
                date_trunc('week', current_date) - interval '2 week'
            )
            AND nr.product_part_number IS NULL
            {dropship_filter}
            AND mps.product_is_compound = false
            AND mps.product_published_flag = true
            AND mps.product_discontinued_flag = false
        GROUP BY 1,2,3,4
    ),
    
    bo AS (
        SELECT  
            vs.vendor_name as field1,
            'Vendor Summary' as cut,
            0 as cut_priority,
            date_trunc('week', bo.order_placed_date) as week,
            SUM(bo.backorder_units)/SUM(bo.autoship_units) as backorder
        FROM SC_AUTOSHIP_SANDBOX.AS_SC_autoship_backorders bo
        JOIN EDLDB.CHEWYBI.products pp ON pp.product_part_number = bo.product_part_number
        JOIN vendor_skus vs ON pp.product_part_number = vs.product_part_number
        WHERE 1=1
            AND pp.product_merch_classification2 <> 'Pharmacy'
            -- AND pp.product_merch_classification1 NOT IN ('Virtual Bundle','Gift Cards','Programs')  -- Commented out merch class filter
            -- AND pp.product_merch_classification1 = 'Cat Consumables'  -- Commented out merch class filter
            AND pp.product_company_description <> 'Chewy Canada'
            AND vs.vendor_number IN ('{vendor_list}')
            AND date_trunc('week', bo.order_placed_date) BETWEEN '{start_date_str}'::date AND '{end_date_str}'::date
        GROUP BY vs.vendor_name,2,3,4
        
        UNION
        
        SELECT  
            pp.product_merch_classification1 as field1,
            'MC1' as cut,
            1 as cut_priority,
            date_trunc('week', bo.order_placed_date) as week,
            SUM(bo.backorder_units)/SUM(bo.autoship_units) as backorder
        FROM SC_AUTOSHIP_SANDBOX.AS_SC_autoship_backorders bo
        JOIN EDLDB.CHEWYBI.products pp ON pp.product_part_number = bo.product_part_number
        JOIN vendor_skus vs ON pp.product_part_number = vs.product_part_number
        WHERE 1=1
            AND pp.product_merch_classification2 <> 'Pharmacy'
            -- AND pp.product_merch_classification1 NOT IN ('Virtual Bundle','Gift Cards','Programs')  -- Commented out merch class filter
            -- AND pp.product_merch_classification1 = 'Cat Consumables'  -- Commented out merch class filter
            AND pp.product_company_description <> 'Chewy Canada'
            AND date_trunc('week', bo.order_placed_date) BETWEEN '{start_date_str}'::date AND '{end_date_str}'::date
        GROUP BY 1,2,3,4
        
        UNION
        
        SELECT  
            pp.product_merch_classification2 as field1,
            'MC2' as cut,
            2 as cut_priority,
            date_trunc('week', bo.order_placed_date) as week,
            SUM(bo.backorder_units)/SUM(bo.autoship_units) as backorder
        FROM SC_AUTOSHIP_SANDBOX.AS_SC_autoship_backorders bo
        JOIN EDLDB.CHEWYBI.products pp ON pp.product_part_number = bo.product_part_number
        JOIN vendor_skus vs ON pp.product_part_number = vs.product_part_number
        WHERE 1=1
            AND pp.product_merch_classification2 <> 'Pharmacy'
            -- AND pp.product_merch_classification2 NOT IN ('Virtual Bundle','Gift Cards','Programs')  -- Commented out merch class filter
            -- AND pp.product_merch_classification2 = 'Cat Consumables'  -- Commented out merch class filter
            AND pp.product_company_description <> 'Chewy Canada'
            AND date_trunc('week', bo.order_placed_date) BETWEEN '{start_date_str}'::date AND '{end_date_str}'::date
        GROUP BY 1,2,3,4
        

        
        UNION
        
        SELECT  
            pp.product_manufacturer_name as field1,
            'Top by Demand' as cut,
            4 as cut_priority,
            date_trunc('week', bo.order_placed_date) as week,
            SUM(bo.backorder_units)/SUM(bo.autoship_units) as backorder
        FROM SC_AUTOSHIP_SANDBOX.AS_SC_autoship_backorders bo
        JOIN EDLDB.CHEWYBI.products pp ON pp.product_part_number = bo.product_part_number
        JOIN vendor_skus vs ON pp.product_part_number = vs.product_part_number
                JOIN top ON pp.product_manufacturer_name = top.product_manufacturer_name
        WHERE 1=1
            AND pp.product_merch_classification2 <> 'Pharmacy'
            -- AND pp.product_merch_classification1 NOT IN ('Virtual Bundle','Gift Cards','Programs')  -- Commented out merch class filter
            -- AND pp.product_merch_classification1 = 'Cat Consumables'  -- Commented out merch class filter
            AND pp.product_company_description <> 'Chewy Canada'
            AND date_trunc('week', bo.order_placed_date) BETWEEN '{start_date_str}'::date AND '{end_date_str}'::date
        GROUP BY 1,2,3,4
        
        UNION
        
        SELECT  
            pp.product_manufacturer_name as field1,
