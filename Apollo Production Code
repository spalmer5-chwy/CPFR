                b.W1_NON_OPT_UNITS / NULLIFZERO(bt.total_w1_non_optimal_demand) AS nop_contribution,
                ROW_NUMBER() OVER(ORDER BY b.W1_NON_OPT_UNITS / NULLIFZERO(bt.total_w1_non_optimal_demand) DESC) AS rn,
                {','.join([f'b.W{i}_NOP, b.W{i}_NON_OPT_UNITS, b.W{i}_TOTAL_UNITS' for i in range(1, timeframe_weeks + 1)])},
                b.NOP_{f"T{timeframe_weeks}W"}
            FROM brand_base b
            CROSS JOIN brand_totals bt
            ORDER BY nop_contribution DESC
            LIMIT 10
        ),
        
        item_base AS (
            SELECT 
                p.product_part_number as sku,
                p.product_name as product_name,
                {nop_columns_sql}
            FROM op_base
            JOIN EDLDB.chewybi.products p USING(product_part_number)
            WHERE p.product_company_description <> 'Chewy Canada'
                -- AND p.product_merch_classification1 = 'Cat Consumables'  -- Commented out merch class filter
                {dropship_filter}
            GROUP BY p.product_part_number, p.product_name
        ),
        
        item_totals AS (
            SELECT 
                SUM(W1_NON_OPT_UNITS) AS total_w1_non_optimal_demand
            FROM item_base
        ),
        
        item AS (
            SELECT 
                ib.sku AS field,
                ib.product_name,
