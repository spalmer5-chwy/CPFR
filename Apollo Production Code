def execute_cover_sheet_query(session, vendor_numbers, start_date, end_date):
    """Execute the cover sheet query to get vendor performance data"""
    try:
        # Generate and execute query based on region
        region = st.session_state.get('region', 'Chewy US')
        include_dropship = st.session_state.get('include_dropship', False)
        if region == "Chewy Canada":
            query = generate_cover_sheet_query_canada(vendor_numbers, start_date, end_date, include_dropship)
        else:
            query = generate_cover_sheet_query(vendor_numbers, start_date, end_date, include_dropship)
        
        # Execute query
        result = session.sql(query).collect()
        
        # Convert to DataFrame
        df = pd.DataFrame(result)
        
        if not df.empty:
            st.success(f"✅ Cover sheet data loaded: {len(df)} performance metrics")
            return df
        else:
            st.warning("⚠️ No cover sheet data found for the specified vendor(s)")
            return None
            
    except Exception as e:
        st.error(f"❌ Error executing cover sheet query: {e}")
        return None


