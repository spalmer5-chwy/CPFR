def generate_asbo_query(vendor_numbers, start_date, end_date, aggregation, include_dropship=False):
    """Generate ASBO (Autoship Back Order) analysis query with dynamic weekly columns and contribution metrics"""
    
    # Get dynamic date range from session state
    weeks_back = st.session_state.get('weeks_back', 2)  # Default to 2 weeks for backward compatibility
    week_dates = calculate_week_dates(weeks_back)
    
    # Get dropship filter
    dropship_filter = ""
    if not include_dropship:
        dropship_filter = "AND pp.product_dropship_flag = false"
    
    # Generate dynamic weekly columns for ASBO metrics
    def generate_weekly_asbo_columns(weeks_back):
        """Generate dynamic CASE statements for weekly ASBO metrics"""
        week_dates = calculate_week_dates(weeks_back)
        
        bo_columns = []
        bo_units_columns = []
        as_units_columns = []
        
        for i, week_start in enumerate(week_dates, 1):
            # Ensure week_start is a datetime.date object
            if isinstance(week_start, str):
                from datetime import datetime
                week_start = datetime.strptime(week_start, '%m/%d/%Y').date()
            week_start_str = week_start.strftime('%Y-%m-%d')
            
            # BO Rate columns - cap at 100% and handle edge cases with minimum threshold
            bo_columns.append(f"""
                CASE 
                    WHEN SUM(CASE WHEN date_trunc('week', bo.order_placed_date) = date_trunc('week', '{week_start_str}'::date) THEN bo.autoship_units ELSE 0 END) < 10 THEN 0
                    ELSE LEAST(1.0, COALESCE(
                        SUM(CASE WHEN date_trunc('week', bo.order_placed_date) = date_trunc('week', '{week_start_str}'::date) THEN bo.backorder_units ELSE 0 END) / 
                        NULLIFZERO(SUM(CASE WHEN date_trunc('week', bo.order_placed_date) = date_trunc('week', '{week_start_str}'::date) THEN bo.autoship_units ELSE 0 END)), 0))
                END as W{i}_BO""")
            
            # BO Units columns
            bo_units_columns.append(f"""
                COALESCE(SUM(CASE WHEN date_trunc('week', bo.order_placed_date) = date_trunc('week', '{week_start_str}'::date) THEN bo.backorder_units ELSE 0 END), 0) as W{i}_BO_UNITS""")
            
            # AS Units columns
            as_units_columns.append(f"""
                COALESCE(SUM(CASE WHEN date_trunc('week', bo.order_placed_date) = date_trunc('week', '{week_start_str}'::date) THEN bo.autoship_units ELSE 0 END), 0) as W{i}_AS_UNITS""")
        
        # Create combined columns in week-by-week order (like OOS)
        combined_columns = []
        for i in range(weeks_back):
            combined_columns.extend([bo_columns[i], bo_units_columns[i], as_units_columns[i]])
        
        # Add aggregate BO column for the entire timeframe
        trailing_weeks_suffix = f"T{weeks_back}W"
        earliest_week = week_dates[-1] if isinstance(week_dates[-1], str) else week_dates[-1].strftime('%m/%d/%Y')
        latest_week = week_dates[0] if isinstance(week_dates[0], str) else week_dates[0].strftime('%m/%d/%Y')
        
        # Convert to SQL date format
        from datetime import datetime
        earliest_week_sql = datetime.strptime(earliest_week, '%m/%d/%Y').strftime('%Y-%m-%d')
        latest_week_sql = datetime.strptime(latest_week, '%m/%d/%Y').strftime('%Y-%m-%d')
        
        aggregate_bo = f"""
            CASE 
                WHEN SUM(CASE WHEN date_trunc('week', bo.order_placed_date) BETWEEN date_trunc('week', '{earliest_week_sql}'::date) 
                    AND date_trunc('week', '{latest_week_sql}'::date) THEN bo.autoship_units ELSE 0 END) < 10 THEN 0
                ELSE LEAST(1.0, COALESCE(
                    SUM(CASE WHEN date_trunc('week', bo.order_placed_date) BETWEEN date_trunc('week', '{earliest_week_sql}'::date) 
                        AND date_trunc('week', '{latest_week_sql}'::date) THEN bo.backorder_units ELSE 0 END) / 
