        **Fill Rate Impact Categories:**
        - **Total Vendor**: Fill rates and unfilled contribution aggregated for the entire vendor
        - **MC1 (Merch Classification 1)**: Fill rate metrics by primary product category
        - **MC2 (Merch Classification 2)**: Fill rate metrics by secondary product category
        - **Top Fill Rate Issues by Brand**: Brands with highest contribution to unfilled units
        - **Top Fill Rate Issues by SKU**: Individual SKUs with highest unfilled contribution
        
        **Key Metrics:**
        - **Fill Rate**: Percentage of ordered quantity that was received (capped_received_qty / original_order_qty)
        - **Weighted Unfilled Contribution**: Percentage contribution to total unfilled units (% of total miss)
        - **Order Quantity**: Total units ordered for the time period
        - **Received Quantity**: Total units actually received
        - **Unfilled Units**: Total units not received (original_order_qty - capped_received_qty)
        - **Weekly Trending**: Weekly breakdown of all metrics with flexible timeframes
        - **Aggregate Metrics**: Total metrics across the selected time period (T2W, T4W, etc.)
        
        **Analysis Structure:**
        - Hierarchical analysis from Vendor → MC1 → MC2 → Brand → SKU levels
        - Contribution-weighted ranking to identify biggest impact areas
        - Flexible date ranges (2-52 weeks) with dynamic column generation
        - Trend visualization with aggregate reference lines
        
        **Note:** Fill Rate measures procurement efficiency. Lower fill rates indicate supply chain issues or vendor performance problems.
        """)


def create_fillrate_trend_charts(fillrate_data, column_mapping):
    """Create trend charts for Fill Rate data"""
    try:
        import altair as alt
        
        # Get fill rate columns (weekly data)
        fill_rate_cols = [col for col in fillrate_data.columns if col.startswith('W') and col.endswith('_FILL_RATE')]
        
        if not fill_rate_cols:
            st.warning("No weekly Fill Rate data found for charting.")
            return
        
        # Get available cut types
        available_cuts = fillrate_data['CUT'].unique() if 'CUT' in fillrate_data.columns else []
        
        # Filter to include all vendor and brand-level data (exclude individual SKUs)
        # Include Total Vendor, MC1/MC2, and contribution charts
        preferred_cuts = ['Vendor', 'MC1', 'MC2', 'Top Fill Rate Issues by Brand']
        available_preferred_cuts = [cut for cut in preferred_cuts if cut in available_cuts]
        
        if available_preferred_cuts:
            viz_data = fillrate_data[fillrate_data['CUT'].isin(available_preferred_cuts)].copy()
        else:
            # Fallback to any non-SKU cuts
            trend_cuts = [cut for cut in available_cuts if not any(x in cut.lower() for x in ['sku', 'top sku', 'item'])][:4]
            if trend_cuts:
                viz_data = fillrate_data[fillrate_data['CUT'].isin(trend_cuts)].copy()
            else:
                st.info("No aggregated data available for trend visualization.")
                return
        
        if viz_data.empty:
            st.info("No data available for trend visualization.")
            return
        
        # Create trend chart for each available cut type
        available_cut_types = viz_data['CUT'].unique()
        for cut_type in available_cut_types:
            cut_data = viz_data[viz_data['CUT'] == cut_type]
            
            if cut_data.empty:
                continue
                
            st.markdown(f"**{cut_type} Fill Rate Trends**")
            
            # Prepare data for line chart
            chart_data = []
            
            # Look for aggregate columns (e.g., T2W, T4W aggregate fill rates)
            aggregate_fill_cols = [col for col in cut_data.columns if 'FILL_RATE' in col and any(suffix in col for suffix in ['_T2W', '_T4W', '_T13W', '_T26W', '_T52W'])]
            aggregate_fill_col = aggregate_fill_cols[0] if aggregate_fill_cols else None
            
            for _, row in cut_data.iterrows():
                entity_name = row.get('FIELD', row.get('PRODUCT_NAME', 'Unknown'))
                
                # Add aggregate fill rate as reference data if available
                if aggregate_fill_col:
                    aggregate_value = row[aggregate_fill_col]
                    if pd.notna(aggregate_value):
                        chart_data.append({
                            'Date': 'Aggregate',
                            'Entity': entity_name,
                            'Fill Rate': float(aggregate_value),
                            'Type': 'Aggregate'
                        })
                
                # Add weekly data points
                for col in fill_rate_cols:
                    # Get display date from column mapping, or use column name
                    date_label = column_mapping.get(col, col).replace('_FILL_RATE', '').replace('_', '/')
                    
                    value = row[col]
                    if pd.notna(value):  # Include 0 values, just exclude NaN/null
                        chart_data.append({
                            'Date': date_label,
                            'Entity': entity_name,
                            'Fill Rate': float(value) if not pd.isna(value) else 0,
                            'Type': 'Weekly'
                        })
            
            if chart_data:
                chart_df = pd.DataFrame(chart_data)
                
                # Separate weekly and aggregate data for different styling
                weekly_data = chart_df[chart_df['Type'] == 'Weekly']
                aggregate_data = chart_df[chart_df['Type'] == 'Aggregate'] if aggregate_fill_col else pd.DataFrame()
                
                # Convert date strings to datetime for proper sorting
                if not weekly_data.empty:
                    try:
                        weekly_data['Date_Sort'] = pd.to_datetime(weekly_data['Date'], format='%m/%d/%Y', errors='coerce')
                        # Sort dates chronologically and convert back to string for display
                        date_order = weekly_data.sort_values('Date_Sort')['Date'].unique().tolist()
                    except:
                        # Fallback to string sorting if date conversion fails
                        date_order = sorted(list(weekly_data['Date'].unique()))
                    
                    # Create weekly lines
                    weekly_lines = alt.Chart(weekly_data).mark_line(point=True, strokeWidth=2).encode(
                        x=alt.X('Date:N', title='Week Starting', sort=date_order),
                        y=alt.Y('Fill Rate:Q', title='Fill Rate', axis=alt.Axis(format='.1%', tickCount=10), 
                               scale=alt.Scale(zero=False, nice=True)),
                        color=alt.Color('Entity:N', title=cut_type),
                        tooltip=['Date:N', 'Entity:N', alt.Tooltip('Fill Rate:Q', format='.2%')]
                    )
                    
                    # Add aggregate reference line if available
                    if not aggregate_data.empty:
                        aggregate_value = aggregate_data['Fill Rate'].iloc[0]
                        
                        aggregate_rule = alt.Chart(pd.DataFrame({'y': [aggregate_value]})).mark_rule(
                            color='red', 
                            strokeDash=[5, 5], 
                            strokeWidth=2,
                            opacity=0.8
                        ).encode(
                            y=alt.Y('y:Q'),
                            tooltip=alt.value(f'Aggregate: {aggregate_value:.2%}')
                        )
                        
                        # Combine weekly lines with aggregate rule
                        final_chart = weekly_lines + aggregate_rule
                    else:
                        final_chart = weekly_lines
                
                # Set chart properties with proper padding to prevent cutoff
                chart = final_chart.properties(
                    width=600,
                    height=300,
                    title=f'{cut_type} Fill Rate Trends' + (' (Red line = Aggregate)' if not aggregate_data.empty else '')
                ).resolve_scale(
                    color='independent'
                ).configure_axis(
                    labelAngle=0,
                    labelFontSize=10
                ).configure_view(
                    stroke=None
                ).configure(
                    padding={"left": 50, "top": 50, "right": 50, "bottom": 80}
                )
                
                st.altair_chart(chart, use_container_width=True)
            else:
                st.info(f"No data available for {cut_type} trend chart.")
            
            st.markdown("---")
            
    except Exception as e:
        st.error(f"Error creating Fill Rate trend charts: {e}")


