                        })
            
            if chart_data:
                chart_df = pd.DataFrame(chart_data)
                
                # Separate weekly and aggregate data for different styling
                weekly_data = chart_df[chart_df['Type'] == 'Weekly']
                aggregate_data = chart_df[chart_df['Type'] == 'Aggregate'] if 'Type' in chart_df.columns else pd.DataFrame()
                
                # Create line chart with interactive selection
                import altair as alt
                
                # Convert date strings to datetime for proper sorting
                try:
                    weekly_data['Date_Sort'] = pd.to_datetime(weekly_data['Date'], format='%m/%d/%Y', errors='coerce')
                    # Sort dates chronologically and convert back to string for display
                    date_order = weekly_data.sort_values('Date_Sort')['Date'].unique().tolist()
                except:
                    # Fallback to string sorting if date conversion fails
                    date_order = sorted(list(weekly_data['Date'].unique()))
                
                # Create base chart for weekly data only
                base_chart = alt.Chart(weekly_data)
                
                # Weekly trend lines (solid lines with points) - keep cut-level legend
                weekly_lines = base_chart.mark_line(point=True, strokeWidth=2).encode(
                    x=alt.X('Date:N', title='Week Starting', sort=date_order),
                    y=alt.Y('WISP Rate:Q', title='WISP Rate', 
                           axis=alt.Axis(format='.1%', tickCount=10), 
                           scale=alt.Scale(zero=False, nice=True)),
                    color=alt.Color('Entity:N', title=f'{cut_type}'),
                    tooltip=['Date:N', 'Entity:N', alt.Tooltip('WISP Rate:Q', format='.2%')]
                )
                
                # Create horizontal aggregate reference line if available
                final_chart = weekly_lines
                if not aggregate_data.empty:
                    # Get the aggregate value (should be same for all entities in this cut)
                    aggregate_value = aggregate_data['WISP Rate'].iloc[0]
                    
                    # Create horizontal rule for aggregate
                    aggregate_rule = alt.Chart(pd.DataFrame({'y': [aggregate_value]})).mark_rule(
                        color='red', 
                        strokeDash=[5, 5], 
                        strokeWidth=2,
                        opacity=0.8
                    ).encode(
                        y=alt.Y('y:Q'),
                        tooltip=alt.value(f'Aggregate: {aggregate_value:.2%}')
                    )
                    
                    # Combine weekly lines with aggregate rule
                    final_chart = weekly_lines + aggregate_rule
                
                # Set chart properties with proper padding to prevent cutoff
                chart = final_chart.properties(
                    width=600,
                    height=300,
                    title=f'{cut_type} WISP Rate Trends' + (' (Red line = Aggregate)' if not aggregate_data.empty else '')
                ).resolve_scale(
                    color='independent'
                ).configure_axis(
                    labelAngle=0,
                    labelFontSize=10
                ).configure_view(
                    stroke=None
                ).configure(
                    padding={"left": 50, "top": 50, "right": 50, "bottom": 80}
                )
                
                st.altair_chart(chart, use_container_width=True)
            else:
                st.info(f"No data available for {cut_type} trend chart.")
            
            st.markdown("---")
        
        # Add Top 10 Individual Items Trend at the end
        st.markdown("**📈 Top 10 Individual WISP Items Trend**")
        create_top_wisp_items_trend_chart(wisp_data, wisp_cols, column_mapping)
    
    except Exception as e:
        st.error(f"Error creating WISP trend charts: {str(e)}")


def create_top_wisp_items_trend_chart(wisp_data, wisp_cols, column_mapping):
    """Create trend chart for top 10 individual WISP items"""
    import altair as alt
    
    # Filter for SKU-level data
    item_data = wisp_data[wisp_data['CUT'] == 'Top Item WISP Contribution'].copy()
    
    if item_data.empty:
        st.warning("⚠️ No SKU-level data available for trends.")
        return
    
    # Sort by WISP Impact Contribution to get the most problematic SKUs (like other charts)
    if 'WISP_IMPACT_CONTRIBUTION' in item_data.columns:
        item_data = item_data.nlargest(10, 'WISP_IMPACT_CONTRIBUTION')
    else:
        # Fallback to first WISP column if contribution not available
        item_data = item_data.nlargest(10, wisp_cols[0])
    
    # Prepare data for line chart
    chart_data = []
    for _, row in item_data.iterrows():
        entity_name = f"{row['FIELD']} - {str(row['PRODUCT_NAME'])[:30]}..." if len(str(row['PRODUCT_NAME'])) > 30 else f"{row['FIELD']} - {str(row['PRODUCT_NAME'])}"
        
        for col in wisp_cols:
            # Get display date from column mapping, or use column name
            date_label = column_mapping.get(col, col).replace('_WISP', '').replace('_', '/')
            
            value = row[col]
            if pd.notna(value):  # Include 0% values - they're valid WISP rates
                chart_data.append({
                    'Date': date_label,
                    'Entity': entity_name,
                    'WISP Rate': float(value) if not pd.isna(value) else 0
                })
    
    if not chart_data:
        st.warning("⚠️ No SKU trend data available.")
        return
    
    chart_df = pd.DataFrame(chart_data)
    
    # Convert date strings to datetime for proper sorting
    try:
        chart_df['Date_Sort'] = pd.to_datetime(chart_df['Date'], format='%m/%d/%Y', errors='coerce')
        # Sort dates chronologically and convert back to string for display
        date_order = chart_df.sort_values('Date_Sort')['Date'].unique().tolist()
    except:
        # Fallback to string sorting if date conversion fails
        date_order = sorted(list(chart_df['Date'].unique()))
    
    # Create line chart with interactive selection
    click_selection = alt.selection_multi(fields=['Entity'])
    
    # Base chart with click selection
    base_chart = alt.Chart(chart_df).add_selection(click_selection)
    
    # Main lines (all data, always visible)
    lines = base_chart.mark_line(point=True, strokeWidth=2).encode(
        x=alt.X('Date:N', title='Week Starting', sort=date_order),
        y=alt.Y('WISP Rate:Q', title='WISP Rate', 
               axis=alt.Axis(format='.1%', tickCount=10), 
               scale=alt.Scale(zero=False, nice=True)),
        color=alt.Color('Entity:N', title='SKU (Click to Select)'),
        opacity=alt.condition(click_selection, alt.value(1.0), alt.value(0.7)),
        strokeWidth=alt.condition(click_selection, alt.value(4), alt.value(2)),
        tooltip=['Date:N', 'Entity:N', alt.Tooltip('WISP Rate:Q', format='.2%')]
    )
    
    chart = lines.properties(
        width=600,
        height=400,
        title='Top 10 Individual WISP Items Rate Trends (Click legend to highlight)'
    ).configure_axis(
        labelAngle=0,
        labelFontSize=10
    ).configure_view(
        stroke=None
    ).configure(
        padding={"left": 50, "top": 50, "right": 50, "bottom": 80}
    )
    
    st.altair_chart(chart, use_container_width=True)
    
    # Add summary info
    if 'WISP_IMPACT_CONTRIBUTION' in item_data.columns:
        total_contribution = item_data['WISP_IMPACT_CONTRIBUTION'].sum()
        st.info(f"📊 Top {len(item_data)} SKUs account for {total_contribution:.1%} of total WISP Impact contribution")
    else:
        st.info(f"📊 Showing top {len(item_data)} SKUs by WISP performance")


