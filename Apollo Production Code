            aggregate_wisp_col = aggregate_wisp_cols[0] if aggregate_wisp_cols else None
            
            for _, row in cut_data.iterrows():
                entity_name = row.get('FIELD', row.get('PRODUCT_NAME', 'Unknown'))
                
                # Add aggregate WISP as reference data if available
