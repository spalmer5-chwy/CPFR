        ),
        
        item_base AS (
            SELECT  
                pp.product_part_number as sku,
                pp.product_name as product_name,
                {weekly_columns['combined_columns']},
                {weekly_columns['aggregate_bo']}
            FROM EDLDB.SC_REPLENISHMENT_SANDBOX.SCRA__CUR_AUTOSHIP_BACKORDERS_BASE bo
            JOIN EDLDB.chewybi.products pp ON pp.product_part_number = bo.product_part_number
            JOIN vendor_skus vs ON pp.product_part_number = vs.product_part_number
