def get_sku_attributes(sku_vendor_pairs: List[tuple]) -> pd.DataFrame:
    """
    Get SKU attributes (Brand, Parent Company, MC1-3, PC1-3, ABC Code) for the provided SKU-vendor pairs.
    
    Args:
        sku_vendor_pairs: List of (chewy_sku, vendor_number) tuples from CSV
        
    Returns:
        DataFrame with SKU attributes
        
    Raises:
        ValueError: If Snowflake connection fails or data cannot be retrieved
    """
    try:
        session = snowflake_get_active_session()
        
        # Create WHERE conditions for each SKU-vendor pair
        pair_conditions = []
        for sku, vendor in sku_vendor_pairs:
            pair_conditions.append(f"(p.product_part_number = '{sku}' AND v.vendor_number = '{vendor}')")
        
        where_clause = " OR ".join(pair_conditions)
        
        # Query to get SKU attributes using the vendor_agreement_line structure
        sku_attributes_query = f"""
        SELECT DISTINCT
            v.vendor_number,
            v.vendor_name,
            p.product_part_number as chewy_sku,
            vl.vendor_product_part_number as vendor_sku,
            p.product_name,
            p.parent_company,
            p.product_manufacturer_name as brand_name,
            p.product_merch_classification1 as mc1_category,
            p.product_merch_classification2 as mc2_category,
            p.product_merch_classification3 as mc3_category,
            p.product_category_level1 as pc1_category,
            p.product_category_level2 as pc2_category,
            p.product_category_level3 as pc3_category,
            p.product_abc_code as sku_velocity
        FROM EDLDB.CHEWYBI.vendor_agreement_line vl
        LEFT JOIN edldb.chewybi.products p ON p.product_part_number = vl.product_part_number
        LEFT JOIN edldb.chewybi.vendors v ON v.vendor_number = vl.vendor_number
        WHERE ({where_clause})
        AND CURRENT_DATE BETWEEN COALESCE(agreement_line_start_date::DATE, CURRENT_DATE)
            AND COALESCE(agreement_line_end_date::DATE, CURRENT_DATE)
        AND COALESCE(disabled_reason_code,'') = ''
        AND COALESCE(agreement_line_status,'') NOT IN ('CANCELED')
        """
        
        result = session.sql(sku_attributes_query).collect()
        
        if not result:
            raise ValueError(f"No SKU attributes found for the provided SKUs")
        
        # Convert to DataFrame
        sku_df = pd.DataFrame([row.asDict() for row in result])
        
        return sku_df
        
    except Exception as e:
        error_msg = f"Unable to retrieve SKU attributes from Snowflake: {str(e)}"
        raise ValueError(error_msg)

def get_chewy_forecasts_aggregated(sku_list: List[str], period_mapping: Dict[str, Any]) -> pd.DataFrame:
    """
    Get Chewy internal forecasts aggregated to vendor periods (database-level aggregation).
    
    Args:
        sku_list: List of Chewy SKUs to get forecasts for
        period_mapping: Period mapping from map_forecast_periods()
        
    Returns:
        DataFrame with Chewy forecasts aggregated by SKU and vendor period
        
    Raises:
        ValueError: If Snowflake connection fails or data cannot be retrieved
    """
    try:
        session = snowflake_get_active_session()
        
        # Convert SKU list to SQL IN clause (handle both string and numeric SKUs)
        sku_in_clause = "', '".join([str(sku) for sku in sku_list])
        
        # Get periods from period mapping
        periods = period_mapping['periods']
        
        all_forecasts = []
        
        # Generate one aggregated query per vendor period
        for period in periods:
            period_start = period[0].strftime('%Y-%m-%d')
            period_end = period[1].strftime('%Y-%m-%d')
            
            # Query Chewy forecasts with database-level aggregation
            chewy_forecast_query = f"""
            SELECT
                fcst.PRODUCT_PART_NUMBER as chewy_sku,
                '{period_start}' as period_start_date,
                '{period_end}' as period_end_date,
                SUM(fcst.FCST_QTY::FLOAT) as chewy_forecast_units,
                MAX(fcst.SNAPSHOT_DATE) as snapshot_date
            FROM edldb.sc_sandbox.blended_fcst_item_day_network_colt fcst
            WHERE fcst.SNAPSHOT_DATE = (
                      SELECT MAX(SNAPSHOT_DATE)
                      FROM edldb.sc_sandbox.blended_fcst_item_day_network_colt
                  )
              AND fcst.FORECAST_DATE BETWEEN '{period_start}' AND '{period_end}'
              AND fcst.PRODUCT_PART_NUMBER IN ('{sku_in_clause}')
            GROUP BY fcst.PRODUCT_PART_NUMBER
            """
            
            result = session.sql(chewy_forecast_query).collect()
            
            if result:
                period_forecasts = pd.DataFrame([row.asDict() for row in result])
                # Debug: Show what columns Snowflake actually returns
                print(f"DEBUG - Snowflake returned columns: {period_forecasts.columns.tolist()}")
                all_forecasts.append(period_forecasts)
        
        # Combine all periods
        print(f"DEBUG - all_forecasts length: {len(all_forecasts)}")
        if all_forecasts:
            forecast_df = pd.concat(all_forecasts, ignore_index=True)
            print(f"DEBUG - Combined forecast_df columns: {forecast_df.columns.tolist()}")
            print(f"DEBUG - Combined forecast_df shape: {forecast_df.shape}")
            
            # Convert date columns to datetime (handle case sensitivity)
            if 'period_start_date' in forecast_df.columns:
                forecast_df['period_start_date'] = pd.to_datetime(forecast_df['period_start_date'])
                forecast_df['period_end_date'] = pd.to_datetime(forecast_df['period_end_date'])
            elif 'PERIOD_START_DATE' in forecast_df.columns:
                forecast_df['period_start_date'] = pd.to_datetime(forecast_df['PERIOD_START_DATE'])
                forecast_df['period_end_date'] = pd.to_datetime(forecast_df['PERIOD_END_DATE'])
                # Drop the uppercase columns to avoid confusion
                forecast_df = forecast_df.drop(columns=['PERIOD_START_DATE', 'PERIOD_END_DATE'])
            
            # Handle chewy_sku column case sensitivity
            if 'chewy_sku' in forecast_df.columns:
                forecast_df['chewy_sku'] = forecast_df['chewy_sku'].astype(str)
            elif 'CHEWY_SKU' in forecast_df.columns:
                forecast_df['chewy_sku'] = forecast_df['CHEWY_SKU'].astype(str)
                forecast_df = forecast_df.drop(columns=['CHEWY_SKU'])
            
            # Handle chewy_forecast_units column case sensitivity
            if 'CHEWY_FORECAST_UNITS' in forecast_df.columns:
                forecast_df['chewy_forecast_units'] = forecast_df['CHEWY_FORECAST_UNITS']
                forecast_df = forecast_df.drop(columns=['CHEWY_FORECAST_UNITS'])
            
            # Handle snapshot_date column case sensitivity
            if 'SNAPSHOT_DATE' in forecast_df.columns:
                forecast_df['snapshot_date'] = forecast_df['SNAPSHOT_DATE']
                forecast_df = forecast_df.drop(columns=['SNAPSHOT_DATE'])
        else:
            print("DEBUG - No forecast data returned from Snowflake")
            # Return empty DataFrame with correct structure
            forecast_df = pd.DataFrame(columns=['chewy_sku', 'period_start_date', 'period_end_date', 'chewy_forecast_units', 'snapshot_date'])
        
        return forecast_df
        
    except Exception as e:
        error_msg = f"Unable to retrieve Chewy forecasts from Snowflake: {str(e)}"
        raise ValueError(error_msg)

def get_chewy_forecasts_historical(sku_list: List[str], period_mapping: Dict[str, Any], snapshot_date: date) -> pd.DataFrame:
    """
    Get Chewy internal forecasts from a specific historical snapshot date (for Historical Upload mode).
    
    Args:
        sku_list: List of Chewy SKUs to get forecasts for
        period_mapping: Period mapping from map_forecast_periods()
