        closest_snapshot = snapshot_result[0]['CLOSEST_SNAPSHOT']
        print(f"DEBUG - Using Chewy forecast snapshot from: {closest_snapshot}")
        
        # Get periods from period mapping
        periods = period_mapping['periods']
        
        all_forecasts = []
        
        # Generate one aggregated query per vendor period using the historical snapshot
        for period in periods:
            period_start = period[0].strftime('%Y-%m-%d')
            period_end = period[1].strftime('%Y-%m-%d')
            
            # Query Chewy forecasts with database-level aggregation from historical snapshot
