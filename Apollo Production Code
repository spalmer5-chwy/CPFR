                ROW_NUMBER() OVER(ORDER BY ZEROIFNULL(bo_contribution) DESC) as rn
            FROM mc1_contribution
        ),
        
        -- MC2 Analysis
        mc2_base AS (
            SELECT  
                pp.product_merch_classification2,
