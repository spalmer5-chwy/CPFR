def convert_query_to_canada(us_query):
    """Convert a US query to Canada by replacing company filters"""
    
    canada_query = us_query.replace(
        "product_company_description = 'Chewy'", 
        "product_company_description = 'Chewy Canada'"
    ).replace(
        "product_company_description <> 'Chewy Canada'", 
        "product_company_description = 'Chewy Canada'"
    ).replace(
        "product_company_description IN ('Chewy')", 
        "product_company_description IN ('Chewy Canada')"
    # Removed the replacement for inclusive company filters to preserve UNION ALL logic
    # ).replace(
    #     "product_company_description IN ('Chewy', 'Chewy Pharmacy', 'Chewy Canada')", 
    #     "product_company_description IN ('Chewy Canada')"
    # ).replace(
    #     "p.product_company_description IN ('Chewy', 'Chewy Pharmacy', 'Chewy Canada')", 
    #     "p.product_company_description IN ('Chewy Canada')"
    ).replace(
        "w.product_company_description IN ('Chewy')", 
        "w.product_company_description IN ('Chewy Canada')"
    ).replace(
        "p.product_company_description = 'Chewy'", 
        "p.product_company_description = 'Chewy Canada'"
    ).replace(
        "l.product_company_description = 'Chewy'", 
        "l.product_company_description = 'Chewy Canada'"
    ).replace(
        "pp.product_company_description <> 'Chewy Canada'", 
        "pp.product_company_description = 'Chewy Canada'"
    ).replace(
        "pp.product_company_description = 'Chewy'", 
        "pp.product_company_description = 'Chewy Canada'"
    ).replace(
        "mps.product_company_description <> 'Chewy Canada'", 
        "mps.product_company_description = 'Chewy Canada'"
    ).replace(
        "prod.PRODUCT_COMPANY_DESCRIPTION = 'Chewy'", 
        "prod.PRODUCT_COMPANY_DESCRIPTION = 'Chewy Canada'"
    ).replace(
        "          AND p.product_company_description = 'Chewy'", 
        "          AND p.product_company_description = 'Chewy Canada'"
    ).replace(
        "          AND prod.PRODUCT_COMPANY_DESCRIPTION = 'Chewy'", 
        "          AND prod.PRODUCT_COMPANY_DESCRIPTION = 'Chewy Canada'"
    ).replace(
        "met.product_company_description = 'Chewy'", 
        "met.product_company_description = 'Chewy Canada'"
    ).replace(
        "p.product_company_description <> 'Chewy Canada'", 
        "p.product_company_description = 'Chewy Canada'"
    )
    
    return canada_query

