def calculate_week_dates(weeks_back):
    """
    Calculate list of week start dates going back N weeks
    Returns list in reverse chronological order (newest first)
    
    Args:
        weeks_back (int): Number of weeks to go back
        
    Returns:
        list: Week start dates in MM/DD/YYYY format, newest first
        
    Example:
        calculate_week_dates(3) -> ['9/15/2024', '9/8/2024', '9/1/2024']
    """
    current_date = datetime.now().date()
    # Most recent completed week (last Monday)
    # If today is Monday-Sunday, we want the previous Monday (completed week)
    last_monday = current_date - timedelta(days=current_date.weekday() + 7)
    
    week_dates = []
    for i in range(weeks_back):
        week_start = last_monday - timedelta(weeks=i)
        week_dates.append(week_start.strftime('%m/%d/%Y'))
    
    return week_dates

def get_effective_weeks(weeks_back, analysis_type):
    """
    Apply 3-month cap for Fill Rate and On Time analysis
    
    Args:
        weeks_back (int): Requested number of weeks
        analysis_type (str): Type of analysis ('Fill Rate', 'On Time', or other)
        
    Returns:
        int: Effective number of weeks (capped at 13 for Fill Rate/On Time)
    """
    if analysis_type in ['Fill Rate', 'On Time']:
        return min(weeks_back, 13)  # Cap at 3 months (13 weeks)
    return weeks_back

