def get_search_performance_metrics(region: str = "US") -> dict:
    """Get performance metrics for the name search system"""
    try:
        lookup_data = get_cached_vendor_lookup(region)
        
        if not lookup_data:
            return {"status": "not_loaded"}
        
        # Calculate metrics
        unique_vendors = len(set([item.get('VENDOR_NUMBER') for item in lookup_data]))
        total_terms = len(lookup_data)
        
        # Count by search type
        search_types = {}
        for item in lookup_data:
            search_type = item.get('SEARCH_TYPE', 'Unknown')
            search_types[search_type] = search_types.get(search_type, 0) + 1
        
        return {
            "status": "loaded",
            "unique_vendors": unique_vendors,
            "total_searchable_terms": total_terms,
            "search_types": search_types,
            "region": region
        }
    except Exception as e:
        return {"status": "error", "error": str(e)}


