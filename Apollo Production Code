                # Helper function to format percentages (NOP rates should not have +/- signs)
                def format_percentage_simple(value):
                    try:
                        if pd.isna(value) or value is None:
                            return "0.00%"
                        
                        # Handle case where value might already be a percentage string
                        if isinstance(value, str) and value.endswith('%'):
                            return value  # Already formatted, return as-is
                        
                        # Convert to float and format as percentage
                        float_val = float(value)
                        
                        # Check if value seems to already be in percentage form (>1)
                        # If so, divide by 100 first to avoid double conversion
                        if float_val > 1:
                            float_val = float_val / 100
                        
                        formatted = f"{float_val:.2%}"
                        return formatted
                    except (ValueError, TypeError):
                        return "0.00%"
                
                display_data[col] = display_data[col].apply(format_percentage_simple)
        
        # Format unit count columns  
