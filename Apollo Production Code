    if 'WISP_IMPACT_CONTRIBUTION' in item_data.columns:
        item_data = item_data.nlargest(10, 'WISP_IMPACT_CONTRIBUTION')
    else:
        # Fallback to first WISP column if contribution not available
        item_data = item_data.nlargest(10, wisp_cols[0])
    
