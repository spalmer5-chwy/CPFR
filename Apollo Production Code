def generate_oos_query(vendor_numbers, start_date, end_date, aggregation, include_dropship=False):
    """Generate Out of Stock (OOS) analysis query with weekly data based on timeframe selection"""
    
    # Get weeks_back from session state (set by timeframe selector)
    weeks_back = st.session_state.get('weeks_back', 2)  # Default to 2 weeks for backward compatibility
    
    # Calculate week dates using helper function
    week_dates = calculate_week_dates(weeks_back)
    
    # Convert week dates to SQL date format for filtering  
    week_dates_sql = [datetime.strptime(date, '%m/%d/%Y').strftime('%Y-%m-%d') for date in week_dates]
    
    # Create date range for WHERE clause (from oldest to newest week)
    start_date_str = week_dates_sql[-1]  # Oldest week (last in reverse chronological list)
    end_date_str = week_dates_sql[0]     # Newest week (first in reverse chronological list)
    
    # Generate dynamic weekly columns for OOS metrics
    def generate_weekly_oos_columns(week_dates, week_dates_sql):
        """Generate dynamic CASE statements for weekly OOS metrics using generic column names"""
        pdp_oos_columns = []
        oos_views_columns = []
        total_views_columns = []
        
        for i, (display_date, sql_date) in enumerate(zip(week_dates, week_dates_sql)):
            week_num = i + 1  # Use simple W1, W2, W3, etc.
            
            # PDP OOS Rate columns
            pdp_oos_columns.append(f"""
                COALESCE(CAST(SUM(CASE WHEN date_trunc('week', mps.activity_date) = date_trunc('week', '{sql_date}'::date) 
                    THEN mps.OutofStock_Distinct_PDP_Views ELSE 0 END) AS DECIMAL(18,10)) / 
                    NULLIFZERO(CAST(SUM(CASE WHEN date_trunc('week', mps.activity_date) = date_trunc('week', '{sql_date}'::date) 
                    THEN mps.Distinct_PDP_Views ELSE 0 END) AS DECIMAL(18,10))), 0) as W{week_num}_PDP_OOS""")
            
            # OOS Views columns  
            oos_views_columns.append(f"""
                COALESCE(SUM(CASE WHEN date_trunc('week', mps.activity_date) = date_trunc('week', '{sql_date}'::date) 
                    THEN mps.OutofStock_Distinct_PDP_Views ELSE 0 END), 0) as W{week_num}_OOS_VIEWS""")
            
            # Total Views columns
            total_views_columns.append(f"""
                COALESCE(SUM(CASE WHEN date_trunc('week', mps.activity_date) = date_trunc('week', '{sql_date}'::date) 
                    THEN mps.Distinct_PDP_Views ELSE 0 END), 0) as W{week_num}_VIEWS""")
        
        # Add aggregate PDP OOS column for the entire timeframe
        trailing_weeks_suffix = f"T{weeks_back}W"
        aggregate_pdp_oos = f"""
            COALESCE(CAST(SUM(CASE WHEN date_trunc('week', mps.activity_date) BETWEEN date_trunc('week', '{week_dates_sql[-1]}'::date) 
                AND date_trunc('week', '{week_dates_sql[0]}'::date) 
                THEN mps.OutofStock_Distinct_PDP_Views ELSE 0 END) AS DECIMAL(18,10)) / 
                NULLIFZERO(CAST(SUM(CASE WHEN date_trunc('week', mps.activity_date) BETWEEN date_trunc('week', '{week_dates_sql[-1]}'::date) 
                AND date_trunc('week', '{week_dates_sql[0]}'::date) 
                THEN mps.Distinct_PDP_Views ELSE 0 END) AS DECIMAL(18,10))), 0) as PDP_OOS_{trailing_weeks_suffix}"""
        
        return ','.join(pdp_oos_columns), ','.join(oos_views_columns), ','.join(total_views_columns), aggregate_pdp_oos
    
    # Generate dynamic column SQL
    pdp_oos_columns, oos_views_columns, total_views_columns, aggregate_pdp_oos = generate_weekly_oos_columns(week_dates, week_dates_sql)
    
    # Generate generic column names list for reference in other CTEs
    week_column_names = []
    for i in range(len(week_dates)):
        week_num = i + 1
        week_column_names.extend([
            f"W{week_num}_PDP_OOS",
            f"W{week_num}_OOS_VIEWS", 
            f"W{week_num}_VIEWS"
        ])
    
    # Add aggregate column to the column names list
    trailing_weeks_suffix = f"T{weeks_back}W"
    week_column_names.append(f"PDP_OOS_{trailing_weeks_suffix}")
    
    # Create comma-separated column references for SELECT statements
    weekly_column_refs = ', '.join(week_column_names)
    
    # Create column references without the aggregate for final SELECT ordering
    weekly_column_refs_without_aggregate = ', '.join(week_column_names[:-1])  # Exclude the last item (aggregate column)
    
    # Create mapping for display/export (generic -> date-based names)
    def create_column_mapping(week_dates):
        """Create mapping from generic column names to date-based display names"""
        mapping = {}
        for i, display_date in enumerate(week_dates):
            week_num = i + 1
            date_prefix = display_date.replace('/', '_')  # 9/15/2024 -> 9_15_2024
            mapping[f"W{week_num}_PDP_OOS"] = f"{date_prefix}_PDP_OOS"
            mapping[f"W{week_num}_OOS_VIEWS"] = f"{date_prefix}_OOS_VIEWS"
            mapping[f"W{week_num}_VIEWS"] = f"{date_prefix}_VIEWS"
        
        # Add aggregate column mapping
        trailing_weeks_suffix = f"T{weeks_back}W"
        mapping[f"PDP_OOS_{trailing_weeks_suffix}"] = f"PDP OOS {trailing_weeks_suffix}"
        
        return mapping
    
    # Store column mapping for later use in display/export functions
    column_mapping = create_column_mapping(week_dates)
    
    # Get dropship filter
    dropship_filter = get_dropship_filter(include_dropship)
    
    # Get vendor list for filtering (removed circular SKU dependency)
    vendor_list = "', '".join(vendor_numbers)
    
    query = f"""
        WITH vendor_skus AS (
            SELECT DISTINCT
                v.vendor_number as vendor_number,
                v.vendor_name as vendor_name,
                p.product_part_number as product_part_number,
