    """
    
    return query, column_mapping


def generate_wisp_query(vendor_numbers, start_date, end_date, aggregation, include_dropship=False):
    """Generate WISP (Weighted In Stock Percentage) analysis query with dynamic timeframes using WISP_total table"""
    
    # Use the dynamic timeframe selector (weeks_back from session state)
    import streamlit as st
    timeframe_weeks = st.session_state.get('weeks_back', 2)  # Default to 2 weeks for backward compatibility
    
    # Calculate week dates for dynamic columns
    week_dates = calculate_week_dates(timeframe_weeks)
    
    # Convert week_dates to SQL date format
    week_dates_sql = []
    for week_date_str in week_dates:
        week_date_sql = datetime.strptime(week_date_str, '%m/%d/%Y').strftime('%Y-%m-%d')
        week_dates_sql.append(week_date_sql)
    
    # Calculate actual date range from the dynamic week dates
    start_date_actual = week_dates_sql[-1]  # Oldest week (last in reverse chronological list)
    end_date_actual = week_dates_sql[0]     # Newest week (first in reverse chronological list)
    
    # Generate dynamic weekly columns for WISP metrics
    def generate_weekly_wisp_columns(week_dates, week_dates_sql):
        """Generate dynamic CASE statements for weekly WISP metrics using WISP_total table"""
        wisp_rate_columns = []
        wisp_units_columns = []
        perfect_sales_columns = []
        lost_sales_columns = []
        
        for i, (display_date, sql_date) in enumerate(zip(week_dates, week_dates_sql)):
            week_num = i + 1  # Use simple W1, W2, W3, etc.
            
            # WISP Rate columns (TOTAL_UNITS / TOTAL_PERFECT_SALES) - exclude non-numeric via WHERE filters
            wisp_rate_columns.append(f"""
                COALESCE(SUM(CASE WHEN wt.WEEK_START = '{sql_date}'::date 
                    THEN wt.TOTAL_UNITS ELSE 0 END) / 
                    NULLIFZERO(SUM(CASE WHEN wt.WEEK_START = '{sql_date}'::date 
                    THEN wt.TOTAL_PERFECT_SALES ELSE 0 END)), 0) as W{week_num}_WISP""")
            
            # Total Units columns
            wisp_units_columns.append(f"""
                COALESCE(SUM(CASE WHEN wt.WEEK_START = '{sql_date}'::date 
                    THEN wt.TOTAL_UNITS ELSE 0 END), 0) as W{week_num}_TOTAL_UNITS""")
            
            # Perfect Sales columns
            perfect_sales_columns.append(f"""
                COALESCE(SUM(CASE WHEN wt.WEEK_START = '{sql_date}'::date 
                    THEN wt.TOTAL_PERFECT_SALES ELSE 0 END), 0) as W{week_num}_PERFECT_SALES""")
            
            # Lost Sales columns - calculate lost sales dollars (lost units * price)
            lost_sales_columns.append(f"""
                COALESCE(SUM(CASE WHEN wt.WEEK_START = '{sql_date}'::date 
                    THEN (wt.TOTAL_UNITS - wt.TOTAL_PERFECT_SALES) * sp.current_price
                    ELSE 0 END), 0) as W{week_num}_LOST_SALES""")
        
        # Create total lost sales column (sum of all weekly lost sales - more negative = bigger impact)
        total_lost_sales_column = f"""
            COALESCE(SUM((wt.TOTAL_UNITS - wt.TOTAL_PERFECT_SALES) * sp.current_price), 0) as TOTAL_LOST_SALES"""
        
        # Add aggregate WISP column for the entire timeframe
        weeks_back = len(week_dates)
        trailing_weeks_suffix = f"T{weeks_back}W"
        
        # Use the earliest and latest week dates for aggregate calculation
        earliest_week_sql = week_dates_sql[-1]  # Last in reverse chronological list
        latest_week_sql = week_dates_sql[0]     # First in reverse chronological list
        
        aggregate_wisp_column = f"""
            COALESCE(SUM(CASE WHEN wt.WEEK_START BETWEEN '{earliest_week_sql}'::date 
                AND '{latest_week_sql}'::date 
                THEN wt.TOTAL_UNITS ELSE 0 END) / 
                NULLIFZERO(SUM(CASE WHEN wt.WEEK_START BETWEEN '{earliest_week_sql}'::date 
                AND '{latest_week_sql}'::date 
                THEN wt.TOTAL_PERFECT_SALES ELSE 0 END)), 0) as WISP_{trailing_weeks_suffix}"""
        
        # Create combined columns in week-by-week order (like ASBO)
        combined_columns = []
        for i in range(len(wisp_rate_columns)):
            combined_columns.extend([wisp_rate_columns[i], wisp_units_columns[i], perfect_sales_columns[i], lost_sales_columns[i]])
        
        return {
            'wisp_rate_columns': ','.join(wisp_rate_columns),
            'wisp_units_columns': ','.join(wisp_units_columns), 
            'perfect_sales_columns': ','.join(perfect_sales_columns),
            'lost_sales_columns': ','.join(lost_sales_columns),
            'total_lost_sales_column': total_lost_sales_column,
            'aggregate_wisp_column': aggregate_wisp_column,
            # Combined WITHOUT aggregate - week-by-week interleaved (like ASBO)
            'combined_columns': ','.join([total_lost_sales_column] + combined_columns),
            # Combined WITH aggregate at end (for vendor_summary that uses full combined)
            'combined_columns_with_aggregate': ','.join([total_lost_sales_column] + combined_columns + [aggregate_wisp_column])
        }
    
    # Generate weekly columns
    weekly_columns = generate_weekly_wisp_columns(week_dates, week_dates_sql)
    
    # Create column mapping for display/export (generic -> date-based names)
    column_mapping = {}
    
    # Add static column mappings
    column_mapping['WISP_IMPACT_CONTRIBUTION'] = 'WISP Impact Contribution'
    column_mapping['TOTAL_LOST_SALES'] = 'Total Lost Sales'
    
    # Add aggregate column mapping
    trailing_weeks_suffix = f"T{timeframe_weeks}W"
    column_mapping[f"WISP_{trailing_weeks_suffix}"] = f"WISP {trailing_weeks_suffix}"
    
    # Add weekly column mappings
    for i, week_start in enumerate(week_dates, 1):
        # Convert to date format for display
        if isinstance(week_start, str):
            week_start = datetime.strptime(week_start, '%m/%d/%Y').date()
        date_str = week_start.strftime('%m_%d_%Y')
        column_mapping[f'W{i}_WISP'] = f'{date_str}_WISP'
        column_mapping[f'W{i}_TOTAL_UNITS'] = f'{date_str}_TOTAL_UNITS'
        column_mapping[f'W{i}_PERFECT_SALES'] = f'{date_str}_PERFECT_SALES'
        column_mapping[f'W{i}_LOST_SALES'] = f'{date_str}_LOST_SALES'
    
    # Generate generic column names list for reference in other CTEs
    week_column_names = []
    for i in range(1, timeframe_weeks + 1):
        week_column_names.extend([f'W{i}_WISP', f'W{i}_TOTAL_UNITS', f'W{i}_PERFECT_SALES', f'W{i}_LOST_SALES'])
    
    # Get vendor list for filtering
    vendor_list = "', '".join(vendor_numbers)
    
    dropship_filter = ""
    if not include_dropship:
        dropship_filter = "AND wt.BRAND NOT LIKE '%DROPSHIP%'"  # Adjust filter for WISP_total table
    
    query = f"""
        WITH vendor_skus AS (
            SELECT DISTINCT
                v.vendor_number as vendor_number,
                v.vendor_name as vendor_name,
                p.product_part_number as product_part_number,
                p.product_manufacturer_name
            FROM EDLDB.CHEWYBI.vendor_agreement_line vl
            LEFT JOIN edldb.chewybi.products p ON p.product_part_number = vl.product_part_number
            LEFT JOIN edldb.chewybi.vendors v ON v.vendor_number = vl.vendor_number
            WHERE CURRENT_DATE BETWEEN COALESCE(agreement_line_start_date::DATE, CURRENT_DATE)
                AND COALESCE(agreement_line_end_date::DATE, CURRENT_DATE)
                AND COALESCE(disabled_reason_code,'') = ''
                AND COALESCE(agreement_line_status,'') NOT IN ('CANCELED')
                AND v.vendor_number IN ('{vendor_list}')
        ),
        
        sku_pricing AS (
            SELECT 
                vs.product_part_number,
                pls.product_price_current as current_price
            FROM vendor_skus vs
            JOIN (
                SELECT 
                    vs.product_part_number,
                    pls.product_price_current,
                    ROW_NUMBER() OVER (PARTITION BY pls.product_part_number ORDER BY pls.snapshot_date DESC) as rn
                FROM vendor_skus vs 
                JOIN EDLDB.CHEWYBI.product_lifecycle_snapshot pls ON pls.product_part_number = vs.product_part_number
                JOIN EDLDB.SC_REPLENISHMENT_SANDBOX.WISP_TOTAL wt 
                    ON vs.product_part_number = wt.PRODUCT_PART_NUMBER 
                    AND pls.snapshot_date = wt.THE_DATE
                WHERE wt.WEEK_START >= '{start_date_actual}'::date
                    AND wt.WEEK_START <= '{end_date_actual}'::date
            ) pls ON vs.product_part_number = pls.product_part_number AND pls.rn = 1
        ),
        
        total_lost_units AS (
            SELECT 
                SUM(wt.TOTAL_PERFECT_SALES - wt.TOTAL_UNITS) as total_lost_units_amount
            FROM vendor_skus vs
            JOIN sku_pricing sp ON sp.product_part_number = vs.product_part_number
            JOIN EDLDB.SC_REPLENISHMENT_SANDBOX.WISP_TOTAL wt ON vs.product_part_number = wt.PRODUCT_PART_NUMBER
            WHERE 1=1
                AND wt.MC2 <> 'Pharmacy'
                AND wt.WEEK_START >= '{start_date_actual}'::date
                AND wt.WEEK_START <= '{end_date_actual}'::date
                {dropship_filter}
        ),
        
        vendor_summary AS (
            SELECT 
                vs.vendor_name AS field,
                NULL as product_name,
                'Total Vendor' AS cut,
                0 AS priority_cut,
                -- WISP Impact Contribution: (Vendor's total lost units) / (Total lost units across all vendors)
                SUM(wt.TOTAL_PERFECT_SALES - wt.TOTAL_UNITS) / 
                NULLIFZERO(tlu.total_lost_units_amount) as wisp_impact_contribution,
                {weekly_columns['aggregate_wisp_column']},
                {weekly_columns['combined_columns']}
            FROM vendor_skus vs
            JOIN sku_pricing sp ON sp.product_part_number = vs.product_part_number
            JOIN EDLDB.SC_REPLENISHMENT_SANDBOX.WISP_TOTAL wt ON vs.product_part_number = wt.PRODUCT_PART_NUMBER
            CROSS JOIN total_lost_units tlu
            WHERE 1=1
                AND wt.MC2 <> 'Pharmacy'
                AND wt.WEEK_START >= '{start_date_actual}'::date
                AND wt.WEEK_START <= '{end_date_actual}'::date
                {dropship_filter}
            GROUP BY vs.vendor_name, tlu.total_lost_units_amount
        ),
        
        mc1_summary AS (
            SELECT 
                wt.MC1 AS field,
                NULL as product_name,
                'MC1' AS cut,
                1 AS priority_cut,
                -- WISP Impact Contribution: (MC1's total lost units) / (Total lost units across all vendors)
                SUM(wt.TOTAL_PERFECT_SALES - wt.TOTAL_UNITS) / 
                NULLIFZERO(tlu.total_lost_units_amount) as wisp_impact_contribution,
                {weekly_columns['aggregate_wisp_column']},
                {weekly_columns['combined_columns']}
            FROM vendor_skus vs
            JOIN sku_pricing sp ON sp.product_part_number = vs.product_part_number
            JOIN EDLDB.SC_REPLENISHMENT_SANDBOX.WISP_TOTAL wt ON vs.product_part_number = wt.PRODUCT_PART_NUMBER
            CROSS JOIN total_lost_units tlu
            WHERE 1=1
                AND wt.MC2 <> 'Pharmacy'
                AND wt.WEEK_START >= '{start_date_actual}'::date
                AND wt.WEEK_START <= '{end_date_actual}'::date
                {dropship_filter}
            GROUP BY wt.MC1, tlu.total_lost_units_amount
        ),
        
        mc2_summary AS (
            SELECT 
                wt.MC2 AS field,
                NULL as product_name,
                'MC2' AS cut,
                2 AS priority_cut,
                -- WISP Impact Contribution: (MC2's total lost units) / (Total lost units across all vendors)
                SUM(wt.TOTAL_PERFECT_SALES - wt.TOTAL_UNITS) / 
                NULLIFZERO(tlu.total_lost_units_amount) as wisp_impact_contribution,
                {weekly_columns['aggregate_wisp_column']},
                {weekly_columns['combined_columns']}
            FROM vendor_skus vs
            JOIN sku_pricing sp ON sp.product_part_number = vs.product_part_number
            JOIN EDLDB.SC_REPLENISHMENT_SANDBOX.WISP_TOTAL wt ON vs.product_part_number = wt.PRODUCT_PART_NUMBER
            CROSS JOIN total_lost_units tlu
            WHERE 1=1
                AND wt.MC2 <> 'Pharmacy'
                AND wt.WEEK_START >= '{start_date_actual}'::date
                AND wt.WEEK_START <= '{end_date_actual}'::date
                {dropship_filter}
            GROUP BY wt.MC2, tlu.total_lost_units_amount
        ),
        
        brand_summary AS (
            SELECT 
                wt.BRAND AS field,
                NULL as product_name,
                'Top WISP Contribution' AS cut,
                3 AS priority_cut,
                -- WISP Impact Contribution: (Brand's total lost units) / (Total lost units across all vendors)
                SUM(wt.TOTAL_PERFECT_SALES - wt.TOTAL_UNITS) / 
                NULLIFZERO(tlu.total_lost_units_amount) as wisp_impact_contribution,
                {weekly_columns['aggregate_wisp_column']},
                {weekly_columns['combined_columns']}
            FROM vendor_skus vs
            JOIN sku_pricing sp ON sp.product_part_number = vs.product_part_number
            JOIN EDLDB.SC_REPLENISHMENT_SANDBOX.WISP_TOTAL wt ON vs.product_part_number = wt.PRODUCT_PART_NUMBER
            CROSS JOIN total_lost_units tlu
            WHERE 1=1
                AND wt.MC2 <> 'Pharmacy'
                AND wt.WEEK_START >= '{start_date_actual}'::date
                AND wt.WEEK_START <= '{end_date_actual}'::date
                {dropship_filter}
            GROUP BY wt.BRAND, tlu.total_lost_units_amount
            ORDER BY SUM(wt.TOTAL_PERFECT_SALES - wt.TOTAL_UNITS) DESC
            LIMIT 10
        ),
        
        item_summary AS (
            SELECT 
                vs.product_part_number AS field,
                p.product_name as product_name,
                'Top Item WISP Contribution' AS cut,
                4 AS priority_cut,
                -- WISP Impact Contribution: (SKU's total lost units) / (Total lost units across all vendors)
                SUM(wt.TOTAL_PERFECT_SALES - wt.TOTAL_UNITS) / 
                NULLIFZERO(tlu.total_lost_units_amount) as wisp_impact_contribution,
                {weekly_columns['aggregate_wisp_column']},
                {weekly_columns['combined_columns']}
            FROM vendor_skus vs
            JOIN sku_pricing sp ON sp.product_part_number = vs.product_part_number
            JOIN EDLDB.SC_REPLENISHMENT_SANDBOX.WISP_TOTAL wt ON vs.product_part_number = wt.PRODUCT_PART_NUMBER
            JOIN EDLDB.chewybi.products p ON p.product_part_number = vs.product_part_number
            CROSS JOIN total_lost_units tlu
            WHERE 1=1
                AND wt.MC2 <> 'Pharmacy'
                AND wt.WEEK_START >= '{start_date_actual}'::date
                AND wt.WEEK_START <= '{end_date_actual}'::date
                {dropship_filter}
            GROUP BY vs.product_part_number, p.product_name, tlu.total_lost_units_amount
            HAVING SUM(wt.TOTAL_PERFECT_SALES - wt.TOTAL_UNITS) / NULLIFZERO(tlu.total_lost_units_amount) > 0
            ORDER BY SUM(wt.TOTAL_UNITS) DESC  -- Order by demand (total units) like NOP does
        )
        
        SELECT * FROM vendor_summary
        UNION ALL
        SELECT * FROM mc1_summary
        UNION ALL
        SELECT * FROM mc2_summary
        UNION ALL
        SELECT * FROM brand_summary
        UNION ALL
        SELECT * FROM item_summary
        ORDER BY priority_cut, COALESCE(wisp_impact_contribution, 0) DESC
    """
    
    return query, column_mapping


def generate_weekly_fillrate_columns(start_date, end_date, weeks_back):
    """Generate weekly fill rate column SQL and column mapping with proper ordering and naming"""
    
    # Calculate actual week dates between start and end date
    week_dates = []
    current_date = end_date
    
    # Generate weeks going backwards from end_date (newest to oldest)
    for i in range(weeks_back):
        # Get Monday of the current week
        week_start = current_date - timedelta(days=current_date.weekday())
        if week_start >= start_date:
            week_dates.append(week_start)
        current_date = week_start - timedelta(days=7)
    
    # Keep in reverse chronological order (newest to oldest: W1 = most recent week)
    # week_dates is already in the correct order
    
    # Generate SQL parts for each level
    vendor_columns = []
    mc1_columns = []
    mc2_columns = []
    brand_columns = []
    sku_columns = []
    
    column_mapping = {}
    column_refs = []
    
    for i, week_start in enumerate(week_dates, 1):
        week_start_str = week_start.strftime('%Y-%m-%d')
        week_display = week_start.strftime('%m/%d')
        
        # Weekly columns in the new order: Fill Rate, Order Qty, Received Qty, Accepted Units, Unfilled Units
        fill_rate_sql = f"""
            CASE 
                WHEN SUM(CASE WHEN week_date = '{week_start_str}'::date THEN original_order_qty ELSE 0 END) > 0
                THEN SUM(CASE WHEN week_date = '{week_start_str}'::date THEN capped_received_qty ELSE 0 END) / 
                     SUM(CASE WHEN week_date = '{week_start_str}'::date THEN original_order_qty ELSE 0 END)
                ELSE NULL  -- No orders = no fill rate data (not 100%)
            END as W{i}_FILL_RATE"""
        
        order_qty_sql = f"""
            SUM(CASE WHEN week_date = '{week_start_str}'::date THEN original_order_qty ELSE 0 END) as W{i}_ORDER_QTY"""
        
        received_qty_sql = f"""
            SUM(CASE WHEN week_date = '{week_start_str}'::date THEN capped_received_qty ELSE 0 END) as W{i}_RECEIVED_QTY"""
        
        accepted_units_sql = f"""
            SUM(CASE WHEN week_date = '{week_start_str}'::date THEN units_accepted ELSE 0 END) as W{i}_ACCEPTED_UNITS"""
        
        unfilled_units_sql = f"""
            SUM(CASE WHEN week_date = '{week_start_str}'::date THEN unfilled_units ELSE 0 END) as W{i}_UNFILLED_UNITS"""
        
        # Add to each level in the new order
        week_columns = [fill_rate_sql, order_qty_sql, received_qty_sql, accepted_units_sql, unfilled_units_sql]
        vendor_columns.extend(week_columns)
        mc1_columns.extend(week_columns)
        mc2_columns.extend(week_columns)
        brand_columns.extend(week_columns)
        sku_columns.extend(week_columns)
        
        # Column mapping for display (W1 = most recent week)
        column_mapping[f'W{i}_FILL_RATE'] = f'{week_display}_FILL_RATE'
        column_mapping[f'W{i}_ORDER_QTY'] = f'{week_display}_ORDER_QTY'
        column_mapping[f'W{i}_RECEIVED_QTY'] = f'{week_display}_RECEIVED_QTY'
        column_mapping[f'W{i}_ACCEPTED_UNITS'] = f'{week_display}_ACCEPTED_UNITS'
        column_mapping[f'W{i}_UNFILLED_UNITS'] = f'{week_display}_UNFILLED_UNITS'
        
        # Column references for final SELECT (in new order)
        column_refs.extend([f'W{i}_FILL_RATE', f'W{i}_ORDER_QTY', f'W{i}_RECEIVED_QTY', f'W{i}_ACCEPTED_UNITS', f'W{i}_UNFILLED_UNITS'])
    
    # Add aggregate columns (trailing weeks totals) - NEW NAMING AND ADDITIONAL METRICS
    trailing_weeks_suffix = f"T{weeks_back}W"
    
    # Aggregate fill rate for entire timeframe (renamed from overall_fill_rate)
    aggregate_fill_rate = f"""
        CASE 
            WHEN SUM(original_order_qty) > 0 
            THEN SUM(capped_received_qty) / SUM(original_order_qty)
            ELSE NULL  -- No orders = no fill rate data (not 100%)
        END as FILL_RATE_{trailing_weeks_suffix}"""
    
    # NEW: Aggregate order quantity for entire timeframe
    aggregate_order_qty = f"""
        SUM(original_order_qty) as ORDER_QTY_{trailing_weeks_suffix}"""
    
    # NEW: Aggregate received quantity for entire timeframe
    aggregate_received_qty = f"""
        SUM(capped_received_qty) as RECEIVED_QTY_{trailing_weeks_suffix}"""
    
    # NEW: Aggregate accepted units for entire timeframe
    aggregate_accepted_units = f"""
        SUM(units_accepted) as ACCEPTED_UNITS_{trailing_weeks_suffix}"""
    
    # Aggregate unfilled units for entire timeframe
    aggregate_unfilled = f"""
        SUM(unfilled_units) as UNFILLED_UNITS_{trailing_weeks_suffix}"""
    
    # Add aggregates to all levels in logical order
    aggregate_columns = [aggregate_fill_rate, aggregate_order_qty, aggregate_received_qty, aggregate_accepted_units, aggregate_unfilled]
    vendor_columns.extend(aggregate_columns)
    mc1_columns.extend(aggregate_columns)
    mc2_columns.extend(aggregate_columns)
    brand_columns.extend(aggregate_columns)
    sku_columns.extend(aggregate_columns)
    
    # Add aggregate column mappings
    column_mapping[f'FILL_RATE_{trailing_weeks_suffix}'] = f'Fill Rate {trailing_weeks_suffix}'
    column_mapping[f'ORDER_QTY_{trailing_weeks_suffix}'] = f'Order Qty {trailing_weeks_suffix}'
    column_mapping[f'RECEIVED_QTY_{trailing_weeks_suffix}'] = f'Received Qty {trailing_weeks_suffix}'
    column_mapping[f'ACCEPTED_UNITS_{trailing_weeks_suffix}'] = f'Accepted Units {trailing_weeks_suffix}'
    column_mapping[f'UNFILLED_UNITS_{trailing_weeks_suffix}'] = f'Unfilled Units {trailing_weeks_suffix}'
    column_refs.extend([f'FILL_RATE_{trailing_weeks_suffix}', f'ORDER_QTY_{trailing_weeks_suffix}', f'RECEIVED_QTY_{trailing_weeks_suffix}', f'ACCEPTED_UNITS_{trailing_weeks_suffix}', f'UNFILLED_UNITS_{trailing_weeks_suffix}'])
    
    # Create column reference strings with proper ordering
    # Aggregate columns first (after weighted_unfilled_contribution)
    aggregate_column_refs = f'FILL_RATE_{trailing_weeks_suffix}, ORDER_QTY_{trailing_weeks_suffix}, RECEIVED_QTY_{trailing_weeks_suffix}, ACCEPTED_UNITS_{trailing_weeks_suffix}, UNFILLED_UNITS_{trailing_weeks_suffix}'
    
    # Weekly columns in proper order (W1 Fill Rate, W1 Order, W1 Received, W1 Accepted, W1 Unfilled, W2...)
    weekly_column_refs = ', '.join([f'W{i}_FILL_RATE, W{i}_ORDER_QTY, W{i}_RECEIVED_QTY, W{i}_ACCEPTED_UNITS, W{i}_UNFILLED_UNITS' for i in range(1, len(week_dates) + 1)])
    
    # Final column order: field, product_name, cut, weighted_unfilled_contribution, aggregates, then weekly
    final_column_refs = f'{aggregate_column_refs}, {weekly_column_refs}'
    
    return {
        'vendor_columns': ',\n                '.join(vendor_columns),
        'mc1_columns': ',\n                '.join(mc1_columns),
        'mc2_columns': ',\n                '.join(mc2_columns),
        'brand_columns': ',\n                '.join(brand_columns),
        'sku_columns': ',\n                '.join(sku_columns),
        'vendor_column_refs': final_column_refs,
        'mc1_column_refs': final_column_refs,
        'mc2_column_refs': final_column_refs,
        'brand_column_refs': final_column_refs,
        'sku_column_refs': final_column_refs,
        'final_column_refs': final_column_refs,
        'column_mapping': column_mapping,
        'weeks_back': weeks_back,
        'trailing_weeks_suffix': trailing_weeks_suffix
    }


def generate_fillrate_query(vendor_numbers, start_date, end_date, aggregation, include_dropship=False):
    """
    Generate Fill Rate query mimicking ASBO structure with contribution analysis
    
    Key Metrics:
    - Fill Rate: capped_received_qty / original_order_qty (corrected formula)
    - Weighted Unfilled Contribution: How much each entity contributes to total unfilled units (% of total miss)
    - Weekly trending data with flexible timeframes
    - Hierarchical analysis (Vendor -> MC1 -> MC2 -> Brand -> SKU)
    """
    
    # Convert dates to strings for SQL
    start_date_str = start_date.strftime('%Y-%m-%d')
    end_date_str = end_date.strftime('%Y-%m-%d')
    
    # Convert vendor numbers to SQL format
    vendor_list = "', '".join(vendor_numbers)
    
    # Calculate weeks between start and end date for flexible timeframes
    weeks_back = ((end_date - start_date).days // 7) + 1
    weeks_back = max(weeks_back, 2)  # Minimum 2 weeks
    
    # Generate weekly column references
    weekly_columns = generate_weekly_fillrate_columns(start_date, end_date, weeks_back)
    
    # Dropship filter
    dropship_filter = ""
    if not include_dropship:
        dropship_filter = "-- Dropship filtering not applicable for procurement data"
    
    query = f"""
        -- Vendor SKUs CTE (CORRECTED - using proper table)
        WITH vendor_skus AS (
            SELECT DISTINCT
                p.product_part_number,
                v.vendor_name,
                v.vendor_number
            FROM EDLDB.CHEWYBI.vendor_agreement_line vl
            LEFT JOIN edldb.chewybi.products p ON p.product_part_number = vl.product_part_number
            LEFT JOIN edldb.chewybi.vendors v ON v.vendor_number = vl.vendor_number
            WHERE CURRENT_DATE BETWEEN COALESCE(vl.agreement_line_start_date::DATE, CURRENT_DATE)
                AND COALESCE(vl.agreement_line_end_date::DATE, CURRENT_DATE)
                AND COALESCE(vl.disabled_reason_code,'') = ''
                AND COALESCE(vl.agreement_line_status,'') NOT IN ('CANCELED')
                AND v.vendor_number IN ('{vendor_list}')
                AND p.product_company_description = 'Chewy'
                AND p.product_discontinued_flag = FALSE
        ),
        
        -- Base fill rate data with weekly breakdowns (CORRECTED FORMULA)
        base_fillrate AS (
            SELECT 
                met.vendor_number,
                v.vendor_name,
                met.product_part_number,
                p.product_name,
                p.product_manufacturer_name,
                p.product_merch_classification1,
                p.product_merch_classification2,
                DATE_TRUNC('week', min_ap_closed_date)::DATE as week_date,
                
                -- Core metrics (CORRECTED)
                SUM(met.orig_order_qty) as original_order_qty,
                SUM(capped_received_qty) as capped_received_qty,
                SUM(LAST_RECVD_855_QTY) as units_accepted,
                SUM(met.orig_order_qty) - SUM(capped_received_qty) as unfilled_units,
                
                -- Fill rate calculation (CORRECTED FORMULA)
                CASE 
                    WHEN SUM(met.orig_order_qty) > 0 
                    THEN SUM(capped_received_qty) / SUM(met.orig_order_qty)
                    ELSE NULL  -- No orders = no fill rate data (not 100%)
                END as fill_rate
                
            FROM EDLDB.CHEWYBI.DM_SUPPLYCHAIN_PROCUREMENT_METRICS met
            JOIN EDLDB.chewybi.procurement_document_product_measures pdpm
                ON pdpm.document_number = met.document_number
                AND pdpm.product_part_number = met.product_part_number
            LEFT JOIN EDLDB.chewybi.vendors v
                ON v.vendor_number = met.vendor_number
            LEFT JOIN EDLDB.chewybi.products p
                ON p.product_part_number = met.product_part_number
            JOIN vendor_skus vs ON met.product_part_number = vs.product_part_number
            WHERE date_trunc('week', min_ap_closed_date) BETWEEN 
                date_trunc('week', '{start_date_str}'::date) AND date_trunc('week', '{end_date_str}'::date)
                AND met.vendor_number IN ('{vendor_list}')
                AND met.product_company_description = 'Chewy'
                AND (not met.deleted_by_users or (met.deleted_by_users and met.po_status not in ('Deleted by Chewy')))
                {dropship_filter}
            GROUP BY 
                met.vendor_number,
                v.vendor_name,
                met.product_part_number,
                p.product_name,
                p.product_manufacturer_name,
                p.product_merch_classification1,
                p.product_merch_classification2,
                DATE_TRUNC('week', min_ap_closed_date)::DATE
        ),
        
        -- Vendor level analysis with weighted contribution
        vendor_base AS (
            SELECT 
                vendor_name,
                {weekly_columns['vendor_columns']},
                -- Aggregate metrics
                SUM(unfilled_units) as total_unfilled_units,
                SUM(original_order_qty) as total_original_qty,
                SUM(capped_received_qty) as total_capped_received,
                CASE 
                    WHEN SUM(original_order_qty) > 0 
                    THEN SUM(capped_received_qty) / SUM(original_order_qty)
                    ELSE NULL  -- No orders = no fill rate data (not 100%)
                END as overall_fill_rate
            FROM base_fillrate
            GROUP BY vendor_name
        ),
        
        vendor_summary AS (
            SELECT 
                vendor_name as field,
                NULL as product_name,
                'Vendor' as cut,
                0 as priority_cut,
                -- Weighted Unfilled Contribution (% of total unfilled units - "% of total miss")
                COALESCE(total_unfilled_units / NULLIFZERO(SUM(total_unfilled_units) OVER()), 0) as weighted_unfilled_contribution,
                {weekly_columns['vendor_column_refs']},
                ROW_NUMBER() OVER(ORDER BY total_unfilled_units DESC) as rn
            FROM vendor_base
        ),
        
        -- MC1 level analysis
        mc1_base AS (
            SELECT 
                product_merch_classification1,
                {weekly_columns['mc1_columns']},
                SUM(unfilled_units) as total_unfilled_units,
                SUM(original_order_qty) as total_original_qty,
                SUM(capped_received_qty) as total_capped_received,
                CASE 
                    WHEN SUM(original_order_qty) > 0 
                    THEN SUM(capped_received_qty) / SUM(original_order_qty)
                    ELSE NULL  -- No orders = no fill rate data (not 100%)
                END as overall_fill_rate
            FROM base_fillrate
            GROUP BY product_merch_classification1
        ),
        
        mc1_ranked AS (
            SELECT 
                product_merch_classification1 as field,
                NULL as product_name,
                'MC1' as cut,
                1 as priority_cut,
                -- Weighted Unfilled Contribution (% of total unfilled units)
                COALESCE(total_unfilled_units / NULLIFZERO(SUM(total_unfilled_units) OVER()), 0) as weighted_unfilled_contribution,
                {weekly_columns['mc1_column_refs']},
                ROW_NUMBER() OVER(ORDER BY total_unfilled_units DESC) as rn
            FROM mc1_base
        ),
        
        -- MC2 level analysis
        mc2_base AS (
            SELECT 
                product_merch_classification2,
                {weekly_columns['mc2_columns']},
                SUM(unfilled_units) as total_unfilled_units,
                SUM(original_order_qty) as total_original_qty,
                SUM(capped_received_qty) as total_capped_received,
                CASE 
                    WHEN SUM(original_order_qty) > 0 
                    THEN SUM(capped_received_qty) / SUM(original_order_qty)
                    ELSE NULL  -- No orders = no fill rate data (not 100%)
                END as overall_fill_rate
            FROM base_fillrate
            GROUP BY product_merch_classification2
        ),
        
        mc2_ranked AS (
            SELECT 
                product_merch_classification2 as field,
                NULL as product_name,
                'MC2' as cut,
                2 as priority_cut,
                -- Weighted Unfilled Contribution (% of total unfilled units)
                COALESCE(total_unfilled_units / NULLIFZERO(SUM(total_unfilled_units) OVER()), 0) as weighted_unfilled_contribution,
                {weekly_columns['mc2_column_refs']},
                ROW_NUMBER() OVER(ORDER BY total_unfilled_units DESC) as rn
            FROM mc2_base
        ),
        
        -- Brand level analysis
        brand_base AS (
            SELECT 
                product_manufacturer_name,
                {weekly_columns['brand_columns']},
                SUM(unfilled_units) as total_unfilled_units,
                SUM(original_order_qty) as total_original_qty,
                SUM(capped_received_qty) as total_capped_received,
                CASE 
                    WHEN SUM(original_order_qty) > 0 
                    THEN SUM(capped_received_qty) / SUM(original_order_qty)
                    ELSE NULL  -- No orders = no fill rate data (not 100%)
                END as overall_fill_rate
            FROM base_fillrate
            GROUP BY product_manufacturer_name
        ),
        
        brand_contribution AS (
            SELECT 
                brand_base.*,
                -- Weighted Unfilled Contribution (% of total unfilled units)
                COALESCE(total_unfilled_units / NULLIFZERO(SUM(total_unfilled_units) OVER()), 0) as weighted_unfilled_contribution
            FROM brand_base
        ),
        
        brand_ranked AS (
            SELECT 
                product_manufacturer_name as field,
                NULL as product_name,
                'Top Fill Rate Issues by Brand' as cut,
                3 as priority_cut,
                weighted_unfilled_contribution,
                {weekly_columns['brand_column_refs']},
                ROW_NUMBER() OVER(ORDER BY total_unfilled_units DESC) as rn
            FROM brand_contribution
            WHERE weighted_unfilled_contribution > 0  -- Only show brands with fill rate issues
            ORDER BY total_unfilled_units DESC
            LIMIT 10
        ),
        
        -- SKU level analysis (Top SKUs weighted by unfilled contribution)
        sku_base AS (
            SELECT 
                product_part_number,
                product_name,
                {weekly_columns['sku_columns']},
                SUM(unfilled_units) as total_unfilled_units,
                SUM(original_order_qty) as total_original_qty,
                SUM(capped_received_qty) as total_capped_received,
                CASE 
                    WHEN SUM(original_order_qty) > 0 
                    THEN SUM(capped_received_qty) / SUM(original_order_qty)
                    ELSE NULL  -- No orders = no fill rate data (not 100%)
                END as overall_fill_rate
            FROM base_fillrate
            GROUP BY product_part_number, product_name
        ),
        
        sku_contribution AS (
            SELECT 
                sku_base.*,
                -- Weighted Unfilled Contribution (% of total unfilled units - "% of total miss")
                COALESCE(total_unfilled_units / NULLIFZERO(SUM(total_unfilled_units) OVER()), 0) as weighted_unfilled_contribution
            FROM sku_base
        ),
        
        sku_ranked AS (
            SELECT 
                product_part_number as field,
                product_name,
                'Top Fill Rate Issues by SKU' as cut,
                4 as priority_cut,
                weighted_unfilled_contribution,
                {weekly_columns['sku_column_refs']},
                ROW_NUMBER() OVER(ORDER BY total_unfilled_units DESC) as rn
            FROM sku_contribution
            WHERE weighted_unfilled_contribution > 0  -- Only show SKUs with fill rate issues
            ORDER BY total_unfilled_units DESC
            -- No limit to show all contributing SKUs (user requested)
        ),
        
        -- Combine all levels with priority ordering
        final_result AS (
            SELECT 
                field, product_name, cut, weighted_unfilled_contribution,
                {weekly_columns['final_column_refs']}
            FROM (
                SELECT * FROM vendor_summary
                UNION ALL
                SELECT * FROM mc1_ranked
                UNION ALL
                SELECT * FROM mc2_ranked
                UNION ALL
                SELECT * FROM brand_ranked
                UNION ALL
                SELECT * FROM sku_ranked
            ) 
            ORDER BY priority_cut, rn
        )
        
        SELECT 
            field, product_name, cut, weighted_unfilled_contribution,
            {weekly_columns['final_column_refs']}
        FROM final_result
    """
    
    return query, weekly_columns.get('column_mapping', {})


def generate_fillrate_data_dump_query(vendor_numbers, start_date, end_date, include_dropship=False):
    """
    Generate raw data dump query for Fill Rate analysis (matches production code structure)
    This provides the detailed PO/SKU level data that matches the aggregated metrics
    """
    
    # Convert dates to strings for SQL
    start_date_str = start_date.strftime('%Y-%m-%d')
    end_date_str = end_date.strftime('%Y-%m-%d')
    
    # Convert vendor numbers to SQL format
    vendor_list = "', '".join(vendor_numbers)
    
    # Dropship filter
    dropship_filter = ""
    if not include_dropship:
        dropship_filter = "-- Dropship filtering not applicable for procurement data"
    
    query = f"""
        SELECT 
            DATE_TRUNC('week', min_ap_closed_date)::DATE as "Week",
            met.vendor_number as "Vendor Number",
            v.vendor_name as "Vendor Name",
            met.document_number as "PO Number",
            met.product_part_number as "Chewy Product Number",
            SUM(capped_received_qty) as "Capped Received Qty",
            SUM(met.orig_order_qty) as "Original Order Qty",
            --ROUND(SUM(met.orig_order_qty) * 0.2, 0) as "Rejected Threshold Units",
            SUM(met.orig_order_qty - POA_Fill_Qty) as "Units Rejected",
            SUM(LAST_RECVD_855_QTY) as "Units Accepted",
            LEAST(SUM(total_rcvd_qty), SUM(met.Orig_Order_Qty), SUM(POA_Fill_Qty)) as "Units Received",
            SUM(POA_Fill_Qty) - LEAST(SUM(total_rcvd_qty), SUM(met.Orig_Order_Qty), SUM(POA_Fill_Qty)) as "Unfilled Units"
        FROM EDLDB.CHEWYBI.DM_SUPPLYCHAIN_PROCUREMENT_METRICS met
        JOIN EDLDB.chewybi.procurement_document_product_measures pdpm
            ON pdpm.document_number = met.document_number
            AND pdpm.product_part_number = met.product_part_number
        LEFT JOIN EDLDB.chewybi.vendors v
            ON v.vendor_number = met.vendor_number
        WHERE date_trunc('week', min_ap_closed_date) BETWEEN 
            date_trunc('week', '{start_date_str}'::date) AND date_trunc('week', '{end_date_str}'::date)
            AND met.vendor_number IN ('{vendor_list}')
            AND met.product_company_description = 'Chewy'
            -- AND pdpm.document_ready_to_reconcile_flag = 'true'  -- Commented out document ready filter
            -- AND location_code NOT IN ('RNO1')  -- Commented out location filter
        GROUP BY 
            met.vendor_number,
            v.vendor_name,
            met.document_number,
            DATE_TRUNC('week', min_ap_closed_date)::DATE,
            met.product_part_number
        ORDER BY "Week" DESC, "PO Number", "Chewy Product Number"
    """
    
    return query


def generate_weekly_ontime_columns(start_date, end_date, weeks_back):
    """Generate weekly On Time columns similar to Fill Rate structure"""
    
    # Calculate actual week dates between start and end date
    week_dates = []
    current_date = end_date
    
    # Generate weeks going backwards from end_date (newest to oldest)
    for i in range(weeks_back):
        # Get Monday of the current week
        week_start = current_date - timedelta(days=current_date.weekday())
        if week_start >= start_date:
            week_dates.append(week_start)
        current_date = week_start - timedelta(days=7)
    
    # Keep in reverse chronological order (newest to oldest: W1 = most recent week)
    
    # Generate SQL parts for each level
    vendor_columns = []
    mc1_columns = []
    mc2_columns = []
    brand_columns = []
    sku_columns = []
    
    column_mapping = {}
    column_refs = []
    
    for i, week_start in enumerate(week_dates, 1):
        week_start_str = week_start.strftime('%Y-%m-%d')
        week_display = week_start.strftime('%m/%d')
        
        # Weekly columns: On Time Rate, Total Units, Late Units
        ontime_rate_sql = f"""
            CASE 
                WHEN SUM(CASE WHEN week_date = '{week_start_str}'::date THEN total_units ELSE 0 END) > 0
                THEN SUM(CASE WHEN week_date = '{week_start_str}'::date THEN ontime_units ELSE 0 END) / 
                     SUM(CASE WHEN week_date = '{week_start_str}'::date THEN total_units ELSE 0 END)
                ELSE NULL
            END as W{i}_ONTIME_RATE"""
        
        total_units_sql = f"""
            SUM(CASE WHEN week_date = '{week_start_str}'::date THEN total_units ELSE 0 END) as W{i}_TOTAL_UNITS"""
        
        late_units_sql = f"""
            SUM(CASE WHEN week_date = '{week_start_str}'::date THEN late_units ELSE 0 END) as W{i}_LATE_UNITS"""
        
        # Add to each level
        week_columns = [ontime_rate_sql, total_units_sql, late_units_sql]
        vendor_columns.extend(week_columns)
        mc1_columns.extend(week_columns)
        mc2_columns.extend(week_columns)
        brand_columns.extend(week_columns)
        sku_columns.extend(week_columns)
        
        # Column mapping for display (W1 = most recent week)
        column_mapping[f'W{i}_ONTIME_RATE'] = f'{week_display}_ONTIME_RATE'
        column_mapping[f'W{i}_TOTAL_UNITS'] = f'{week_display}_TOTAL_UNITS'
        column_mapping[f'W{i}_LATE_UNITS'] = f'{week_display}_LATE_UNITS'
        
        # Column references for final SELECT
        column_refs.extend([f'W{i}_ONTIME_RATE', f'W{i}_TOTAL_UNITS', f'W{i}_LATE_UNITS'])
    
    # Create trailing weeks suffix for aggregate columns
    if weeks_back <= 4:
        trailing_weeks_suffix = f'T{weeks_back}W'
    else:
        trailing_weeks_suffix = f'T{weeks_back}W'
    
    # Add aggregate columns
    column_mapping[f'ONTIME_RATE_{trailing_weeks_suffix}'] = f'On Time Rate {trailing_weeks_suffix}'
    column_mapping[f'TOTAL_UNITS_{trailing_weeks_suffix}'] = f'Total Units {trailing_weeks_suffix}'
    column_mapping[f'LATE_UNITS_{trailing_weeks_suffix}'] = f'Late Units {trailing_weeks_suffix}'
    
    # Create column reference strings with proper ordering
    aggregate_column_refs = f'ONTIME_RATE_{trailing_weeks_suffix}, TOTAL_UNITS_{trailing_weeks_suffix}, LATE_UNITS_{trailing_weeks_suffix}'
    
    # Weekly columns in proper order
    weekly_column_refs = ', '.join([f'W{i}_ONTIME_RATE, W{i}_TOTAL_UNITS, W{i}_LATE_UNITS' for i in range(1, len(week_dates) + 1)])
    
    # Final column order: field, product_name, cut, weighted_late_contribution, aggregates, then weekly
    final_column_refs = f'{aggregate_column_refs}, {weekly_column_refs}'
    
    return {
        'vendor_columns': ',\n                '.join(vendor_columns),
        'mc1_columns': ',\n                '.join(mc1_columns),
        'mc2_columns': ',\n                '.join(mc2_columns),
        'brand_columns': ',\n                '.join(brand_columns),
        'sku_columns': ',\n                '.join(sku_columns),
        'vendor_column_refs': final_column_refs,
        'mc1_column_refs': final_column_refs,
        'mc2_column_refs': final_column_refs,
        'brand_column_refs': final_column_refs,
        'sku_column_refs': final_column_refs,
        'final_column_refs': final_column_refs,
        'column_mapping': column_mapping,
        'trailing_weeks_suffix': trailing_weeks_suffix
    }


def generate_ontime_analysis_query(vendor_numbers, start_date, end_date, aggregation, include_dropship=False):
    """Generate On Time analysis query with hierarchical structure like Fill Rate"""
    
    # Convert dates to strings for SQL
    start_date_str = start_date.strftime('%Y-%m-%d')
    end_date_str = end_date.strftime('%Y-%m-%d')
    
    # Convert vendor numbers to SQL format
    vendor_list = "', '".join(vendor_numbers)
    
    # Calculate weeks between start and end date for flexible timeframes
    weeks_back = ((end_date - start_date).days // 7) + 1
    weeks_back = max(weeks_back, 2)  # Minimum 2 weeks
    
    # Generate weekly column references
    weekly_columns = generate_weekly_ontime_columns(start_date, end_date, weeks_back)
    
    query = f"""
        -- Base On Time data with dual freight terms calculation methods
        WITH base_ontime AS (
            SELECT 
                v.vendor_name,
                vc.product_part_number,
                p.product_name,
                p.product_manufacturer_name,
                p.product_merch_classification1,
                p.product_merch_classification2,
                vc.freight_terms_lookup_code,
                DATE_TRUNC('week', vc.min_ap_closed_date)::DATE as week_date,
                
                -- Core metrics
                SUM(vc.total_rcvd_qty) as total_units,
                
                -- Dual On Time calculation based on freight terms
                SUM(
                    CASE 
                        -- CC (Chewy Collect): Use existing late_po_count logic
                        WHEN vc.freight_terms_lookup_code = 'CC' AND vc.late_po_count != '1' 
                        THEN vc.total_rcvd_qty
                        -- PP (Prepaid): Compare original_requested_delivery_date vs appointment_dttm (date only)
                        WHEN vc.freight_terms_lookup_code = 'PP' AND vc.appointment_dttm::DATE <= vc.original_requested_delivery_date
                        THEN vc.total_rcvd_qty
                        ELSE 0 
                    END
                ) as ontime_units,
                
                -- Dual Late Units calculation based on freight terms
                SUM(
                    CASE 
                        -- CC (Chewy Collect): Use existing late quantity logic
                        WHEN vc.freight_terms_lookup_code = 'CC' 
                        THEN vc.total_late_quantity
                        -- PP (Prepaid): Calculate late units based on appointment date comparison
                        WHEN vc.freight_terms_lookup_code = 'PP' AND vc.appointment_dttm::DATE > vc.original_requested_delivery_date
                        THEN vc.total_rcvd_qty
                        ELSE 0 
                    END
                ) as late_units,
                
                COUNT(DISTINCT vc.document_number) as total_pos,
                
                -- On Time Rate calculation (will be recalculated at aggregation level)
                COALESCE(
                    SUM(
                        CASE 
                            WHEN vc.freight_terms_lookup_code = 'CC' AND vc.late_po_count != '1' 
                            THEN vc.total_rcvd_qty
                            WHEN vc.freight_terms_lookup_code = 'PP' AND vc.appointment_dttm::DATE <= vc.original_requested_delivery_date
                            THEN vc.total_rcvd_qty
                            ELSE 0 
                        END
                    ) / NULLIFZERO(SUM(vc.total_rcvd_qty)), 0
                ) as ontime_rate
                
            FROM EDLDB.CHEWYBI.DM_SUPPLYCHAIN_PROCUREMENT_METRICS vc
            JOIN EDLDB.CHEWYBI.vendors v ON v.vendor_number = vc.vendor_number
            LEFT JOIN EDLDB.CHEWYBI.products p ON p.product_part_number = vc.product_part_number
            WHERE DATE_TRUNC('week', vc.min_ap_closed_date) BETWEEN 
                DATE_TRUNC('week', '{start_date_str}'::date) AND DATE_TRUNC('week', '{end_date_str}'::date)
                AND vc.product_company_description = 'Chewy'
                AND vc.vendor_number IN ('{vendor_list}')
                -- Only include CC and PP freight terms for proper calculation
                AND vc.freight_terms_lookup_code IN ('CC', 'PP')
            GROUP BY v.vendor_name, vc.product_part_number, p.product_name, p.product_manufacturer_name,
                     p.product_merch_classification1, p.product_merch_classification2, 
                     vc.freight_terms_lookup_code, DATE_TRUNC('week', vc.min_ap_closed_date)::DATE
        ),
        
        -- Vendor level analysis
        vendor_base AS (
            SELECT 
                vendor_name,
                {weekly_columns['vendor_columns']},
                -- Aggregate metrics
                SUM(late_units) as total_late_units,
                SUM(total_units) as total_units,
                SUM(ontime_units) as total_ontime_units,
                CASE 
                    WHEN SUM(total_units) > 0 
                    THEN SUM(ontime_units) / SUM(total_units)
                    ELSE NULL
                END as ONTIME_RATE_{weekly_columns['trailing_weeks_suffix']},
                SUM(total_units) as TOTAL_UNITS_{weekly_columns['trailing_weeks_suffix']},
                SUM(late_units) as LATE_UNITS_{weekly_columns['trailing_weeks_suffix']}
            FROM base_ontime
            GROUP BY vendor_name
        ),
        
        vendor_summary AS (
            SELECT 
                vendor_name as field,
                NULL as product_name,
                'Vendor' as cut,
                0 as priority_cut,
                -- Weighted Late Contribution (% of total late units, or % of total units if NO late units exist anywhere)
                CASE 
                    WHEN SUM(total_late_units) OVER() > 0 
                    THEN COALESCE(total_late_units / NULLIFZERO(SUM(total_late_units) OVER()), 0)
                    ELSE COALESCE(total_units / NULLIFZERO(SUM(total_units) OVER()), 0)
                END as weighted_late_contribution,
                {weekly_columns['vendor_column_refs']},
                ROW_NUMBER() OVER(ORDER BY total_late_units DESC) as rn
            FROM vendor_base
        ),
        
        -- MC1 level analysis
        mc1_base AS (
            SELECT 
                product_merch_classification1,
                {weekly_columns['mc1_columns']},
                SUM(late_units) as total_late_units,
                SUM(total_units) as total_units,
                SUM(ontime_units) as total_ontime_units,
                CASE 
                    WHEN SUM(total_units) > 0 
                    THEN SUM(ontime_units) / SUM(total_units)
                    ELSE NULL
                END as ONTIME_RATE_{weekly_columns['trailing_weeks_suffix']},
                SUM(total_units) as TOTAL_UNITS_{weekly_columns['trailing_weeks_suffix']},
                SUM(late_units) as LATE_UNITS_{weekly_columns['trailing_weeks_suffix']},
            FROM base_ontime
            WHERE product_merch_classification1 IS NOT NULL
            GROUP BY product_merch_classification1
        ),
        
        mc1_ranked AS (
            SELECT 
                product_merch_classification1 as field,
                NULL as product_name,
                'MC1' as cut,
                1 as priority_cut,
                -- Weighted Late Contribution (% of total late units, or % of total units if NO late units exist anywhere)
                CASE 
                    WHEN SUM(total_late_units) OVER() > 0 
                    THEN COALESCE(total_late_units / NULLIFZERO(SUM(total_late_units) OVER()), 0)
                    ELSE COALESCE(total_units / NULLIFZERO(SUM(total_units) OVER()), 0)
                END as weighted_late_contribution,
                {weekly_columns['mc1_column_refs']},
                ROW_NUMBER() OVER(ORDER BY total_late_units DESC) as rn
            FROM mc1_base
        ),
        
        -- MC2 level analysis
        mc2_base AS (
            SELECT 
                product_merch_classification2,
                {weekly_columns['mc2_columns']},
                SUM(late_units) as total_late_units,
                SUM(total_units) as total_units,
                SUM(ontime_units) as total_ontime_units,
                CASE 
                    WHEN SUM(total_units) > 0 
                    THEN SUM(ontime_units) / SUM(total_units)
                    ELSE NULL
                END as ONTIME_RATE_{weekly_columns['trailing_weeks_suffix']},
                SUM(total_units) as TOTAL_UNITS_{weekly_columns['trailing_weeks_suffix']},
                SUM(late_units) as LATE_UNITS_{weekly_columns['trailing_weeks_suffix']},
            FROM base_ontime
            WHERE product_merch_classification2 IS NOT NULL
            GROUP BY product_merch_classification2
        ),
        
        mc2_ranked AS (
            SELECT 
                product_merch_classification2 as field,
                NULL as product_name,
                'MC2' as cut,
                2 as priority_cut,
                -- Weighted Late Contribution (% of total late units, or % of total units if NO late units exist anywhere)
                CASE 
                    WHEN SUM(total_late_units) OVER() > 0 
                    THEN COALESCE(total_late_units / NULLIFZERO(SUM(total_late_units) OVER()), 0)
                    ELSE COALESCE(total_units / NULLIFZERO(SUM(total_units) OVER()), 0)
                END as weighted_late_contribution,
                {weekly_columns['mc2_column_refs']},
                ROW_NUMBER() OVER(ORDER BY total_late_units DESC) as rn
            FROM mc2_base
        ),
        
        -- Brand level analysis (top contributors)
        brand_base AS (
            SELECT 
                product_manufacturer_name,
                {weekly_columns['brand_columns']},
                SUM(late_units) as total_late_units,
                SUM(total_units) as total_units,
                SUM(ontime_units) as total_ontime_units,
                CASE 
                    WHEN SUM(total_units) > 0 
                    THEN SUM(ontime_units) / SUM(total_units)
                    ELSE NULL
                END as ONTIME_RATE_{weekly_columns['trailing_weeks_suffix']},
                SUM(total_units) as TOTAL_UNITS_{weekly_columns['trailing_weeks_suffix']},
                SUM(late_units) as LATE_UNITS_{weekly_columns['trailing_weeks_suffix']},
            FROM base_ontime
            WHERE product_manufacturer_name IS NOT NULL
            GROUP BY product_manufacturer_name
        ),
        
        brand_ranked AS (
            SELECT 
                product_manufacturer_name as field,
                NULL as product_name,
                'Top On Time Issues by Brand' as cut,
                3 as priority_cut,
                -- Weighted Late Contribution (% of total late units, or % of total units if NO late units exist anywhere)
                CASE 
                    WHEN SUM(total_late_units) OVER() > 0 
                    THEN COALESCE(total_late_units / NULLIFZERO(SUM(total_late_units) OVER()), 0)
                    ELSE COALESCE(total_units / NULLIFZERO(SUM(total_units) OVER()), 0)
                END as weighted_late_contribution,
                {weekly_columns['brand_column_refs']},
                ROW_NUMBER() OVER(ORDER BY total_late_units DESC) as rn
            FROM brand_base
        ),
        
        -- Freight Terms level analysis (replaces SKU level)
        freight_terms_base AS (
            SELECT 
                freight_terms_lookup_code,
                {weekly_columns['brand_columns']},
                SUM(late_units) as total_late_units,
                SUM(total_units) as total_units,
                SUM(ontime_units) as total_ontime_units,
                CASE 
                    WHEN SUM(total_units) > 0 
                    THEN SUM(ontime_units) / SUM(total_units)
                    ELSE NULL
                END as ONTIME_RATE_{weekly_columns['trailing_weeks_suffix']},
                SUM(total_units) as TOTAL_UNITS_{weekly_columns['trailing_weeks_suffix']},
                SUM(late_units) as LATE_UNITS_{weekly_columns['trailing_weeks_suffix']},
            FROM base_ontime
            WHERE freight_terms_lookup_code IS NOT NULL
            GROUP BY freight_terms_lookup_code
        ),
        
        freight_terms_ranked AS (
            SELECT 
                CASE 
                    WHEN freight_terms_lookup_code = 'CC' THEN 'CC (Chewy Collect)'
                    WHEN freight_terms_lookup_code = 'PP' THEN 'PP (Prepaid)'
                    ELSE freight_terms_lookup_code
                END as field,
                NULL as product_name,
                'Freight Terms Analysis' as cut,
                4 as priority_cut,
                -- Weighted Late Contribution (% of total late units, or % of total units if NO late units exist anywhere)
                CASE 
                    WHEN SUM(total_late_units) OVER() > 0 
                    THEN COALESCE(total_late_units / NULLIFZERO(SUM(total_late_units) OVER()), 0)
                    ELSE COALESCE(total_units / NULLIFZERO(SUM(total_units) OVER()), 0)
                END as weighted_late_contribution,
                {weekly_columns['brand_column_refs']},
                ROW_NUMBER() OVER(ORDER BY total_late_units DESC) as rn
            FROM freight_terms_base
        )
        
        SELECT * FROM vendor_summary
        UNION ALL
        SELECT * FROM mc1_ranked WHERE rn <= 10
        UNION ALL
        SELECT * FROM mc2_ranked WHERE rn <= 10
        UNION ALL
        SELECT * FROM brand_ranked WHERE rn <= 10
        UNION ALL
        SELECT * FROM freight_terms_ranked
        ORDER BY priority_cut, rn
    """
    
    return query, weekly_columns['column_mapping']

def generate_ontime_query(vendor_numbers, start_date, end_date, aggregation, include_dropship=False):
    """Generate On Time PO analysis query - data dump of PO delivery performance"""
    # Use dynamic date range (same as other sections)
    start_date_str = start_date.strftime('%Y-%m-%d')
    end_date_str = end_date.strftime('%Y-%m-%d')
    
    # Convert vendor numbers to SQL format
    vendor_list = "', '".join(vendor_numbers)
    
    # Note: On Time analysis focuses on procurement/PO delivery data and may not directly use dropship filtering
    # The include_dropship parameter is maintained for consistency but may not affect results
    dropship_filter = ""
    if not include_dropship:
        # Dropship filtering may not be applicable for procurement delivery metrics
        dropship_filter = "-- Dropship filtering not applicable for procurement delivery data"
    
    query = f"""
        SELECT 
            DATE_TRUNC('week', min_ap_closed_date)::DATE as "Week",
            vc.vendor_number as "Vendor Number",
            vc.vendor_name as "Vendor Name",
            vc.document_number as "PO Number",
            vc.freight_terms_lookup_code as "Freight Terms",
            vc.location_code as "FC",
            vc.original_requested_delivery_date as "Chewy Requested Date",
            vc.vendor_date_to_use as "Vendor Available Date",
            vc.appointment_dttm::DATE as "Appointment Date",
            CASE 
                -- CC (Chewy Collect): Use existing late_po_count logic
                WHEN vc.freight_terms_lookup_code = 'CC' AND vc.late_po_count = '1' THEN 'LATE'
                WHEN vc.freight_terms_lookup_code = 'CC' AND vc.late_po_count != '1' THEN 'ON TIME'
                -- PP (Prepaid): Compare original_requested_delivery_date vs appointment_dttm (date only)
                WHEN vc.freight_terms_lookup_code = 'PP' AND vc.appointment_dttm::DATE > vc.original_requested_delivery_date THEN 'LATE'
                WHEN vc.freight_terms_lookup_code = 'PP' AND vc.appointment_dttm::DATE <= vc.original_requested_delivery_date THEN 'ON TIME'
                ELSE 'UNKNOWN'
            END as "PO Disposition",
            SUM(vc.total_rcvd_qty) as "PO Units",
            SUM(
                CASE 
                    -- CC (Chewy Collect): Use existing late quantity logic
                    WHEN vc.freight_terms_lookup_code = 'CC' 
                    THEN vc.total_late_quantity
                    -- PP (Prepaid): Calculate late units based on appointment date comparison
                    WHEN vc.freight_terms_lookup_code = 'PP' AND vc.appointment_dttm::DATE > vc.original_requested_delivery_date
                    THEN vc.total_rcvd_qty
                    ELSE 0 
                END
            ) as "Late Units"
        FROM EDLDB.CHEWYBI.DM_SUPPLYCHAIN_PROCUREMENT_METRICS vc
        WHERE date_trunc('week', min_ap_closed_date) BETWEEN 
            date_trunc('week', '{start_date_str}'::date) AND date_trunc('week', '{end_date_str}'::date)
            AND vc.vendor_number IN ('{vendor_list}')
            AND vc.product_company_description = 'Chewy'

        GROUP BY 
            vc.vendor_number,
            vc.vendor_name,
            vc.document_number,
            vc.freight_terms_lookup_code,
            vc.location_code,
            vc.original_requested_delivery_date,
            vc.vendor_date_to_use,
            vc.appointment_dttm,
            DATE_TRUNC('week', min_ap_closed_date)::DATE,
            vc.late_po_count
        ORDER BY "Week" DESC, "PO Number"
    """
    
    return query


