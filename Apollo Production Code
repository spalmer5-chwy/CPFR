def check_existing_snapshot(vendor_number: str, period_start: date, period_end: date, user_id: str) -> str:
    """
    Check if a forecast snapshot already exists for the given parameters.
    
    Args:
        vendor_number: Vendor number from CSV
        period_start: Start date of forecast period
        period_end: End date of forecast period  
        user_id: Current user ID
        
    Returns:
        "NO_CONFLICT", "OVERWRITE_WARNING", or "VERSION_WARNING"
    """
    try:
        session = snowflake_get_active_session()
        
        # Check for existing snapshots for this vendor in the same date range
        # Since we store one row per SKU per period, we need to check by snapshot_id
        check_query = f"""
        SELECT DISTINCT user_id, upload_timestamp, snapshot_id, 
               MIN(forecast_period_start) as min_period_start,
               MAX(forecast_period_end) as max_period_end
        FROM EDLDB.SC_SANDBOX.FORECAST_RECONCILIATION_SNAPSHOTS 
        WHERE vendor_number = '{vendor_number}'
        GROUP BY user_id, upload_timestamp, snapshot_id
        HAVING MIN(forecast_period_start) = '{period_start}' 
           AND MAX(forecast_period_end) = '{period_end}'
        ORDER BY upload_timestamp DESC
        LIMIT 1
        """
        
        result = session.sql(check_query).collect()
        
        # Store debug info in session state to display in the app
        debug_info = {
            'query_results_count': len(result),
            'first_result': result[0].asDict() if result else None,
            'existing_user': result[0]['USER_ID'] if result else None,
            'current_user': user_id,
            'conflict_status': None
        }
        
        if not result:
            debug_info['conflict_status'] = "NO_CONFLICT - No existing snapshots found"
            st.session_state['conflict_debug'] = debug_info
            return "NO_CONFLICT"
        
        existing_user = result[0]['USER_ID']
        
        if existing_user == user_id:
            debug_info['conflict_status'] = "OVERWRITE_WARNING - Same user found"
            st.session_state['conflict_debug'] = debug_info
            return "OVERWRITE_WARNING"
        else:
            debug_info['conflict_status'] = "VERSION_WARNING - Different user found"
            st.session_state['conflict_debug'] = debug_info
            return "VERSION_WARNING"
            
    except Exception as e:
        # If table doesn't exist or other error, assume no conflict
        debug_info = {
            'query_results_count': 0,
            'first_result': None,
            'existing_user': None,
            'current_user': user_id,
            'conflict_status': f"NO_CONFLICT - Error occurred: {str(e)}"
        }
        st.session_state['conflict_debug'] = debug_info
        return "NO_CONFLICT"

def export_dataframe_to_csv(df: pd.DataFrame, filename: str) -> bytes:
    """
    Convert DataFrame to CSV bytes for download.
    
    Args:
        df: DataFrame to export
        filename: Name for the file (used in download)
        
    Returns:
        CSV data as bytes
    """
    import io
    
    # Create a buffer to hold the CSV data
    buffer = io.StringIO()
    
    # Convert DataFrame to CSV
    df.to_csv(buffer, index=False)
    
    # Get the CSV string and encode to bytes
    csv_string = buffer.getvalue()
    return csv_string.encode('utf-8')

def save_forecast_snapshot(master_df: pd.DataFrame, user_notes: str, user_id: str, upload_mode: str = "Current Analysis", snapshot_date: date = None, overwrite: bool = False) -> str:
    """
    Save the forecast reconciliation data to Snowflake.
    
    Args:
        master_df: Master dataset with all reconciliation data
        user_notes: User's notes about this upload
        user_id: Current user ID
        overwrite: Whether to overwrite existing data
        
    Returns:
        snapshot_id: UUID of the saved snapshot
    """
    try:
        session = snowflake_get_active_session()
        
        # Generate snapshot metadata
        snapshot_date_for_record = date.today()  # When the snapshot was saved
        vendor_number = master_df['vendor_number'].iloc[0]
        period_start = master_df['period_start_date'].min().date()
        period_end = master_df['period_end_date'].max().date()
        forecast_start_date = master_df['period_start_date'].min().date()
        period_type = "Month"  # TODO: Get from session state
        
        # Table will be auto-created by write_pandas with auto_create_table=True
        
        # Delete existing data if overwriting (only if table exists)
        if overwrite:
            try:
                delete_query = f"""
                DELETE FROM EDLDB.SC_SANDBOX.FORECAST_RECONCILIATION_SNAPSHOTS 
                WHERE vendor_number = '{vendor_number}'
                AND forecast_period_start = '{period_start}'
                AND forecast_period_end = '{period_end}'
                AND user_id = '{user_id}'
                """
                session.sql(delete_query).collect()
            except Exception:
                # Table doesn't exist yet, which is fine for first save
                pass
        
        # Generate unique snapshot ID
        import uuid
        snapshot_id = str(uuid.uuid4())
        
        # Prepare data for insertion
        insert_data = []
        for _, row in master_df.iterrows():
            insert_data.append({
                'snapshot_id': snapshot_id,
                'snapshot_date': snapshot_date_for_record,
                'vendor_number': str(row.get('vendor_number', '')),
                'chewy_sku': str(row.get('chewy_sku', '')),
                'vendor_sku': str(row.get('vendor_sku', '')),
                'forecast_period_start': row['period_start_date'].date(),
                'forecast_period_end': row['period_end_date'].date(),
                'period_name': str(row.get('period_name', '')),
                'vendor_forecast_units': float(row.get('vendor_forecast_units', 0)),
                'chewy_forecast_units': float(row.get('chewy_forecast_units', 0)),
                'yoy_actual_units': float(row.get('yoy_actual_units', 0)),
                
                # SKU Attributes (handle both cases)
                'product_name': str(row.get('PRODUCT_NAME', row.get('product_name', ''))),
                'parent_company': str(row.get('PARENT_COMPANY', row.get('parent_company', ''))),
                'brand_name': str(row.get('BRAND_NAME', row.get('brand_name', ''))),
                'mc1_category': str(row.get('MC1_CATEGORY', row.get('mc1_category', ''))),
                'mc2_category': str(row.get('MC2_CATEGORY', row.get('mc2_category', ''))),
                'mc3_category': str(row.get('MC3_CATEGORY', row.get('mc3_category', ''))),
                'pc1_category': str(row.get('PC1_CATEGORY', row.get('pc1_category', ''))),
                'pc2_category': str(row.get('PC2_CATEGORY', row.get('pc2_category', ''))),
                'pc3_category': str(row.get('PC3_CATEGORY', row.get('pc3_category', ''))),
                'sku_velocity': str(row.get('SKU_VELOCITY', row.get('sku_velocity', ''))),
                
                # Metadata
                'forecast_start_date': forecast_start_date,
                'period_type': period_type,
                'user_id': user_id,
                'upload_notes': user_notes,
                'upload_mode': upload_mode,
                'historical_snapshot_date': snapshot_date.strftime('%Y-%m-%d') if snapshot_date else None
            })
        
        # Create table if it doesn't exist (using same pattern as usage analytics)
        create_table_sql = """
        CREATE TABLE IF NOT EXISTS forecast_reconciliation_snapshots (
            snapshot_id VARCHAR(100) PRIMARY KEY,
            snapshot_date DATE NOT NULL,
            vendor_number VARCHAR(50) NOT NULL,
            chewy_sku VARCHAR(50) NOT NULL,
            vendor_sku VARCHAR(50),
            forecast_period_start DATE NOT NULL,
            forecast_period_end DATE NOT NULL,
            period_name VARCHAR(50) NOT NULL,
            vendor_forecast_units NUMERIC(15,3),
            chewy_forecast_units NUMERIC(15,3),
            yoy_actual_units NUMERIC(15,3),
            
            -- SKU Attributes
            product_name VARCHAR(500),
            parent_company VARCHAR(200),
            brand_name VARCHAR(200),
            mc1_category VARCHAR(100),
            mc2_category VARCHAR(100), 
            mc3_category VARCHAR(100),
            pc1_category VARCHAR(100),
            pc2_category VARCHAR(100),
            pc3_category VARCHAR(100),
            sku_velocity VARCHAR(10),
            
            -- Metadata
            forecast_start_date DATE NOT NULL,
            period_type VARCHAR(20) NOT NULL,
            upload_timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            user_id VARCHAR(100) NOT NULL,
            upload_notes TEXT,
            upload_mode VARCHAR(20) DEFAULT 'Current Analysis',
            historical_snapshot_date DATE
            
            -- NOTE: Calculated metrics (abs_error, bias_pct, more_accurate flags) are NOT stored
            -- They are calculated real-time during analysis to ensure accuracy with fresh actuals data
        )
        """
        
        # Execute table creation
        session.sql(create_table_sql).collect()
        
        # Add new columns if they don't exist (for existing tables)
        try:
            session.sql("ALTER TABLE forecast_reconciliation_snapshots ADD COLUMN upload_mode VARCHAR(20) DEFAULT 'Current Analysis'").collect()
        except:
            pass  # Column already exists
            
        try:
            session.sql("ALTER TABLE forecast_reconciliation_snapshots ADD COLUMN historical_snapshot_date DATE").collect()
        except:
            pass  # Column already exists
        
        # Use batch INSERT with VALUES clause for better performance
        st.info(f"💾 Preparing to insert {len(insert_data)} records...")
        
        # Build batch INSERT with multiple VALUES
        batch_size = 1000  # Insert in batches to avoid SQL length limits
        
        # Create a progress bar
        progress_bar = st.progress(0)
        status_text = st.empty()
        
        total_batches = (len(insert_data) + batch_size - 1) // batch_size
        
        for i in range(0, len(insert_data), batch_size):
            batch = insert_data[i:i + batch_size]
            batch_num = i//batch_size + 1
            
            status_text.text(f"Inserting batch {batch_num}/{total_batches}: records {i+1} to {min(i+batch_size, len(insert_data))}")
            progress_bar.progress(batch_num / total_batches)
            
            # Build VALUES clauses for this batch
            values_clauses = []
            for row_data in batch:
                # Escape single quotes in string fields
                safe_values = {}
                for key, value in row_data.items():
                    if isinstance(value, str):
                        safe_values[key] = value.replace("'", "''")
                    elif value is None:
                        safe_values[key] = 'NULL'
                    else:
                        safe_values[key] = value
                
                # Handle NULL values properly
                upload_mode_val = f"'{safe_values['upload_mode']}'" if safe_values.get('upload_mode') else "'Current Analysis'"
                hist_snapshot_val = f"'{safe_values['historical_snapshot_date']}'" if safe_values.get('historical_snapshot_date') and safe_values['historical_snapshot_date'] != 'NULL' else 'NULL'
                
                values_clause = f"""(
                    '{safe_values['snapshot_id']}',
                    '{safe_values['snapshot_date']}',
                    '{safe_values['vendor_number']}',
                    '{safe_values['chewy_sku']}',
                    '{safe_values['vendor_sku']}',
                    '{safe_values['forecast_period_start']}',
                    '{safe_values['forecast_period_end']}',
                    '{safe_values['period_name']}',
                    {safe_values['vendor_forecast_units']},
                    {safe_values['chewy_forecast_units']},
                    {safe_values['yoy_actual_units']},
                    '{safe_values['product_name']}',
                    '{safe_values['parent_company']}',
                    '{safe_values['brand_name']}',
                    '{safe_values['mc1_category']}',
                    '{safe_values['mc2_category']}',
                    '{safe_values['mc3_category']}',
                    '{safe_values['pc1_category']}',
                    '{safe_values['pc2_category']}',
                    '{safe_values['pc3_category']}',
                    '{safe_values['sku_velocity']}',
                    '{safe_values['forecast_start_date']}',
                    '{safe_values['period_type']}',
                    '{safe_values['user_id']}',
                    '{safe_values['upload_notes']}',
                    {upload_mode_val},
                    {hist_snapshot_val}
                )"""
                values_clauses.append(values_clause)
            
            # Execute batch INSERT
            batch_insert_sql = f"""
            INSERT INTO forecast_reconciliation_snapshots (
                snapshot_id, snapshot_date, vendor_number, chewy_sku, vendor_sku,
                forecast_period_start, forecast_period_end, period_name,
                vendor_forecast_units, chewy_forecast_units, yoy_actual_units,
                product_name, parent_company, brand_name,
                mc1_category, mc2_category, mc3_category,
                pc1_category, pc2_category, pc3_category, sku_velocity,
                forecast_start_date, period_type, user_id, upload_notes,
                upload_mode, historical_snapshot_date
            ) VALUES {', '.join(values_clauses)}
            """
            
            # Execute batch insert
            session.sql(batch_insert_sql).collect()
        
        # Clear progress indicators and show completion
        progress_bar.progress(1.0)
        status_text.text("✅ All batches inserted successfully!")
        
        # Explicit commit to ensure data is saved (same as usage analytics)
        try:
            session.sql("COMMIT").collect()
        except:
            pass  # Auto-commit handled it
        
        return snapshot_id
        
    except Exception as e:
        error_msg = f"Failed to save forecast snapshot: {str(e)}"
        raise ValueError(error_msg)

def get_historical_snapshots(vendor_number: str = None) -> List[Dict]:
    """
    Get list of historical forecast snapshots available for accuracy analysis.
    Uses "Latest Wins" approach - for each vendor/period combination, only returns 
    the most recent upload, with attribution showing who submitted it.
    
    Args:
        vendor_number: Optional vendor number to filter results
    
    Returns:
        List of dictionaries with snapshot metadata (deduplicated by latest upload)
    """
    try:
        session = snowflake_get_active_session()
        
        # Build vendor filter
        vendor_filter = f"AND vendor_number = '{vendor_number}'" if vendor_number else ""
        
        # Get latest snapshot for each vendor/period combination using "Latest Wins"
        query = f"""
        WITH latest_forecasts AS (
            SELECT 
                snapshot_id,
                snapshot_date,
                vendor_number,
                forecast_period_start,
                forecast_period_end,
                period_type,
                upload_timestamp,
                user_id,
                ROW_NUMBER() OVER (
                    PARTITION BY vendor_number, forecast_period_start, forecast_period_end 
                    ORDER BY upload_timestamp DESC
                ) as rn
            FROM EDLDB.SC_SANDBOX.FORECAST_RECONCILIATION_SNAPSHOTS
            WHERE 1=1
            {vendor_filter}
        )
        SELECT 
            snapshot_id,
            snapshot_date,
            vendor_number,
            forecast_period_start,
            forecast_period_end,
            period_type,
            upload_timestamp,
            user_id
        FROM latest_forecasts 
        WHERE rn = 1
        ORDER BY snapshot_date DESC
        LIMIT 50
        """
        
        result = session.sql(query).collect()
        
        if result:
            snapshots = []
            for row in result:
                snapshots.append({
                    'snapshot_id': row['SNAPSHOT_ID'],
                    'snapshot_date': row['SNAPSHOT_DATE'],
                    'vendor_number': row['VENDOR_NUMBER'],
                    'period_start': row['FORECAST_PERIOD_START'],
                    'period_end': row['FORECAST_PERIOD_END'],
                    'period_type': row['PERIOD_TYPE'],
                    'upload_timestamp': row['UPLOAD_TIMESTAMP'],
                    'user_id': row['USER_ID']
                })
            return snapshots
        else:
            return []
            
    except Exception as e:
        # If table doesn't exist or other error, return empty list
        print(f"DEBUG - Error getting historical snapshots: {str(e)}")
        return []

def get_forecast_evolution_data(vendor_number: str) -> pd.DataFrame:
    """
    Get ALL forecast uploads for a vendor to track forecast evolution over time.
    Unlike get_historical_accuracy_data which uses "Latest Wins", this returns 
    ALL uploads to show how forecasts changed.
    
    Args:
        vendor_number: Vendor to analyze
        
    Returns:
        DataFrame with all forecast uploads including upload_timestamp for tracking evolution
    """
    try:
        session = snowflake_get_active_session()
        
        # Get ALL uploads for this vendor (no Latest Wins deduplication)
        query = f"""
        SELECT 
            snapshot_id,
            snapshot_date,
            vendor_number,
            chewy_sku,
            vendor_sku,
            forecast_period_start,
            forecast_period_end,
            period_name,
            vendor_forecast_units,
            product_name,
            brand_name,
            mc1_category,
            mc2_category,
            upload_timestamp,
            upload_mode,
            historical_snapshot_date,
            user_id
        FROM EDLDB.SC_SANDBOX.FORECAST_RECONCILIATION_SNAPSHOTS
        WHERE vendor_number = '{vendor_number}'
        ORDER BY upload_timestamp, forecast_period_start, chewy_sku
        """
        
        result = session.sql(query).to_pandas()
        
        if result.empty:
            return pd.DataFrame()
        
        # Create upload identifier (use snapshot_date for historical uploads, upload_timestamp for current)
        result['upload_date'] = result.apply(
            lambda row: row['HISTORICAL_SNAPSHOT_DATE'] if row['UPLOAD_MODE'] == 'Historical Upload' and pd.notna(row['HISTORICAL_SNAPSHOT_DATE']) else row['UPLOAD_TIMESTAMP'].date(),
            axis=1
        )
        
        # Create unique upload ID
        result['upload_id'] = result['upload_date'].astype(str) + ' - ' + result['USER_ID']
        
        return result
        
    except Exception as e:
        st.error(f"Error loading forecast evolution data: {str(e)}")
        import traceback
        st.code(traceback.format_exc())
        return pd.DataFrame()


def load_most_recent_forecast(vendor_number: str) -> pd.DataFrame:
    """
    Load the most recent forecast snapshot for a vendor to enable Forward-Looking Analysis
    in "View Historical" mode without requiring a CSV upload.
    
    IMPORTANT: This function now filters by BOTH snapshot_id AND vendor_number to handle
    multi-vendor CSV uploads correctly - ensuring only SKUs for the requested vendor are returned.
    
    Args:
        vendor_number: Vendor to load forecast for
        
    Returns:
        DataFrame structured like master_dataset with most recent forecast data
    """
    try:
        session = snowflake_get_active_session()
        
        # Get the most recent snapshot for this vendor
        # FIXED: Now joins on BOTH snapshot_id AND vendor_number to prevent pulling 
        # SKUs from other vendors when a multi-vendor CSV was uploaded
        query = f"""
        WITH latest_snapshot AS (
            SELECT 
                snapshot_id,
                snapshot_date,
                upload_timestamp,
                upload_mode,
                historical_snapshot_date
            FROM EDLDB.SC_SANDBOX.FORECAST_RECONCILIATION_SNAPSHOTS
            WHERE vendor_number = '{vendor_number}'
            ORDER BY upload_timestamp DESC
            LIMIT 1
        )
        SELECT 
            f.vendor_number,
            f.chewy_sku,
            f.vendor_sku,
            f.product_name,
            f.brand_name,
            f.mc1_category,
            f.mc2_category,
            f.forecast_period_start,
            f.forecast_period_end,
            f.period_name,
            f.vendor_forecast_units,
            f.chewy_forecast_units,
            f.yoy_actual_units,
            f.snapshot_date,
            f.upload_timestamp,
            f.upload_mode,
            f.historical_snapshot_date
        FROM EDLDB.SC_SANDBOX.FORECAST_RECONCILIATION_SNAPSHOTS f
        INNER JOIN latest_snapshot ls 
            ON f.snapshot_id = ls.snapshot_id
            AND f.vendor_number = '{vendor_number}'  -- CRITICAL: Filter by vendor to prevent cross-vendor pollution
        ORDER BY f.forecast_period_start, f.chewy_sku
        """
        
        result = session.sql(query).to_pandas()
        
        if result.empty:
            return pd.DataFrame()
        
        # Normalize column names to match master_dataset structure
        # Snowflake returns uppercase column names, but master_dataset uses lowercase/mixed case
        column_mapping = {
            'VENDOR_NUMBER': 'vendor_number',
            'CHEWY_SKU': 'chewy_sku',
            'VENDOR_SKU': 'vendor_sku',
            'PRODUCT_NAME': 'PRODUCT_NAME',  # Keep uppercase for display columns
            'BRAND_NAME': 'BRAND_NAME',
            'MC1_CATEGORY': 'MC1_CATEGORY',
            'MC2_CATEGORY': 'MC2_CATEGORY',
            'FORECAST_PERIOD_START': 'period_start_date',
            'FORECAST_PERIOD_END': 'period_end_date',
            'PERIOD_NAME': 'period_name',
            'VENDOR_FORECAST_UNITS': 'vendor_forecast_units',
            'CHEWY_FORECAST_UNITS': 'chewy_forecast_units',
            'YOY_ACTUAL_UNITS': 'yoy_actual_units',
            'SNAPSHOT_DATE': 'SNAPSHOT_DATE',
            'UPLOAD_TIMESTAMP': 'UPLOAD_TIMESTAMP',
            'UPLOAD_MODE': 'UPLOAD_MODE',
            'HISTORICAL_SNAPSHOT_DATE': 'HISTORICAL_SNAPSHOT_DATE'
        }
        
        result = result.rename(columns=column_mapping)
        
        # Store snapshot metadata in session state for display
        st.session_state['loaded_snapshot_date'] = result['SNAPSHOT_DATE'].iloc[0]
        st.session_state['loaded_upload_timestamp'] = result['UPLOAD_TIMESTAMP'].iloc[0]
        
        # Debug: Check YoY data loaded from snapshot
        total_yoy = result['yoy_actual_units'].sum()
        st.info(f"📊 Loaded forecast snapshot with {len(result):,} records and {total_yoy:,.0f} total YoY units")
        
        # Note: If YoY is 0, this snapshot was saved before YoY data collection was enabled.
        # Re-upload the historical forecast to capture YoY data for future viewing.
        if total_yoy == 0:
            st.warning("⚠️ **Note:** This snapshot has no YoY data (saved before YoY collection was enabled). "
                      "To view YoY analysis, re-upload this historical forecast - YoY data will be captured and saved.")
        
        return result
        
    except Exception as e:
        st.error(f"Error loading most recent forecast: {str(e)}")
        import traceback
        st.code(traceback.format_exc())
        return pd.DataFrame()


def get_historical_accuracy_data(vendor_number: str = None, lookback_periods: int = 12) -> List[Dict]:
    """
    Get historical forecast data for accuracy analysis using "Latest Wins" approach.
    For each vendor/period combination, returns only the most recent upload.
    
    This function is now period-type agnostic - it gets exact period boundaries from 
    saved forecast data and uses those for actuals aggregation, working perfectly 
    with Month, Custom, or any other period type.
    
    Args:
        vendor_number: Specific vendor to analyze (None for all vendors)
        lookback_periods: Number of periods to look back
        
    Returns:
        List of dictionaries with forecast and actual data for accuracy calculations
    """
    try:
        session = snowflake_get_active_session()
        
        # Build vendor filter
        vendor_filter = f"AND vendor_number = '{vendor_number}'" if vendor_number else ""
        
        # STEP 1: Get available historical periods using period-aware logic
        import streamlit as st
        
        # First, get all available periods for this vendor (with exact boundaries)
        # Use ROW_NUMBER to get one representative record per unique period
        periods_query = f"""
        WITH distinct_periods AS (
            SELECT 
                forecast_period_start,
                forecast_period_end,
                period_name,
                period_type,
                upload_timestamp,
                historical_snapshot_date,
                upload_mode,
                ROW_NUMBER() OVER (
                    PARTITION BY forecast_period_start, forecast_period_end 
                    ORDER BY upload_timestamp DESC
                ) as rn
            FROM EDLDB.SC_SANDBOX.FORECAST_RECONCILIATION_SNAPSHOTS
            WHERE forecast_period_end < CURRENT_DATE()  -- Only fully completed periods (period must have ended)
            {vendor_filter}
        )
        SELECT 
            forecast_period_start,
            forecast_period_end,
            period_name,
            period_type,
            upload_timestamp,
            historical_snapshot_date,
            upload_mode
        FROM distinct_periods 
        WHERE rn = 1
        ORDER BY forecast_period_start DESC
        """
        
        periods_result = session.sql(periods_query).collect()
        
        if not periods_result:
            st.warning(f"No historical forecast data found for vendor {vendor_number}")
            return []
        
        # Convert to list and apply lookback limit
        available_periods = []
        for row in periods_result:
            available_periods.append({
                'period_start': row['FORECAST_PERIOD_START'],
                'period_end': row['FORECAST_PERIOD_END'], 
                'period_name': row['PERIOD_NAME'],
                'period_type': row['PERIOD_TYPE'],
                'upload_timestamp': row['UPLOAD_TIMESTAMP'],
                'historical_snapshot_date': row['HISTORICAL_SNAPSHOT_DATE'],
                'upload_mode': row['UPLOAD_MODE']
            })
        
        # Apply lookback limit (take most recent N periods)
        selected_periods = available_periods[:lookback_periods]
        
        # Debug: Show period-aware parameters
        if st.session_state.get('debug_mode', False):
            with st.expander("🔍 Debug - Period-Aware Historical Query Parameters", expanded=True):
                st.write(f"**Query Parameters:**")
                st.write(f"  vendor_number: {vendor_number}")
                st.write(f"  lookback_periods: {lookback_periods}")
                st.write(f"  vendor_filter: {vendor_filter}")
                st.write(f"  **Date Filter**: Only periods with forecast_period_end < CURRENT_DATE() (fully completed periods only)")
                st.write(f"")
                st.write(f"**Available Past Periods Found:** {len(available_periods)}")
                st.write(f"**Selected Periods (Last {lookback_periods}):** {len(selected_periods)}")
                st.write(f"")
                st.write(f"**Selected Period Details:**")
                for i, period in enumerate(selected_periods):
                    st.write(f"  {i+1}. {period['period_name']}: {period['period_start']} to {period['period_end']} ({period['period_type']})")
        
        if not selected_periods:
            st.warning("No periods selected for analysis")
            return []
        
        # STEP 2: Get forecasts and actuals using period-aware approach (same as Forward-Looking)
        all_accuracy_data = []
        
        # Process each period separately (same approach as get_chewy_forecasts_aggregated)
