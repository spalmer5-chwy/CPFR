        )
        
        SELECT 
            field, product_name, cut, bo_contribution,
            BO_{trailing_weeks_suffix},
            {weekly_column_refs_without_aggregate}
        FROM final_result
    """
    
    return query, column_mapping


def generate_weekly_nop_columns(week_dates):
    """Generate weekly NOP column SQL and column mapping"""
    column_sql_parts = []
    column_mapping = {}
    
    for i, week_start in enumerate(week_dates, 1):
        # Handle date format conversion
        if isinstance(week_start, str):
            week_start = datetime.strptime(week_start, '%m/%d/%Y').date()
        
        week_start_str = week_start.strftime('%Y-%m-%d')
        
        # Generate SQL for each week's metrics
        # NOP Rate: non-optimal units / total demand units for that week
        nop_rate_sql = f"""
                SUM(CASE 
                    WHEN tier <> 1 AND DATE_TRUNC('week',snapshot_date) = DATE_TRUNC('week','{week_start_str}'::date) 
                    THEN n_units 
                    ELSE 0 
                END) / NULLIFZERO(SUM(CASE 
                    WHEN DATE_TRUNC('week',snapshot_date) = DATE_TRUNC('week','{week_start_str}'::date) 
                    THEN n_units 
                    ELSE 0 
                END)) AS W{i}_NOP"""
        
        # Non-optimal demand units for that week
        non_opt_units_sql = f"""
                SUM(CASE 
                    WHEN tier <> 1 AND DATE_TRUNC('week',snapshot_date) = DATE_TRUNC('week','{week_start_str}'::date) 
                    THEN n_units 
                    ELSE 0 
                END) AS W{i}_NON_OPT_UNITS"""
        
        # Total demand units for that week  
        total_units_sql = f"""
                SUM(CASE 
                    WHEN DATE_TRUNC('week',snapshot_date) = DATE_TRUNC('week','{week_start_str}'::date) 
                    THEN n_units 
                    ELSE 0 
                END) AS W{i}_TOTAL_UNITS"""
        
        column_sql_parts.extend([nop_rate_sql, non_opt_units_sql, total_units_sql])
        
        # Create column mapping for display names
        week_display = week_start.strftime('%m/%d')
        column_mapping[f'W{i}_NOP'] = f'{week_display}_NOP'
        column_mapping[f'W{i}_NON_OPT_UNITS'] = f'{week_display}_NON_OPT_UNITS'  
        column_mapping[f'W{i}_TOTAL_UNITS'] = f'{week_display}_TOTAL_UNITS'
    
    # Add aggregate NOP column for the entire timeframe
    weeks_back = len(week_dates)
    trailing_weeks_suffix = f"T{weeks_back}W"
    
    # Convert week dates to SQL format for aggregate calculation
    earliest_week_date = week_dates[-1] if isinstance(week_dates[-1], str) else week_dates[-1].strftime('%m/%d/%Y')
    latest_week_date = week_dates[0] if isinstance(week_dates[0], str) else week_dates[0].strftime('%m/%d/%Y')
    
    earliest_week_sql = datetime.strptime(earliest_week_date, '%m/%d/%Y').strftime('%Y-%m-%d')
    latest_week_sql = datetime.strptime(latest_week_date, '%m/%d/%Y').strftime('%Y-%m-%d')
    
    aggregate_nop_sql = f"""
                SUM(CASE 
                    WHEN tier <> 1 AND DATE_TRUNC('week',snapshot_date) BETWEEN DATE_TRUNC('week','{earliest_week_sql}'::date) 
                        AND DATE_TRUNC('week','{latest_week_sql}'::date)
                    THEN n_units 
                    ELSE 0 
                END) / NULLIFZERO(SUM(CASE 
                    WHEN DATE_TRUNC('week',snapshot_date) BETWEEN DATE_TRUNC('week','{earliest_week_sql}'::date) 
                        AND DATE_TRUNC('week','{latest_week_sql}'::date)
                    THEN n_units 
                    ELSE 0 
                END)) AS NOP_{trailing_weeks_suffix}"""
    
    column_sql_parts.append(aggregate_nop_sql)
    
    # Add aggregate column to mapping
    column_mapping[f"NOP_{trailing_weeks_suffix}"] = f"NOP {trailing_weeks_suffix}"
    
    return ',\n                '.join(column_sql_parts), column_mapping


def generate_nop_query(vendor_numbers, start_date, end_date, aggregation, include_dropship=False):
    """Generate NOP (Non-Optimal Placement) analysis query with dynamic timeframes"""
    from datetime import datetime, timedelta
    
    # Use the new timeframe selector (weeks_back from session state) instead of old aggregation system
    import streamlit as st
    timeframe_weeks = st.session_state.get('weeks_back', 2)  # Default to 2 weeks for backward compatibility
    
    # Calculate week dates for dynamic columns
    week_dates = calculate_week_dates(timeframe_weeks)
    
    # Get dropship filter
    dropship_filter = ""
    if not include_dropship:
        dropship_filter = "AND p.product_dropship_flag = false"
    
    # Generate weekly column SQL and mapping
    nop_columns_sql, column_mapping = generate_weekly_nop_columns(week_dates)
    
    # Calculate actual date range from the dynamic week dates (not the passed parameters)
    from datetime import datetime
    
    # Convert week_dates to datetime objects and find the range
    week_date_objects = [datetime.strptime(date, '%m/%d/%Y').date() for date in week_dates]
    
    # Use the full range: earliest week start to latest week end  
    start_date_actual = min(week_date_objects)  # Oldest week (furthest back)
    end_date_actual = max(week_date_objects)    # Most recent week
    
    # Add 6 days to end_date to include the full week (Monday to Sunday)
    from datetime import timedelta
    end_date_actual = end_date_actual + timedelta(days=6)
    
    end_date_str = end_date_actual.strftime('%Y-%m-%d') 
    start_date_str = start_date_actual.strftime('%Y-%m-%d')
    
    # Get vendor list for filtering
    vendor_list = "', '".join(vendor_numbers)
    
    query = f"""
        WITH vendor_skus AS (
            SELECT DISTINCT
                v.vendor_number as vendor_number,
                v.vendor_name as vendor_name,
                p.product_part_number as product_part_number,
                p.product_manufacturer_name
            FROM EDLDB.CHEWYBI.vendor_agreement_line vl
            LEFT JOIN edldb.chewybi.products p ON p.product_part_number = vl.product_part_number
            LEFT JOIN edldb.chewybi.vendors v ON v.vendor_number = vl.vendor_number
            WHERE CURRENT_DATE BETWEEN COALESCE(agreement_line_start_date::DATE, CURRENT_DATE)
                AND COALESCE(agreement_line_end_date::DATE, CURRENT_DATE)
                AND COALESCE(disabled_reason_code,'') = ''
                AND COALESCE(agreement_line_status,'') NOT IN ('CANCELED')
                AND v.vendor_number IN ('{vendor_list}')
        ),
        
        op_base AS (
            SELECT DISTINCT * 
            FROM (
                SELECT 
                    rpm.snapshot_date,
                    financial_calendar_reporting_quarter,
                    rpm.zip_code,
                    rpm.product_part_number,
                    tier,
                    rpm.fc as fc_picked,
                    CASE WHEN tier = 1 THEN rpm.fc ELSE frt.fc END as fc_tier1,
                    CASE WHEN tier = 1 THEN SUM(n_units) ELSE SUM(n_units)/cnt_tier1 END as n_units
                FROM sc_replenishment_sandbox.op_core rpm
                JOIN vendor_skus vs ON vs.product_part_number = rpm.product_part_number
                JOIN (
                    SELECT DISTINCT 
                        zip_code,
                        fc,
                        COUNT(fc) OVER (PARTITION BY zip_code) as cnt_tier1
                    FROM (
                        SELECT 
                            zip_code,
                            fc,
                            tier_distance
                        FROM EDLDB.SC_USER_TOOLS_ANALYTICS_SANDBOX.REPLEN_TIER_DISTANCE_SNAPSHOT
                        WHERE CURRENT_DATE BETWEEN VALID_FROM AND (CASE WHEN VALID_TILL = '2024-12-31' THEN '2025-12-31' ELSE VALID_TILL END)
                    ) abc 
                    WHERE tier_distance = 1
                ) frt ON frt.zip_code = rpm.zip_code
                JOIN EDLDB.chewybi.common_date cd ON common_date_dttm::date = rpm.snapshot_date 
                WHERE 1=1
                    AND tier_type = 'distance-based' 
                    AND tier IN (1,2,3,4,5,6,7,8)
                    AND snapshot_date BETWEEN '{start_date_str}'::date AND '{end_date_str}'::date
                GROUP BY 1,2,3,4,5,6,frt.fc,cnt_tier1
            ) comp
        ),
        
        brand_base AS (
            SELECT 
                p.product_manufacturer_name,
                {nop_columns_sql}
            FROM op_base
            JOIN EDLDB.chewybi.products p USING(product_part_number)
            WHERE p.product_company_description <> 'Chewy Canada'
                -- AND p.product_merch_classification1 = 'Cat Consumables'  -- Commented out merch class filter
