        wisp_cols = [col for col in display_data.columns if col.endswith('_WISP') or ('WISP T' in col and any(col.endswith(suffix) for suffix in ['T2W', 'T4W', 'T13W', 'T26W', 'T52W']))]
        
        # Contribution columns (should be percentages)
        contribution_cols = [col for col in display_data.columns if 'Impact Contribution' in col or 'WISP_IMPACT_CONTRIBUTION' in col]
        
        # Units columns (should be formatted as integers with commas)
        unit_cols = [col for col in display_data.columns if col.endswith('_TOTAL_UNITS') or col.endswith('_PERFECT_SALES')]
        
        # Sales columns (should be formatted as currency)
        sales_cols = [col for col in display_data.columns if col.endswith('_LOST_SALES')]
        
        # Format WISP rate columns as percentages
        for col in wisp_cols:
            if col in display_data.columns:
                def format_wisp_percentage(value):
                    try:
                        if pd.isna(value) or value is None:
                            return "0.00%"
                        # WISP values are already as ratios (0.95), so multiply by 100 for percentage
                        percentage = float(value) * 100
                        return f"{percentage:.2f}%"
                    except (ValueError, TypeError):
                        return "0.00%"
                
                display_data[col] = display_data[col].apply(format_wisp_percentage)
        
        # Format WISP Impact Contribution columns as percentages
        for col in contribution_cols:
            if col in display_data.columns:
                def format_contribution_percentage(value):
                    try:
                        if pd.isna(value) or value is None:
                            return "0.00%"
                        # Contribution values are already as ratios (0.15), so multiply by 100 for percentage
                        percentage = float(value) * 100
                        formatted = f"{percentage:.2f}%"
                        # Remove negative sign if it rounds to exactly 0.00%
                        if formatted == "-0.00%":
                            return "0.00%"
                        return formatted
                    except (ValueError, TypeError):
                        return "0.00%"
                
                display_data[col] = display_data[col].apply(format_contribution_percentage)
        
        # Format unit count columns  
        for col in unit_cols:
            if col in display_data.columns:
                def format_unit_count(value):
                    try:
                        if pd.isna(value) or value is None:
                            return "0"
                        return f"{int(float(value)):,}"
                    except (ValueError, TypeError):
                        return "0"
                
                display_data[col] = display_data[col].apply(format_unit_count)
        
        # Add total lost sales to sales columns for formatting (check both original and mapped names)
        if 'TOTAL_LOST_SALES' in display_data.columns:
            sales_cols.append('TOTAL_LOST_SALES')
        elif 'Total Lost Sales' in display_data.columns:
            sales_cols.append('Total Lost Sales')
        
        # Format lost sales dollar columns
        for col in sales_cols:
            if col in display_data.columns:
                # Helper function to format dollar amounts with conditional +/- sign
                def format_dollar_with_sign(val):
                    if pd.isna(val) or val is None:
                        return "$0"
                    try:
                        val = float(val)
                        formatted = f"${abs(val):,.0f}"
                        # If it rounds to $0, don't show + or - sign
                        if abs(val) < 0.5:  # Less than 50 cents rounds to $0
                            return "$0"
                        elif col in ['LW_LOST_SALES', 'TOTAL_LOST_SALES', 'Total Lost Sales']:  # Total and last week lost sales - show negative sign for lost revenue
                            return f"-{formatted}" if val < 0 else formatted
                        elif val >= 0:  # WOW changes - show + for increases
                            return f"+{formatted}"
                        else:  # WOW changes - show - for decreases
                            return f"-{formatted}"
                    except (ValueError, TypeError):
                        return "$0"
                
                display_data[col] = display_data[col].apply(format_dollar_with_sign)
        
        # Drop internal columns we don't want to display
        columns_to_drop = ['RN', 'PRIORITY_CUT']
        for col in columns_to_drop:
            if col in display_data.columns:
                display_data = display_data.drop(columns=[col])
        
        # Final table formatting
        # Rename Field to Product/Brand
        if 'FIELD' in display_data.columns:
            display_data = display_data.rename(columns={'FIELD': 'Product/Brand'})
        
        # Replace underscores with spaces in column names
        display_data.columns = [col.replace('_', ' ') for col in display_data.columns]
        
        # Reset index to start from 1
        display_data.reset_index(drop=True, inplace=True)
        display_data.index = display_data.index + 1
        
        # Display the formatted data
        st.dataframe(display_data, use_container_width=True)
        
        # Create WISP trend charts
        st.markdown("---")
        create_wisp_trend_charts()
        
    else:

        
        # Show what the WISP analysis will include
        st.subheader("WISP Analysis Will Include:")
        st.write("""
        **Weighted Instock Percentage Impact Categories:**
        - **Total Vendor**: WISP rates and contribution aggregated for the entire vendor
        - **MC1 (Merch Classification 1)**: WISP metrics by primary product category
        - **MC2 (Merch Classification 2)**: WISP metrics by secondary product category
        - **Top WISP Contribution**: Brands with highest instock impact (ranked by perfect sales gap)
        - **Top Item WISP Contribution**: Individual SKUs with highest WISP impact
        
        **Key Metrics:**
        - **LW WISP**: Last week's weighted instock percentage (total units / total perfect sales)
        - **WOW WISP**: Week-over-week change in WISP percentage
        - **LW Total Units**: Last week's actual units sold
        - **LW Total Perfect Sales**: Last week's potential units if 100% instock
        - **LW Lost Sales**: Last week's lost sales revenue due to stockouts (perfect sales - actual sales) × price
        - **WOW Lost Sales**: Week-over-week change in lost sales dollars
        - **Total Units Contribution**: Percentage contribution to total units
        - **WOW Unit Changes**: Week-over-week change in unit metrics
        
        **Note:** WISP measures availability weighted by demand importance. Lower WISP indicates more stockouts on high-demand items.
        """)

