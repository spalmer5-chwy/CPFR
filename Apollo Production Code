def generate_asbo_query(vendor_numbers, start_date, end_date, aggregation, include_dropship=False):
    """Generate ASBO (Autoship Back Order) analysis query with dynamic weekly columns and contribution metrics"""
    
    # Get dynamic date range from session state
    weeks_back = st.session_state.get('weeks_back', 2)  # Default to 2 weeks for backward compatibility
    week_dates = calculate_week_dates(weeks_back)
    
    # Get dropship filter
    dropship_filter = ""
    if not include_dropship:
        dropship_filter = "AND pp.product_dropship_flag = false"
    
    # Generate dynamic weekly columns for ASBO metrics
    def generate_weekly_asbo_columns(weeks_back):
        """Generate dynamic CASE statements for weekly ASBO metrics"""
        week_dates = calculate_week_dates(weeks_back)
        
        bo_columns = []
        bo_units_columns = []
        as_units_columns = []
        
        for i, week_start in enumerate(week_dates, 1):
            # Ensure week_start is a datetime.date object
            if isinstance(week_start, str):
                from datetime import datetime
                week_start = datetime.strptime(week_start, '%m/%d/%Y').date()
            week_start_str = week_start.strftime('%Y-%m-%d')
            
            # BO Rate columns - cap at 100% and handle edge cases with minimum threshold
            bo_columns.append(f"""
                CASE 
                    WHEN SUM(CASE WHEN date_trunc('week', bo.order_placed_date) = date_trunc('week', '{week_start_str}'::date) THEN bo.autoship_units ELSE 0 END) < 10 THEN 0
                    ELSE LEAST(1.0, COALESCE(
                        SUM(CASE WHEN date_trunc('week', bo.order_placed_date) = date_trunc('week', '{week_start_str}'::date) THEN bo.backorder_units ELSE 0 END) / 
                        NULLIFZERO(SUM(CASE WHEN date_trunc('week', bo.order_placed_date) = date_trunc('week', '{week_start_str}'::date) THEN bo.autoship_units ELSE 0 END)), 0))
                END as W{i}_BO""")
            
            # BO Units columns
            bo_units_columns.append(f"""
                COALESCE(SUM(CASE WHEN date_trunc('week', bo.order_placed_date) = date_trunc('week', '{week_start_str}'::date) THEN bo.backorder_units ELSE 0 END), 0) as W{i}_BO_UNITS""")
            
            # AS Units columns
            as_units_columns.append(f"""
                COALESCE(SUM(CASE WHEN date_trunc('week', bo.order_placed_date) = date_trunc('week', '{week_start_str}'::date) THEN bo.autoship_units ELSE 0 END), 0) as W{i}_AS_UNITS""")
        
        # Create combined columns in week-by-week order (like OOS)
        combined_columns = []
        for i in range(weeks_back):
            combined_columns.extend([bo_columns[i], bo_units_columns[i], as_units_columns[i]])
        
        # Add aggregate BO column for the entire timeframe
        trailing_weeks_suffix = f"T{weeks_back}W"
        earliest_week = week_dates[-1] if isinstance(week_dates[-1], str) else week_dates[-1].strftime('%m/%d/%Y')
        latest_week = week_dates[0] if isinstance(week_dates[0], str) else week_dates[0].strftime('%m/%d/%Y')
        
        # Convert to SQL date format
        from datetime import datetime
        earliest_week_sql = datetime.strptime(earliest_week, '%m/%d/%Y').strftime('%Y-%m-%d')
        latest_week_sql = datetime.strptime(latest_week, '%m/%d/%Y').strftime('%Y-%m-%d')
        
        aggregate_bo = f"""
            CASE 
                WHEN SUM(CASE WHEN date_trunc('week', bo.order_placed_date) BETWEEN date_trunc('week', '{earliest_week_sql}'::date) 
                    AND date_trunc('week', '{latest_week_sql}'::date) THEN bo.autoship_units ELSE 0 END) < 10 THEN 0
                ELSE LEAST(1.0, COALESCE(
                    SUM(CASE WHEN date_trunc('week', bo.order_placed_date) BETWEEN date_trunc('week', '{earliest_week_sql}'::date) 
                        AND date_trunc('week', '{latest_week_sql}'::date) THEN bo.backorder_units ELSE 0 END) / 
                    NULLIFZERO(SUM(CASE WHEN date_trunc('week', bo.order_placed_date) BETWEEN date_trunc('week', '{earliest_week_sql}'::date) 
                        AND date_trunc('week', '{latest_week_sql}'::date) THEN bo.autoship_units ELSE 0 END)), 0))
            END as BO_{trailing_weeks_suffix}"""
        
        return {
            'bo_columns': ','.join(bo_columns),
            'bo_units_columns': ','.join(bo_units_columns),
            'as_units_columns': ','.join(as_units_columns),
            'combined_columns': ','.join(combined_columns),
            'aggregate_bo': aggregate_bo
        }
    
    # Generate weekly columns
    weekly_columns = generate_weekly_asbo_columns(weeks_back)
    
    # Create column mapping for display/export (generic -> date-based names)
    column_mapping = {}
    for i, week_start in enumerate(week_dates, 1):
        # Ensure week_start is a datetime.date object
        if isinstance(week_start, str):
            from datetime import datetime
            week_start = datetime.strptime(week_start, '%m/%d/%Y').date()
        date_str = week_start.strftime('%m_%d_%Y')
        column_mapping[f'W{i}_BO'] = f'{date_str}_BO'
        column_mapping[f'W{i}_BO_UNITS'] = f'{date_str}_BO_UNITS'
        column_mapping[f'W{i}_AS_UNITS'] = f'{date_str}_AS_UNITS'
    
    # Add aggregate column mapping
    trailing_weeks_suffix = f"T{weeks_back}W"
    column_mapping[f"BO_{trailing_weeks_suffix}"] = f"BO {trailing_weeks_suffix}"
    
    # Generate generic column names list for reference in other CTEs (following OOS pattern)
    week_column_names = []
    for i in range(1, weeks_back + 1):
        week_column_names.extend([
            f"W{i}_BO",
            f"W{i}_BO_UNITS", 
            f"W{i}_AS_UNITS"
        ])
    
    # Add aggregate column to the column names list
    week_column_names.append(f"BO_{trailing_weeks_suffix}")
    
    # Create comma-separated column references for SELECT statements
    weekly_column_refs = ', '.join(week_column_names)
    
    # Create column references without the aggregate for final SELECT ordering
    weekly_column_refs_without_aggregate = ', '.join(week_column_names[:-1])  # Exclude the last item (aggregate column)
    
    # Get date range for WHERE clause
    # Ensure dates are datetime.date objects
    earliest_date = week_dates[-1]  # Last item is earliest date
    latest_date = week_dates[0]  # First item is latest week start
    
    if isinstance(earliest_date, str):
        from datetime import datetime
        earliest_date = datetime.strptime(earliest_date, '%m/%d/%Y').date()
    if isinstance(latest_date, str):
        from datetime import datetime
        latest_date = datetime.strptime(latest_date, '%m/%d/%Y').date()
    
    latest_date = latest_date + timedelta(days=6)  # Add 6 days for end of week
    
    # Get vendor list for filtering (removed circular SKU dependency)
    vendor_list = "', '".join(vendor_numbers)
    
    query = f"""
        WITH vendor_skus AS (
            SELECT DISTINCT
                v.vendor_number as vendor_number,
                v.vendor_name as vendor_name,
                p.product_part_number as product_part_number,
                p.product_manufacturer_name
            FROM EDLDB.CHEWYBI.vendor_agreement_line vl
            LEFT JOIN edldb.chewybi.products p ON p.product_part_number = vl.product_part_number
            LEFT JOIN edldb.chewybi.vendors v ON v.vendor_number = vl.vendor_number
            WHERE CURRENT_DATE BETWEEN COALESCE(agreement_line_start_date::DATE, CURRENT_DATE)
                AND COALESCE(agreement_line_end_date::DATE, CURRENT_DATE)
