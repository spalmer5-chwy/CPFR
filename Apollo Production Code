            forecast_query = f"""
            WITH latest_forecasts AS (
                SELECT 
                    *,
                    ROW_NUMBER() OVER (
                        PARTITION BY vendor_number, chewy_sku, forecast_period_start, forecast_period_end 
                        ORDER BY 
                            CASE 
