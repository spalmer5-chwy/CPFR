def save_feedback_to_excel(feedback_data):
    """Save feedback data to Excel spreadsheet in Snowflake"""
    try:
        session = get_snowflake_session()
        if session is None:
            return False
        

        
        # Using your personal sandbox schema
        table_name = "EDLDB.SC_SANDBOX.APOLLO_FEEDBACK"
        
        # Create table with proper column sizes (only if it doesn't exist)
        create_table_sql = f"""
        CREATE TABLE IF NOT EXISTS {table_name} (
            FEEDBACK_ID VARCHAR(50),
            TIMESTAMP TIMESTAMP_NTZ,
            FEEDBACK_TYPE VARCHAR(50),
            SEVERITY VARCHAR(100),
            SUBJECT VARCHAR(500),
            DESCRIPTION TEXT,
            CONTACT_INFO VARCHAR(200),
            VENDOR_NUMBERS VARCHAR(500),
            SESSION_REGION VARCHAR(100)
        )
        """
        session.sql(create_table_sql).collect()
        
        # Insert data using direct SQL (more reliable)
        insert_sql = f"""
        INSERT INTO {table_name} (
            FEEDBACK_ID, TIMESTAMP, FEEDBACK_TYPE, SEVERITY, SUBJECT, 
            DESCRIPTION, CONTACT_INFO, VENDOR_NUMBERS, SESSION_REGION
        ) VALUES (
            '{feedback_data['FEEDBACK_ID']}',
            '{feedback_data['TIMESTAMP']}',
            '{feedback_data['FEEDBACK_TYPE']}',
            '{feedback_data['SEVERITY']}',
            '{feedback_data['SUBJECT'].replace("'", "''")}',
            '{feedback_data['DESCRIPTION'].replace("'", "''")}',
            '{feedback_data['CONTACT_INFO']}',
            '{feedback_data['VENDOR_NUMBERS']}',
            '{feedback_data['SESSION_REGION']}'
        )
        """
        
        # Execute insert
        session.sql(insert_sql).collect()
        
        # Explicitly commit the transaction to make data visible to other sessions
        session.sql("COMMIT").collect()
        
        return True
    except Exception as e:
        
        st.error(f"Error saving feedback: {str(e)}")
        return False

