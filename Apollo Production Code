                        # Run raw data dump query
                        fillrate_raw_data = session.sql(raw_data_query).to_pandas()
                        
                        
                        fillrate_duration = int((time.time() - fillrate_start_time) * 1000)
                        
                        # Track query execution
                        track_query_execution("Fill Rate Analysis", vendor_numbers, start_date, end_date, region, fillrate_duration, len(fillrate_data))
                        
                        if not fillrate_data.empty:
                            # Store both datasets in session state
                            st.session_state['fillrate_data'] = fillrate_data
                            st.session_state['fillrate_column_mapping'] = column_mapping
                            st.session_state['fillrate_raw_data'] = fillrate_raw_data
                            
                            # Trigger rerun to show download buttons
                            st.rerun()
                            
                        else:
                            st.warning("No Fill Rate data found for the selected criteria.")
                        
                except Exception as e:
