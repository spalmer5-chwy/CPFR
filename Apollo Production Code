        # Helper function to convert Decimal strings to float
        def convert_decimal_string(val):
            if pd.isna(val):
                return None
            if isinstance(val, str) and val.startswith("Decimal('") and val.endswith("')"):
                # Extract the number from "Decimal('0.123456')" format
                decimal_str = val[9:-2]  # Remove "Decimal('" and "')"
                return float(decimal_str)
            return float(val) if val is not None else None
        
        # Remove cut_priority column from display (check for uppercase)
        if 'CUT_PRIORITY' in display_data.columns:
            display_data = display_data.drop('CUT_PRIORITY', axis=1)
        
        # Helper function to format percentage with conditional +/- sign
        def format_percentage_with_sign(val):
            if val is None:
                return "N/A"
            converted_val = convert_decimal_string(val)
            if converted_val is None:
                return "N/A"
            formatted = f"{converted_val:.2%}"
            # If it rounds to 0.00%, don't show + or - sign
            if formatted == "0.00%":
                return "0.00%"
            elif converted_val >= 0:
                return f"+{formatted}"
            else:
                return formatted  # negative sign is already included
        
        # Format OOS percentage columns with 2 decimal places
        if 'LW_OOS' in display_data.columns:
            display_data['LW_OOS'] = display_data['LW_OOS'].apply(
                lambda x: f"{convert_decimal_string(x):.2%}" if convert_decimal_string(x) is not None else "N/A"
            )
        if 'WOW_OOS' in display_data.columns:
            display_data['WOW_OOS'] = display_data['WOW_OOS'].apply(format_percentage_with_sign)
        
        # Format backorder (BO) percentage columns with 2 decimal places
        if 'LW_BACKORDER' in display_data.columns:
            display_data['LW_BACKORDER'] = display_data['LW_BACKORDER'].apply(
                lambda x: f"{convert_decimal_string(x):.2%}" if convert_decimal_string(x) is not None else "N/A"
            )
        if 'WOW_BACKORDER' in display_data.columns:
            display_data['WOW_BACKORDER'] = display_data['WOW_BACKORDER'].apply(format_percentage_with_sign)
        
        # Format optimal placement (OP) percentage columns with 2 decimal places
        if 'LW_OP' in display_data.columns:
            display_data['LW_OP'] = display_data['LW_OP'].apply(
                lambda x: f"{convert_decimal_string(x):.2%}" if convert_decimal_string(x) is not None else "N/A"
            )
        if 'WOW_OP' in display_data.columns:
            display_data['WOW_OP'] = display_data['WOW_OP'].apply(format_percentage_with_sign)
        
        # Helper function to format dollar amounts with conditional +/- sign
        def format_dollar_with_sign(val):
            if pd.isna(val) or val is None:
                return "N/A"
            formatted = f"${abs(val):,.0f}"
            # If it rounds to $0, don't show + or - sign
            if abs(val) < 0.5:  # Less than 50 cents rounds to $0
                return "$0"
            elif val >= 0:
                return f"+{formatted}"
            else:
                return f"-{formatted}"
        
        # Format inventory dollar columns as US currency (rounded to whole dollars)
        if 'LW_INV_DOLLARS' in display_data.columns:
            display_data['LW_INV_DOLLARS'] = display_data['LW_INV_DOLLARS'].apply(lambda x: f"${x:,.0f}" if pd.notnull(x) else "N/A")
        if 'WOW_INV_DOLLARS' in display_data.columns:
            display_data['WOW_INV_DOLLARS'] = display_data['WOW_INV_DOLLARS'].apply(format_dollar_with_sign)
        
        # Final table formatting
        # 1. Rename Field1 to Aggregate
        if 'FIELD1' in display_data.columns:
            display_data = display_data.rename(columns={'FIELD1': 'Aggregate'})
        
        # 2. Replace all underscores with spaces in column names
