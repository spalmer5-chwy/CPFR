def generate_vendor_foundation_query(vendor_numbers, start_date, end_date):
    """Generate the optimized foundation query with vendor_skus CTE for ISM data"""
    
    # Convert vendor numbers list to SQL IN clause
    vendor_list = "', '".join(vendor_numbers)
    
    query = f"""
    WITH
    -- Vendor SKUs filter - feed this into all subsequent CTEs
    vendor_skus AS (
        SELECT DISTINCT
            v.vendor_number,
            v.vendor_name,
            v.vendor_purchaser_code as ISM,
            p.product_part_number,
            vl.vendor_product_part_number,
            p.product_key,
            p.product_abc_code,
            p.product_name,
            p.parent_company,
            p.product_merch_classification1,
            p.product_merch_classification2,
            p.product_category_level1,
            p.product_category_level2,
            p.product_category_level3,
            p.product_manufacturer_name,
            p.last_direct_unit_cost
        FROM EDLDB.CHEWYBI.vendor_agreement_line vl
        LEFT JOIN edldb.chewybi.products p ON p.product_part_number = vl.product_part_number
        LEFT JOIN edldb.chewybi.vendors v ON v.vendor_number = vl.vendor_number
        WHERE CURRENT_DATE BETWEEN COALESCE(agreement_line_start_date::DATE, CURRENT_DATE)
            AND COALESCE(agreement_line_end_date::DATE, CURRENT_DATE)
            AND COALESCE(disabled_reason_code,'') = ''
            AND COALESCE(agreement_line_status,'') NOT IN ('CANCELED')
            AND v.vendor_number IN ('{vendor_list}')
    ),
    
    -- Extract active supplier locations (filtered by vendor_skus)
    supplier_location AS (
        SELECT
            vs.vendor_number,
            vl.location_code,
            MAX(vl.vendor_status) AS vendor_location_status,
            MAX(vl.vendor_lead_time_business_days) AS vendor_lead_time_business_days
        FROM vendor_skus vs
        JOIN EDLDB.CHEWYBI.VENDOR_LOCATION vl ON vs.vendor_number = vl.vendor_number
        WHERE vl.snapshot_date >= CURRENT_DATE - 1
          AND vl.vendor_status = 'Enabled'
        GROUP BY vs.vendor_number, vl.location_code
    ),

    -- UOM conversion (filtered by vendor_skus)
    item_uom_conversion AS (
        SELECT
            vs.product_part_number as item_id,
            MAX(CASE WHEN iuom."CODE" = 'LA' THEN iuom."QTY_ PER UNIT OF MEASURE" END) AS la_uom_rate,
            MAX(CASE WHEN iuom."CODE" = 'PA' THEN iuom."QTY_ PER UNIT OF MEASURE" END) AS pa_uom_rate,
            MAX(CASE WHEN iuom."CODE" = 'CS' THEN iuom."QTY_ PER UNIT OF MEASURE" END) AS cs_uom_rate
        FROM vendor_skus vs
        JOIN EDLDB.chewybi.item_unit_of_measure iuom ON iuom."ITEM NO_" = vs.product_part_number
        WHERE iuom."CODE" IN ('LA', 'PA', 'CS')
        GROUP BY vs.product_part_number
    ),

    -- Vendor agreements with pricing (filtered by vendor_skus)
    vendor_agreements AS (
        SELECT
            vs.vendor_number,
            vs.product_part_number,
            val.vendor_purchase_price,
            val.VENDOR_UOM,
            val.VENDOR_PRODUCT_PART_NUMBER,
            COALESCE(iuom."QTY_ PER UNIT OF MEASURE",1) AS qty_per_uom,
            val.PRODUCT_VENDOR_MINIMUM_ORDER_QUANTITY,
            val.PRODUCT_VENDOR_ORDER_MULTIPLE,
            val.PRODUCT_VENDOR_MINIMUM_ORDER_QUANTITY * COALESCE(iuom."QTY_ PER UNIT OF MEASURE",1) AS chewy_moq,
            val.PRODUCT_VENDOR_ORDER_MULTIPLE * COALESCE(iuom."QTY_ PER UNIT OF MEASURE",1) AS chewy_order_multiple
        FROM vendor_skus vs
        JOIN EDLDB.CHEWYBI.vendor_agreement_line val ON val.vendor_number = vs.vendor_number 
            AND val.product_part_number = vs.product_part_number
        LEFT JOIN EDLDB.CHEWYBI.ITEM_UNIT_OF_MEASURE iuom
            ON iuom."ITEM NO_" = val.product_part_number
           AND iuom."CODE" = val.VENDOR_UOM
        WHERE CURRENT_DATE BETWEEN COALESCE(val.agreement_line_start_date::DATE, CURRENT_DATE)
                              AND COALESCE(val.agreement_line_end_date::DATE, CURRENT_DATE)
          AND COALESCE(val.disabled_reason_code,'') = ''
          AND COALESCE(val.agreement_line_status,'') NOT IN ('CANCELED')
    ),

    -- Active assortment items (filtered by vendor_skus)
    assortment_items AS (
        SELECT vs.product_part_number as item_id, mai.location_cd
        FROM vendor_skus vs
        JOIN EDLDB.CHEWYBI.MERCURY_ASSORTMENT_ITEMS mai ON mai.item_id = vs.product_part_number
        WHERE mai.active_ind = TRUE
    ),

    -- Vendors (filtered by vendor_skus)
    vendors AS (
        SELECT vs.vendor_number, v.vendor_distribution_method
        FROM vendor_skus vs
        JOIN EDLDB.CHEWYBI.VENDORS v ON v.vendor_number = vs.vendor_number
    ),

    -- Active products (filtered by vendor_skus)
    products AS (
        SELECT vs.*, p.product_discontinued_flag, p.product_status, p.product_company_description
        FROM vendor_skus vs
        JOIN EDLDB.chewybi.products p ON p.product_part_number = vs.product_part_number
        WHERE p.product_discontinued_flag = FALSE
    ),

    -- Replacement for temp_item_vendor (now filtered)
    temp_item_vendor AS (
        SELECT
            product_part_number,
            vendor_number AS supplier_code,
            location_code,
            VENDOR_PRODUCT_PART_NUMBER,
            qty_per_uom AS uom_quantity,
            CURRENT_DATE AS snapshot_date,
            vendor_location_status AS product_vendor_location_disabled_flag,
            vendor_distribution_method AS distribution_method,
            vendor_lead_time_business_days,
            la_uom_rate,
            pa_uom_rate,
            cs_uom_rate,
            VENDOR_UOM,
            PRODUCT_VENDOR_MINIMUM_ORDER_QUANTITY,
            PRODUCT_VENDOR_ORDER_MULTIPLE,
            vendor_purchase_price
        FROM (
            SELECT
                sl.vendor_number,
                va.product_part_number,
                sl.location_code,
                v.vendor_distribution_method,
                va.VENDOR_PRODUCT_PART_NUMBER,
                va.qty_per_uom,
                sl.vendor_location_status,
                sl.vendor_lead_time_business_days,
                iuc.la_uom_rate,
                iuc.pa_uom_rate,
                iuc.cs_uom_rate,
                va.VENDOR_UOM,
                va.PRODUCT_VENDOR_MINIMUM_ORDER_QUANTITY,
                va.PRODUCT_VENDOR_ORDER_MULTIPLE,
                va.vendor_purchase_price,
                ROW_NUMBER() OVER (
                    PARTITION BY va.product_part_number
                    ORDER BY
                        CASE
                            WHEN v.vendor_distribution_method = 'DIRECT' THEN 1
                            WHEN v.vendor_distribution_method IN ('CROSS-DOCK', 'DROP-SHIP') THEN 2
                            WHEN v.vendor_distribution_method = 'DISTRIBUTOR' THEN 3
                        END,
                        va.vendor_purchase_price ASC,
                        sl.vendor_lead_time_business_days ASC,
                        v.vendor_number ASC
                ) AS rnk
            FROM supplier_location sl
            JOIN vendor_agreements va
                ON va.vendor_number = sl.vendor_number
            JOIN assortment_items ai
                ON va.product_part_number = ai.item_id
               AND sl.location_code = ai.location_cd
            JOIN vendors v
                ON v.vendor_number = va.vendor_number
            JOIN products p
                ON p.product_part_number = va.product_part_number
            JOIN item_uom_conversion iuc
                ON iuc.item_id = p.product_part_number
        )
        WHERE rnk = 1
    ),

    -- Temporary disables (filtered by vendor_skus)
    Tempd AS (
        SELECT DISTINCT
            vs.product_part_number,
            ac.agreement_line_availability_date AS "Temp Disable"
        FROM vendor_skus vs
        JOIN chewybi.vendor_agreement_line_pharmacy ac ON ac.product_part_number = vs.product_part_number
        WHERE ac.agreement_line_end_date IS NULL
          AND ac.agreement_line_availability_date IS NOT NULL
          AND ac.agreement_line_availability_date > CURRENT_DATE
    ),

    -- Product base info (filtered by vendor_skus)
    a AS (
        SELECT
            vs.product_part_number AS SKU,
            vs.product_name AS Description,
            vs.parent_company AS "Parent Company",
            p.product_published_flag AS "Published Y/N",
            p.product_discontinued_flag AS "Discontinued Y/N",
            p.product_gtin AS UPC,
            p.product_unit_of_measure AS "Base UOM Code",
            vs.product_abc_code AS "ABC Code",
            p.product_warehouse_packaged_weight AS "Gross Unit Weight",
            p.product_warehouse_packaged_length AS "Unit Length",
            p.product_warehouse_packaged_width AS "Unit Width",
            p.product_warehouse_packaged_height AS "Unit Height",
            ROW_NUMBER() OVER (PARTITION BY vs.product_part_number ORDER BY vs.product_part_number) AS RowNum
        FROM vendor_skus vs
        JOIN chewybi.products p ON p.product_part_number = vs.product_part_number
        WHERE p.product_status = 'Active'
          AND p.product_company_description = 'Chewy'
    ),

    -- Vendor linkage (now pre-filtered)
    l AS (
        SELECT
            tiv.product_part_number AS ITEM,
            tiv.supplier_code,
            tiv.PRODUCT_VENDOR_ORDER_MULTIPLE AS "Order Multiple",
            tiv.VENDOR_UOM AS "Purchase UOM Code",
            tiv.uom_quantity AS "Eaches Per Purchase UOM",
            tiv.cs_uom_rate AS "Eaches per Case",
            tiv.la_uom_rate AS "Eaches per Layer",
            tiv.pa_uom_rate AS "Eaches per Pallet",
            tiv.PRODUCT_VENDOR_MINIMUM_ORDER_QUANTITY AS MOQ,
            tiv.VENDOR_PRODUCT_PART_NUMBER AS "VPN",
            tiv.vendor_purchase_price AS "Cost",
            1 AS RowNum
        FROM temp_item_vendor tiv
        WHERE tiv.distribution_method = 'DIRECT'
    ),

    -- Forecast (filtered by vendor_skus)
    Forecast AS (
        SELECT
            vs.product_part_number AS PRODUCT_PART_NUMBER,
            ROUND(SUM(arg.FCST_QTY::FLOAT), 1) AS Forecast
        FROM vendor_skus vs
        JOIN edldb.sc_sandbox.blended_fcst_item_day_network_colt arg ON arg.PRODUCT_PART_NUMBER = vs.product_part_number
        JOIN chewybi.products prod ON arg.PRODUCT_PART_NUMBER = prod.PRODUCT_PART_NUMBER
        WHERE arg.SNAPSHOT_DATE = (
                  SELECT MAX(SNAPSHOT_DATE)
                  FROM edldb.sc_sandbox.blended_fcst_item_day_network_colt
              )
          AND arg.FORECAST_DATE BETWEEN CURRENT_DATE AND CURRENT_DATE + 29
          AND prod.PRODUCT_COMPANY_DESCRIPTION = 'Chewy'
        GROUP BY vs.product_part_number
    ),

    -- Final query prep with all classification data joined
    final_query AS (
        SELECT
            a.SKU,
            COALESCE(l."VPN", '') AS "VPN",
            a.Description,
            l.supplier_code,
            a."ABC Code",
            a."Parent Company",
            -- Get classification data directly from vendor_skus join
            vs.ISM,
            vs.product_merch_classification1 as MC1,
            vs.product_merch_classification2 as MC2,
            vs.product_category_level1 as "Category Level 1",
            vs.product_category_level2 as "Category Level 2",
            vs.product_category_level3 as "Category Level 3",
            vs.product_manufacturer_name as Brand,
            a.UPC,
            a."Published Y/N",
            a."Discontinued Y/N",
            COALESCE(l."Order Multiple", 0) AS "Order Multiple",
            COALESCE(l.MOQ, 0) AS MOQ,
            COALESCE(l."Order Multiple", 0)*COALESCE(l."Eaches Per Purchase UOM", 0) AS "Order Multiple Base UOM",
            COALESCE(l.MOQ, 0)*COALESCE(l."Eaches Per Purchase UOM", 0) AS "MOQ Base UOM",
            CASE WHEN COALESCE(l."Order Multiple", 0) > COALESCE(l.MOQ, 0) THEN true ELSE false END AS "Is OM > MOQ",
            COALESCE(l."Purchase UOM Code", '') AS "Purchase UOM Code",
            a."Base UOM Code",
            COALESCE(l."Eaches Per Purchase UOM", 0) AS "Eaches Per Purchase UOM",
            COALESCE(l."Eaches per Case", 0) AS "Eaches per Case",
            COALESCE(l."Eaches per Layer", 0) AS "Eaches per Layer",
            COALESCE(l."Eaches per Pallet", 0) AS "Eaches per Pallet",
            l."Cost",
            a."Gross Unit Weight",
            a."Unit Length",
            a."Unit Width",
            a."Unit Height",
            CASE WHEN l.MOQ = 0 THEN NULL ELSE COALESCE(l."Eaches per Pallet", 0) / l.MOQ END AS "Is Pallet divisible by MOQ (whole number y/n)",
            CASE WHEN l."Eaches per Layer" = 0 THEN NULL ELSE COALESCE(l."Eaches per Pallet", 0) / l."Eaches per Layer" END AS "Is Pallet divisible by Layers (whole number y/n)",
            ROUND(
                CASE WHEN COALESCE(Forecast.Forecast, 0) <> 0
                     THEN (COALESCE(l.MOQ, 0)*COALESCE(l."Eaches Per Purchase UOM", 0)) / (COALESCE(Forecast.Forecast, 0) / 29)
                     ELSE 0 END, 0) AS "Days of Supply",
            Tempd."Temp Disable",
            ROW_NUMBER() OVER (PARTITION BY a.SKU ORDER BY a.SKU) AS rn
        FROM a
        LEFT JOIN l ON a.SKU = l.ITEM AND a.RowNum = l.RowNum
        LEFT JOIN Forecast ON a.SKU = Forecast.product_part_number
        LEFT JOIN Tempd ON a.SKU = Tempd.product_part_number
        LEFT JOIN vendor_skus vs ON vs.product_part_number = a.SKU
    )

    -- Final select (no vendor filtering needed - already done at the top)
    SELECT
        SKU as "SKU",
        "VPN" as "Vendor SKU",
        UPC,
        supplier_code as "Vendor Number",
        Description,
        "ABC Code" as "Velocity Code",
        "Parent Company",
        -- Classification columns now come directly from final_query
        ISM as "ISM",
        MC1 as "MC1",
        MC2 as "MC2",
        "Category Level 1",
        "Category Level 2", 
        "Category Level 3",
        Brand as "Brand",
        MOQ,
        "Order Multiple",
        "Base UOM Code",
        "Purchase UOM Code",
        round("Eaches Per Purchase UOM", 2) as "Eaches Per Purchase UOM",
        round("Eaches per Case", 2) as "Eaches per Case",
        round("Eaches per Layer", 2) as "Eaches per Layer",
        round("Eaches per Pallet", 2) as "Eaches per Pallet",
        "Cost" as "SKU Cost",
        "Gross Unit Weight",
        "Unit Length",
        "Unit Width",
        "Unit Height",
        round("MOQ Base UOM", 2) as "MOQ Base UOM",
        round("Order Multiple Base UOM", 2) as "Order Multiple Base UOM",
        "Is OM > MOQ",
        "Published Y/N",
        "Discontinued Y/N",
        round("Is Pallet divisible by MOQ (whole number y/n)", 2) as "Is Pallet divisible by MOQ (whole number y/n)",
        round("Is Pallet divisible by Layers (whole number y/n)", 2) as "Is Pallet divisible by Layers (whole number y/n)",
        "Days of Supply",
        "Temp Disable"
    FROM final_query
    WHERE rn = 1
    """
    
    return query


def execute_vendor_foundation_query(session, vendor_numbers, start_date, end_date):
    """Execute the foundation query to get vendor and SKU data"""
    try:
        query = generate_vendor_foundation_query(vendor_numbers, start_date, end_date)
        
        # Execute query
        result = session.sql(query).collect()
        
        # Convert to DataFrame
        df = pd.DataFrame(result)
        
        if not df.empty:

            return df
        else:
            st.warning("⚠️ No data found for the specified vendor(s)")
            return None
            
    except Exception as e:
        st.error(f"❌ Error executing foundation query: {e}")
        return None

