def get_session_id():
    """Get or create a unique session ID for tracking user sessions"""
    if 'session_id' not in st.session_state:
        st.session_state.session_id = str(uuid.uuid4())
    return st.session_state.session_id

def get_user_id():
    """Get user identifier - using Streamlit's built-in user info if available"""
    try:
        # Try to get user info from Streamlit Cloud
        if hasattr(st, 'user') and st.user:
            return st.user.email
        else:
            # Fallback to session-based user ID
            if 'user_id' not in st.session_state:
                st.session_state.user_id = f"user_{str(uuid.uuid4())[:8]}"
            return st.session_state.user_id
    except:
        # Fallback to session-based user ID
        if 'user_id' not in st.session_state:
            st.session_state.user_id = f"user_{str(uuid.uuid4())[:8]}"
        return st.session_state.user_id

def log_usage_event(action_type, section_name=None, vendor_numbers=None, 
                   date_range_start=None, date_range_end=None, region=None,
                   query_duration_ms=None, error_message=None, additional_metadata=None):
    """
    Log usage events to Snowflake analytics table
    
    Args:
        action_type: 'session_start', 'section_access', 'query_run', 'export', 'chart_view', 'error'
        section_name: 'OOS', 'ASBO', 'NOP', 'Demand', 'WISP', 'Cover_Sheet'
        vendor_numbers: List or string of vendor numbers searched
        date_range_start: Start date of analysis
        date_range_end: End date of analysis  
        region: 'Chewy US' or 'Chewy Canada'
        query_duration_ms: Query execution time in milliseconds
        error_message: Error details if action_type is 'error'
        additional_metadata: Dict of additional data to store as JSON
    """
    try:
        session = get_snowflake_session()
        
        # Prepare data
        session_id = get_session_id()
        user_id = get_user_id()
        timestamp = datetime.now()
        
        # Convert vendor_numbers to string if it's a list
        if isinstance(vendor_numbers, list):
            vendor_numbers = ','.join(map(str, vendor_numbers))
        
        # For now, skip the complex JSON metadata to get basic tracking working
        # Convert additional_metadata to simple string representation
        metadata_string = str(additional_metadata) if additional_metadata else ''
        
        # Create the analytics table if it doesn't exist (append data, don't recreate)
        create_table_sql = """
        CREATE TABLE IF NOT EXISTS EDLDB.SC_SANDBOX.APOLLO_USAGE_ANALYTICS (
            session_id VARCHAR(100),
            user_id VARCHAR(200),
            timestamp TIMESTAMP_NTZ,
            action_type VARCHAR(50),
            section_name VARCHAR(50),
            vendor_numbers VARCHAR(1000),
            date_range_start DATE,
            date_range_end DATE,
            region VARCHAR(50),
            query_duration_ms INTEGER,
            error_message VARCHAR(5000),
            additional_metadata VARCHAR(5000)
        )
        """
        
        # Execute table creation (only if it doesn't exist)
        session.sql(create_table_sql).collect()
        # Insert data using direct SQL (same pattern as feedback table)
        # Escape single quotes in string fields
        safe_user_id = str(user_id).replace("'", "''") if user_id else ''
        safe_section_name = str(section_name).replace("'", "''") if section_name else ''
        safe_vendor_numbers = str(vendor_numbers).replace("'", "''") if vendor_numbers else ''
        safe_region = str(region).replace("'", "''") if region else ''
        safe_error_message = str(error_message).replace("'", "''") if error_message else ''
        # Escape metadata string for SQL
        safe_metadata = metadata_string.replace("'", "''") if metadata_string else ''
        
        insert_sql = f"""
        INSERT INTO EDLDB.SC_SANDBOX.APOLLO_USAGE_ANALYTICS (
            session_id, user_id, timestamp, action_type, section_name, vendor_numbers, 
            date_range_start, date_range_end, region, query_duration_ms, error_message, additional_metadata
        ) VALUES (
            '{session_id}',
            '{safe_user_id}',
            '{timestamp}',
            '{action_type}',
            '{safe_section_name}',
            '{safe_vendor_numbers}',
            {f"'{date_range_start}'" if date_range_start else 'NULL'},
            {f"'{date_range_end}'" if date_range_end else 'NULL'},
            '{safe_region}',
            {query_duration_ms if query_duration_ms is not None else 'NULL'},
            '{safe_error_message}',
            '{safe_metadata}'
        )
        """
        
        # Execute insert with explicit commit
        result = session.sql(insert_sql).collect()
        
        # Explicit commit to ensure data is saved
        try:
            session.sql("COMMIT").collect()
        except:
            pass  # Auto-commit handled it
        
    except Exception as e:
        # Silent failure - don't disrupt user experience
        pass

