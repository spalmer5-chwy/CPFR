def generate_oos_query(vendor_numbers, start_date, end_date, aggregation, include_dropship=False):
    """Generate Out of Stock (OOS) analysis query with weekly data based on timeframe selection"""
    
    # Get weeks_back from session state (set by timeframe selector)
    weeks_back = st.session_state.get('weeks_back', 2)  # Default to 2 weeks for backward compatibility
    
    # Calculate week dates using helper function
    week_dates = calculate_week_dates(weeks_back)
    
    # Convert week dates to SQL date format for filtering  
    week_dates_sql = [datetime.strptime(date, '%m/%d/%Y').strftime('%Y-%m-%d') for date in week_dates]
    
    # Create date range for WHERE clause (from oldest to newest week)
    start_date_str = week_dates_sql[-1]  # Oldest week (last in reverse chronological list)
    end_date_str = week_dates_sql[0]     # Newest week (first in reverse chronological list)
    
    # Generate dynamic weekly columns for OOS metrics
    def generate_weekly_oos_columns(week_dates, week_dates_sql):
        """Generate dynamic CASE statements for weekly OOS metrics using generic column names"""
        pdp_oos_columns = []
        oos_views_columns = []
        total_views_columns = []
        
        for i, (display_date, sql_date) in enumerate(zip(week_dates, week_dates_sql)):
            week_num = i + 1  # Use simple W1, W2, W3, etc.
            
            # PDP OOS Rate columns
            pdp_oos_columns.append(f"""
                COALESCE(CAST(SUM(CASE WHEN date_trunc('week', mps.activity_date) = date_trunc('week', '{sql_date}'::date) 
                    THEN mps.OutofStock_Distinct_PDP_Views ELSE 0 END) AS DECIMAL(18,10)) / 
                    NULLIFZERO(CAST(SUM(CASE WHEN date_trunc('week', mps.activity_date) = date_trunc('week', '{sql_date}'::date) 
                    THEN mps.Distinct_PDP_Views ELSE 0 END) AS DECIMAL(18,10))), 0) as W{week_num}_PDP_OOS""")
            
            # OOS Views columns  
            oos_views_columns.append(f"""
                COALESCE(SUM(CASE WHEN date_trunc('week', mps.activity_date) = date_trunc('week', '{sql_date}'::date) 
                    THEN mps.OutofStock_Distinct_PDP_Views ELSE 0 END), 0) as W{week_num}_OOS_VIEWS""")
            
            # Total Views columns
            total_views_columns.append(f"""
                COALESCE(SUM(CASE WHEN date_trunc('week', mps.activity_date) = date_trunc('week', '{sql_date}'::date) 
                    THEN mps.Distinct_PDP_Views ELSE 0 END), 0) as W{week_num}_VIEWS""")
        
        # Add aggregate PDP OOS column for the entire timeframe
        trailing_weeks_suffix = f"T{weeks_back}W"
        aggregate_pdp_oos = f"""
            COALESCE(CAST(SUM(CASE WHEN date_trunc('week', mps.activity_date) BETWEEN date_trunc('week', '{week_dates_sql[-1]}'::date) 
                AND date_trunc('week', '{week_dates_sql[0]}'::date) 
                THEN mps.OutofStock_Distinct_PDP_Views ELSE 0 END) AS DECIMAL(18,10)) / 
                NULLIFZERO(CAST(SUM(CASE WHEN date_trunc('week', mps.activity_date) BETWEEN date_trunc('week', '{week_dates_sql[-1]}'::date) 
                AND date_trunc('week', '{week_dates_sql[0]}'::date) 
                THEN mps.Distinct_PDP_Views ELSE 0 END) AS DECIMAL(18,10))), 0) as PDP_OOS_{trailing_weeks_suffix}"""
        
        return ','.join(pdp_oos_columns), ','.join(oos_views_columns), ','.join(total_views_columns), aggregate_pdp_oos
    
    # Generate dynamic column SQL
    pdp_oos_columns, oos_views_columns, total_views_columns, aggregate_pdp_oos = generate_weekly_oos_columns(week_dates, week_dates_sql)
    
    # Generate generic column names list for reference in other CTEs
    week_column_names = []
    for i in range(len(week_dates)):
        week_num = i + 1
        week_column_names.extend([
            f"W{week_num}_PDP_OOS",
            f"W{week_num}_OOS_VIEWS", 
            f"W{week_num}_VIEWS"
        ])
    
    # Add aggregate column to the column names list
    trailing_weeks_suffix = f"T{weeks_back}W"
    week_column_names.append(f"PDP_OOS_{trailing_weeks_suffix}")
    
    # Create comma-separated column references for SELECT statements
    weekly_column_refs = ', '.join(week_column_names)
    
    # Create column references without the aggregate for final SELECT ordering
    weekly_column_refs_without_aggregate = ', '.join(week_column_names[:-1])  # Exclude the last item (aggregate column)
    
    # Create mapping for display/export (generic -> date-based names)
    def create_column_mapping(week_dates):
        """Create mapping from generic column names to date-based display names"""
        mapping = {}
        for i, display_date in enumerate(week_dates):
            week_num = i + 1
            date_prefix = display_date.replace('/', '_')  # 9/15/2024 -> 9_15_2024
            mapping[f"W{week_num}_PDP_OOS"] = f"{date_prefix}_PDP_OOS"
            mapping[f"W{week_num}_OOS_VIEWS"] = f"{date_prefix}_OOS_VIEWS"
            mapping[f"W{week_num}_VIEWS"] = f"{date_prefix}_VIEWS"
        
        # Add aggregate column mapping
        trailing_weeks_suffix = f"T{weeks_back}W"
        mapping[f"PDP_OOS_{trailing_weeks_suffix}"] = f"PDP OOS {trailing_weeks_suffix}"
        
        return mapping
    
    # Store column mapping for later use in display/export functions
    column_mapping = create_column_mapping(week_dates)
    
    # Get dropship filter
    dropship_filter = get_dropship_filter(include_dropship)
    
    # Get vendor list for filtering (removed circular SKU dependency)
    vendor_list = "', '".join(vendor_numbers)
    
    query = f"""
        WITH vendor_skus AS (
            SELECT DISTINCT
                v.vendor_number as vendor_number,
                v.vendor_name as vendor_name,
                p.product_part_number as product_part_number,
                p.product_manufacturer_name
            FROM EDLDB.CHEWYBI.vendor_agreement_line vl
            LEFT JOIN edldb.chewybi.products p ON p.product_part_number = vl.product_part_number
            LEFT JOIN edldb.chewybi.vendors v ON v.vendor_number = vl.vendor_number
            WHERE CURRENT_DATE BETWEEN COALESCE(agreement_line_start_date::DATE, CURRENT_DATE)
                AND COALESCE(agreement_line_end_date::DATE, CURRENT_DATE)
                AND COALESCE(disabled_reason_code,'') = ''
                AND COALESCE(agreement_line_status,'') NOT IN ('CANCELED')
                AND v.vendor_number IN ('{vendor_list}')
        ),
        
        brand_base AS (
            SELECT 
                p.product_manufacturer_name,
                {pdp_oos_columns},
                {oos_views_columns},
                {total_views_columns},
                {aggregate_pdp_oos},
                -- Computed averages for backward compatibility with downstream CTEs
                AVG(CASE WHEN date_trunc('week', mps.activity_date) BETWEEN date_trunc('week', '{start_date_str}'::date) AND date_trunc('week', '{end_date_str}'::date)
                    THEN mps.OutofStock_Distinct_PDP_Views / NULLIFZERO(mps.Distinct_PDP_Views) ELSE NULL END) as avg_pdp_oos,
                SUM(CASE WHEN date_trunc('week', mps.activity_date) BETWEEN date_trunc('week', '{start_date_str}'::date) AND date_trunc('week', '{end_date_str}'::date)
                    THEN mps.OutofStock_Distinct_PDP_Views ELSE 0 END) as total_oos_views,
                SUM(CASE WHEN date_trunc('week', mps.activity_date) BETWEEN date_trunc('week', '{start_date_str}'::date) AND date_trunc('week', '{end_date_str}'::date)
                    THEN mps.Distinct_PDP_Views ELSE 0 END) as total_views
            FROM mrch.merch_performance_snapshot_pharmacy mps
            LEFT JOIN edldb.sc_sandbox.non_replenishable_items nr ON nr.snapshot_date = mps.activity_date AND mps.product_part_number = nr.product_part_number
            JOIN chewybi.products p ON p.product_part_number = mps.product_part_number
            JOIN vendor_skus vs ON p.product_part_number = vs.product_part_number
            WHERE 1=1
                AND mps.product_merch_classification2 <> 'Pharmacy'
                AND mps.product_merch_classification1 NOT IN ('Virtual Bundle','Gift Cards')  -- Commented out merch class filter
                AND date_trunc('week', mps.activity_date) BETWEEN 
                    date_trunc('week', '{start_date_str}'::date) AND 
                    date_trunc('week', '{end_date_str}'::date)
                -- AND mps.product_merch_classification1 = 'Cat Consumables'  -- Commented out merch class filter
                AND nr.product_part_number IS NULL
                {dropship_filter}
                AND mps.product_is_compound = false
                AND mps.product_published_flag = true
                AND mps.product_merch_classification1 IS NOT NULL
                AND mps.product_merch_classification2 IS NOT NULL
                AND mps.product_merch_classification3 IS NOT NULL
                AND mps.brand IS NOT NULL
                AND mps.product_discontinued_flag = false
            GROUP BY 1
        ),
        
        contribution AS (
            SELECT 
                brand_base.*,
                COALESCE(total_oos_views / NULLIFZERO(SUM(total_oos_views) OVER()), 0) as oos_contribution,
                COALESCE(total_views / NULLIFZERO(SUM(total_views) OVER()), 0) as views_contribution
            FROM brand_base
        ),
        
        contribution_ranked AS (
            SELECT 
                c.product_manufacturer_name as field,
                NULL as product_name,
                'Top PDP OOS Contribution' as cut,
                1 as priority_cut,
                c.avg_pdp_oos,
                c.total_oos_views,
                c.total_views,
                c.oos_contribution,
                ROW_NUMBER() OVER(ORDER BY ZEROIFNULL(c.oos_contribution) DESC) as rn
            FROM contribution c
            ORDER BY ZEROIFNULL(c.oos_contribution) DESC
            LIMIT 10
        ),
        
        del_base AS (
            SELECT 
                brand_base.*,
                COALESCE(total_oos_views / NULLIFZERO(SUM(total_oos_views) OVER()), 0) as oos_contribution,
                COALESCE(total_views / NULLIFZERO(SUM(total_views) OVER()), 0) as views_contribution,
                -- For delta calculation, use average OOS rate impact 
                ABS(avg_pdp_oos * total_views) as del
            FROM brand_base
        ),
        
        del_ranked AS (
            SELECT 
                product_manufacturer_name as field,
                NULL as product_name,
                'Top PDP OOS Delta Contribution' as cut,
                2 as priority_cut,
                avg_pdp_oos,
                total_oos_views,
                total_views,
                oos_contribution,
                ROW_NUMBER() OVER(ORDER BY ZEROIFNULL(del) DESC) as rn
            FROM del_base
            ORDER BY ZEROIFNULL(del) DESC
            LIMIT 10
        ),
        
        item_base AS (
            SELECT 
                p.product_part_number as sku,
                p.product_name as product_name,
                {pdp_oos_columns},
                {oos_views_columns},
                {total_views_columns},
                {aggregate_pdp_oos},
                -- Computed averages for backward compatibility with downstream CTEs
                AVG(CASE WHEN date_trunc('week', mps.activity_date) BETWEEN date_trunc('week', '{start_date_str}'::date) AND date_trunc('week', '{end_date_str}'::date)
                    THEN mps.OutofStock_Distinct_PDP_Views / NULLIFZERO(mps.Distinct_PDP_Views) ELSE NULL END) as avg_pdp_oos,
                SUM(CASE WHEN date_trunc('week', mps.activity_date) BETWEEN date_trunc('week', '{start_date_str}'::date) AND date_trunc('week', '{end_date_str}'::date)
                    THEN mps.OutofStock_Distinct_PDP_Views ELSE 0 END) as total_oos_views,
                SUM(CASE WHEN date_trunc('week', mps.activity_date) BETWEEN date_trunc('week', '{start_date_str}'::date) AND date_trunc('week', '{end_date_str}'::date)
                    THEN mps.Distinct_PDP_Views ELSE 0 END) as total_views
            FROM mrch.merch_performance_snapshot_pharmacy mps
            LEFT JOIN edldb.sc_sandbox.non_replenishable_items nr ON nr.snapshot_date = mps.activity_date AND mps.product_part_number = nr.product_part_number
            JOIN chewybi.products p ON p.product_part_number = mps.product_part_number
            JOIN vendor_skus vs ON p.product_part_number = vs.product_part_number
            WHERE 1=1
                AND mps.product_merch_classification2 <> 'Pharmacy'
                AND mps.product_merch_classification1 NOT IN ('Virtual Bundle','Gift Cards')  -- Commented out merch class filter
                AND date_trunc('week', mps.activity_date) BETWEEN 
                    date_trunc('week', '{start_date_str}'::date) AND 
                    date_trunc('week', '{end_date_str}'::date)
                -- AND mps.product_merch_classification1 = 'Cat Consumables'  -- Commented out merch class filter
                AND nr.product_part_number IS NULL
                {dropship_filter}
                AND mps.product_is_compound = false
                AND mps.product_published_flag = true
                AND mps.product_merch_classification1 IS NOT NULL
                AND mps.product_merch_classification2 IS NOT NULL
                AND mps.product_merch_classification3 IS NOT NULL
                AND mps.brand IS NOT NULL
                AND mps.product_discontinued_flag = false
            GROUP BY p.product_part_number, p.product_name
        ),
        
        item_contribution AS (
            SELECT 
                item_base.*,
                COALESCE(total_oos_views / NULLIFZERO(SUM(total_oos_views) OVER()), 0) as oos_contribution,
                COALESCE(total_views / NULLIFZERO(SUM(total_views) OVER()), 0) as views_contribution
            FROM item_base
        ),
        
        item_ranked AS (
            SELECT 
                sku as field,
                product_name,
                'Top SKU OOS Contribution' as cut,
                3 as priority_cut,
                avg_pdp_oos,
                total_oos_views,
                total_views,
                oos_contribution,
                ROW_NUMBER() OVER(ORDER BY ZEROIFNULL(oos_contribution) DESC) as rn
            FROM item_contribution
            ORDER BY ZEROIFNULL(oos_contribution) DESC
            LIMIT 30
        ),
        
        vendor_summary AS (
            SELECT 
                vs.vendor_name as field,
                NULL as product_name,
                'Total Vendor' as cut,
                0 as priority_cut,
                {pdp_oos_columns},
                {oos_views_columns},
                {total_views_columns},
                {aggregate_pdp_oos},
                1.0 as oos_contribution,
                0 as rn
            FROM mrch.merch_performance_snapshot_pharmacy mps
            LEFT JOIN edldb.sc_sandbox.non_replenishable_items nr ON nr.snapshot_date = mps.activity_date AND mps.product_part_number = nr.product_part_number
            JOIN chewybi.products p ON p.product_part_number = mps.product_part_number
            JOIN vendor_skus vs ON p.product_part_number = vs.product_part_number
            WHERE 1=1
                AND mps.product_merch_classification2 <> 'Pharmacy'
                AND mps.product_merch_classification1 NOT IN ('Virtual Bundle','Gift Cards') 
                AND date_trunc('week', mps.activity_date) BETWEEN 
                    date_trunc('week', '{start_date_str}'::date) AND 
                    date_trunc('week', '{end_date_str}'::date)
                            AND vs.vendor_number IN ('{vendor_list}')
            AND nr.product_part_number IS NULL
            {dropship_filter}
            AND mps.product_is_compound = false
                AND mps.product_published_flag = true
                AND mps.product_merch_classification1 IS NOT NULL
                AND mps.product_merch_classification2 IS NOT NULL
                AND mps.product_merch_classification3 IS NOT NULL
                AND mps.brand IS NOT NULL
                AND mps.product_discontinued_flag = false
            GROUP BY vs.vendor_name
        ),
        
        
        -- Create contribution calculations with weekly data (avoid nested window functions)
        brand_contribution_with_weekly_calc AS (
            SELECT 
                bb.product_manufacturer_name as field,
                NULL as product_name,
                'Top PDP OOS Contribution' as cut,
                3 as priority_cut,
                bb.{weekly_column_refs},
                COALESCE(bb.total_oos_views / NULLIFZERO(SUM(bb.total_oos_views) OVER()), 0) as oos_contribution
            FROM brand_base bb
            -- Removed WHERE filter to show all brands, even with 0% contribution
        ),
        
        brand_contribution_with_weekly AS (
            SELECT *,
                ROW_NUMBER() OVER(ORDER BY oos_contribution DESC) as rn
            FROM brand_contribution_with_weekly_calc
        ),
        
        -- MC1 Analysis
        mc1_base AS (
            SELECT 
                p.product_merch_classification1,
                {pdp_oos_columns},
                {oos_views_columns},
                {total_views_columns},
                {aggregate_pdp_oos},
                -- Computed averages for backward compatibility with downstream CTEs
                AVG(CASE WHEN date_trunc('week', mps.activity_date) BETWEEN date_trunc('week', '{start_date_str}'::date) AND date_trunc('week', '{end_date_str}'::date)
                    THEN mps.OutofStock_Distinct_PDP_Views / NULLIFZERO(mps.Distinct_PDP_Views) ELSE NULL END) as avg_pdp_oos,
