        for col in wisp_cols:
            # Get display date from column mapping, or use column name
            date_label = column_mapping.get(col, col).replace('_WISP', '').replace('_', '/')
            
            value = row[col]
            if pd.notna(value):  # Include 0% values - they're valid WISP rates
                chart_data.append({
                    'Date': date_label,
                    'Entity': entity_name,
                    'WISP Rate': float(value) if not pd.isna(value) else 0
