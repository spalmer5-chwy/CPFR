def generate_po_status_query(po_numbers):
    """Generate PO status query with dynamic PO list"""
    
    # Create VALUES clause for input POs
    po_values = ",\n        ".join([f"('{po}')" for po in po_numbers])
    
    query = f"""
-- ========= PARAM: List of POs (swap to temp table for big lists) =========
WITH input_pos AS (
    SELECT COLUMN1::STRING AS po
    FROM VALUES
        {po_values}
),

-- ========= PO → Shipment(s) (ISPOT) =========
po_to_shipment AS (
    SELECT DISTINCT
        t.PURCHASE_ORDER AS po,
        t.SHIPMENT_ID
    FROM EDLDB.CHEWYBI.INBOUND_SHIPMENT_PURCHASE_ORDER_TRANSACTIONS t
    JOIN input_pos i ON i.po = t.PURCHASE_ORDER
),

-- ========= Transportation detail (ITPS) =========
itps AS (
    SELECT
        p2s.po,
        itps.SHIPMENT_ID,
        itps.CARRIER_SCAC_CD,
        itps.TRANSPORT_MODE,
        itps.SOURCE_LOCATION_NAME,
        itps.DESTINATION_LOCATION_ID,
        itps.PICKUP_APPOINTMENT_DTTM,
        itps.PICKUP_ACTUAL_ARRIVAL_DTTM,
        itps.PICKUP_ACTUAL_DEPARTURE_DTTM,
        itps.DELIVERY_APPOINTMENT_DTTM,
        itps.DELIVERY_ACTUAL_ARRIVAL_DTTM,    -- FC gate/yard/dock arrival
        itps.DELIVERY_ACTUAL_DEPARTURE_DTTM,  -- trailer leaves FC
        itps.DELIVERY_ESTIMATED_ARRIVAL_DTTM,
        itps.ENROUTE_STATUS
    FROM EDLDB.CHEWYBI.INBOUND_TRANSPORTATION_PS itps
    JOIN po_to_shipment p2s
      ON itps.SHIPMENT_ID = p2s.SHIPMENT_ID
),

-- ========= On-site context (YMS) =========
yms AS (
    SELECT
        y.PO            AS po,
        y.FC            AS fc,
        y.ARRIVAL_TIME  AS yms_arrival_time,
        y.CURRENT_LOCATION,
        y.LOCATION_TYPE,
        y.LOAD_STATUS,
        y.TRAILER_USAGE,
        y.CARRIER_SCAC   AS yms_carrier_scac
    FROM EDLDB.BT_SC_TRANSPORTATION.YMS_ONSITE_PO_DETAIL y
    JOIN input_pos i ON i.po = y.PO
),

-- ========= Receipts (Inventory Transactions — authoritative) =========
-- Only count transactions of type 'Purchase'
inv_receipts_raw AS (
    SELECT
        t.INVENTORY_TRANSACTION_DOCUMENT_NUMBER      AS po,
        t.FULFILLMENT_CENTER_NAME                    AS fc,
        t.INVENTORY_TRANSACTION_TRANSACTION_DTTM     AS receipt_ts
    FROM EDLDB.CHEWYBI.INVENTORY_TRANSACTIONS t
    JOIN input_pos i
      ON i.po = t.INVENTORY_TRANSACTION_DOCUMENT_NUMBER
    WHERE UPPER(t.INVENTORY_TRANSACTION_TRANSACTION_TYPE) = 'PURCHASE'
),
-- Latest receipt per PO (pick the row with the max timestamp using QUALIFY)
inv_receipts AS (
    SELECT
        po,
        fc AS fc_latest,
        receipt_ts AS last_receipt_ts
    FROM inv_receipts_raw
    QUALIFY ROW_NUMBER() OVER (PARTITION BY po ORDER BY receipt_ts DESC) = 1
),

-- Optional: procurement "closed" flag (fallback context only)
proc_closed AS (
    SELECT
        r.DOCUMENT_NUMBER AS po,
        MAX(
            IFF(
                TRY_TO_BOOLEAN(r.DOCUMENT_READY_TO_RECONCILE_FLAG) = TRUE, 
                1, 
                0
            )
        ) AS is_closed
    FROM EDLDB.CHEWYBI.PROCUREMENT_DOCUMENT_PRODUCT_MEASURES r
    JOIN input_pos i 
        ON i.po = r.DOCUMENT_NUMBER
    GROUP BY r.DOCUMENT_NUMBER
),

-- ========= Event synthesis =========
events AS (
    SELECT
        it.po,
        it.SHIPMENT_ID,
        it.PICKUP_ACTUAL_DEPARTURE_DTTM                      AS ts_picked_up,
        COALESCE(
            it.DELIVERY_ESTIMATED_ARRIVAL_DTTM,
            it.DELIVERY_ACTUAL_DEPARTURE_DTTM,
            it.PICKUP_ACTUAL_DEPARTURE_DTTM
        )                                                    AS ts_in_transit_activity,
        GREATEST(it.DELIVERY_ACTUAL_ARRIVAL_DTTM, y.yms_arrival_time) AS ts_at_fc_yard,
        ir.last_receipt_ts                                   AS ts_received,            -- authoritative receipt timestamp
        it.CARRIER_SCAC_CD,
        it.TRANSPORT_MODE,
        it.SOURCE_LOCATION_NAME,
        it.DESTINATION_LOCATION_ID,
        COALESCE(ir.fc_latest, y.fc, it.DESTINATION_LOCATION_ID) AS fc,
        y.CURRENT_LOCATION,
        y.LOCATION_TYPE,
        y.LOAD_STATUS,
        y.TRAILER_USAGE,
        it.ENROUTE_STATUS,
        it.DELIVERY_ESTIMATED_ARRIVAL_DTTM,
        pc.is_closed
    FROM itps it
    LEFT JOIN yms y
      ON y.po = it.po
    LEFT JOIN inv_receipts ir
      ON ir.po = it.po
    LEFT JOIN proc_closed pc
      ON pc.po = it.po
),

-- ========= Decide "current status" per PO =========
ranked AS (
    SELECT
        e.*,
        ROW_NUMBER() OVER (
            PARTITION BY e.po
            ORDER BY
                /* Priority: RECEIVED > AT_FC_YARD > IN_TRANSIT > PICKED_UP > NO_SIGNAL */
                CASE 
                    WHEN e.ts_received IS NOT NULL                            THEN 5
                    WHEN e.ts_at_fc_yard IS NOT NULL                          THEN 4
                    WHEN e.ts_picked_up IS NOT NULL 
                         AND e.ts_at_fc_yard IS NULL 
                         AND e.ts_received IS NULL                            THEN 3
                    WHEN e.ts_picked_up IS NOT NULL                            THEN 2
                    ELSE 1
                END DESC,
                GREATEST(
                    COALESCE(e.ts_received,            CAST('1900-01-01' AS TIMESTAMP)),
                    COALESCE(e.ts_at_fc_yard,          CAST('1900-01-01' AS TIMESTAMP)),
                    COALESCE(e.ts_in_transit_activity, CAST('1900-01-01' AS TIMESTAMP)),
                    COALESCE(e.ts_picked_up,           CAST('1900-01-01' AS TIMESTAMP))
                ) DESC
        ) AS rn
    FROM events e
),

winner AS (
    SELECT
        r.po,
        r.SHIPMENT_ID,
        CASE 
            WHEN r.ts_received IS NOT NULL THEN 'Received at FC'
            WHEN r.ts_at_fc_yard IS NOT NULL THEN 'At FC gate/yard'
            WHEN r.ts_picked_up IS NOT NULL 
                 AND r.ts_at_fc_yard IS NULL 
                 AND r.ts_received IS NULL THEN 'In transit'
            WHEN r.ts_picked_up IS NOT NULL THEN 'Picked up'
            ELSE 'No movement signal'
        END AS status_label,
        CASE 
            WHEN r.ts_received IS NOT NULL THEN r.ts_received
            WHEN r.ts_at_fc_yard IS NOT NULL THEN r.ts_at_fc_yard
            WHEN r.ts_picked_up IS NOT NULL 
                 AND r.ts_at_fc_yard IS NULL 
                 AND r.ts_received IS NULL THEN r.ts_in_transit_activity
            WHEN r.ts_picked_up IS NOT NULL THEN r.ts_picked_up
            ELSE NULL
        END AS last_event_ts,
        r.CARRIER_SCAC_CD,
        r.TRANSPORT_MODE,
        r.SOURCE_LOCATION_NAME,
        r.DESTINATION_LOCATION_ID,
        r.fc,
        r.CURRENT_LOCATION,
        r.LOCATION_TYPE,
        r.LOAD_STATUS,
        r.TRAILER_USAGE,
        r.ENROUTE_STATUS,
        r.DELIVERY_ESTIMATED_ARRIVAL_DTTM,
        r.is_closed
    FROM ranked r
    WHERE r.rn = 1
)

SELECT
    w.po,
    w.SHIPMENT_ID,
    w.status_label,
    w.last_event_ts,
    DATEDIFF('hour', w.last_event_ts, CURRENT_TIMESTAMP()) AS hours_since_last_event,
    w.CARRIER_SCAC_CD        AS carrier_scac,
    w.TRANSPORT_MODE         AS transport_mode,
    w.SOURCE_LOCATION_NAME   AS source_location,
    w.DESTINATION_LOCATION_ID AS destination_location,
    w.fc,
    w.CURRENT_LOCATION       AS yms_current_location,
    w.LOCATION_TYPE          AS yms_location_type,
    w.LOAD_STATUS            AS yms_load_status,
    w.TRAILER_USAGE          AS yms_trailer_usage,
    w.ENROUTE_STATUS         AS tms_enroute_status,
    w.DELIVERY_ESTIMATED_ARRIVAL_DTTM AS eta_fc,
    w.is_closed              AS procurement_closed_flag
FROM winner w
ORDER BY w.po, w.last_event_ts DESC;
"""
    
    return query


