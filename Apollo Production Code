        wisp_cols = [col for col in wisp_data.columns if col.startswith('W') and 'WISP' in col and not col.startswith('WOW') and '_WISP' in col]
        
        if not wisp_cols:
            st.warning("No weekly WISP data found for visualization.")
            return
        
        # Filter to vendor-level and category-level data (exclude individual SKUs for main trends)
        # Include Total Vendor, MC1/MC2, and brand contribution charts
        preferred_cuts = ['Total Vendor', 'MC1', 'MC2', 'Top WISP Contribution']
        available_cuts = wisp_data['CUT'].unique() if 'CUT' in wisp_data.columns else []
        available_preferred_cuts = [cut for cut in preferred_cuts if cut in available_cuts]
        
        if available_preferred_cuts:
            viz_data = wisp_data[wisp_data['CUT'].isin(available_preferred_cuts)].copy()
        else:
            # Fallback to any non-SKU cuts
            trend_cuts = [cut for cut in available_cuts if not any(x in cut.lower() for x in ['sku', 'top item', 'item'])][:5]
            if trend_cuts:
                viz_data = wisp_data[wisp_data['CUT'].isin(trend_cuts)].copy()
            else:
                viz_data = wisp_data[wisp_data['CUT'].isin(['Total Vendor'])].copy()
        
        if viz_data.empty:
            # Try to use any available data for trend analysis
            available_cuts = wisp_data['CUT'].unique() if 'CUT' in wisp_data.columns else []
            
            if len(available_cuts) > 0:
                # Use the first few available cuts, excluding SKU-level data for trend clarity
                trend_cuts = [cut for cut in available_cuts if not any(x in cut.lower() for x in ['sku', 'top item', 'item'])][:4]
                if trend_cuts:
                    viz_data = wisp_data[wisp_data['CUT'].isin(trend_cuts)].copy()
                else:
                    st.info("No aggregated data available for trend visualization.")
                    return
            else:
