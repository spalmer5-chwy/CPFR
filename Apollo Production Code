    try:
        # Get individual item data (SKUs/products, not aggregated)
        item_data = oos_data[
            oos_data['CUT'].str.contains('SKU|Item', case=False, na=False)
        ].copy()
        
        # If no SKU data, try product-level data
        if item_data.empty:
            item_data = oos_data[
                (~oos_data['CUT'].isin(['Total Vendor', 'MC1', 'MC2'])) &
                (~oos_data['CUT'].str.contains('PDP OOS Contribution', case=False, na=False))
            ].copy()
        
        if item_data.empty:
            st.info("No individual item data available for trend analysis.")
            return
        
        # Filter out contributions > 100% for quality
        item_data = item_data[item_data['OOS_CONTRIBUTION'] <= 1.0]
        
        # Get top 10 items by OOS contribution
        top_items = item_data.nlargest(10, 'OOS_CONTRIBUTION')
        
        if top_items.empty:
