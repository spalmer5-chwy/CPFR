def create_setup_audit_alert(foundation_data):
    """Create Setup Audit Alert table to identify data quality issues"""
    
    if foundation_data.empty:
        return pd.DataFrame()
    
    
    audit_issues = []
    
    # Check each row for audit issues
    for idx, row in foundation_data.iterrows():
        sku = row.get('SKU', 'Unknown')
        # Try multiple possible column names for description
        description = (row.get('Description', None) or 
                      row.get('DESCRIPTION', None) or 
                      row.get('description', None) or 
                      'Unknown')
        # Try multiple possible column names for velocity code  
        velocity_code = (row.get('Velocity Code', None) or 
                        row.get('VELOCITY CODE', None) or 
                        row.get('ABC Code', None) or 
                        row.get('velocity_code', None) or 
                        'Unknown')
        
        # Issue 1: Order Multiple > MOQ
        if row.get('Is OM > MOQ', False) == True:
            audit_issues.append({
                'SKU': sku,
                'Description': description,
                'Velocity Code': velocity_code,
                'Issue Type': 'Order Multiple > MOQ',
                'Issue Description': f'Order Multiple ({row.get("Order Multiple", 0)}) is greater than MOQ ({row.get("MOQ", 0)})',
                'Current Value': f'OM: {row.get("Order Multiple", 0)}, MOQ: {row.get("MOQ", 0)}',
                'Severity': 'High'
            })
        
        # Issue 2: Published = False
        if row.get('Published Y/N', True) == False:
            audit_issues.append({
                'SKU': sku,
                'Description': description,
                'Velocity Code': velocity_code,
                'Issue Type': 'Not Published',
                'Issue Description': 'SKU is not published and may not be available for sale',
                'Current Value': 'Published: False',
                'Severity': 'High'
            })
        
        # Issue 3: Pallet not divisible by MOQ (not whole number)
        pallet_moq_divisible = row.get('Is Pallet divisible by MOQ (whole number y/n)', 0)
        if pd.notna(pallet_moq_divisible) and pallet_moq_divisible != 0:
            # Check if it's not a whole number (has decimal places)
            if abs(pallet_moq_divisible - round(pallet_moq_divisible)) > 0.01:
                audit_issues.append({
                    'SKU': sku,
                    'Description': description,
                    'Velocity Code': velocity_code,
                    'Issue Type': 'Pallet/MOQ Not Whole Number',
                    'Issue Description': f'Pallet quantity is not evenly divisible by MOQ',
                    'Current Value': f'Pallet ÷ MOQ = {pallet_moq_divisible:.2f}',
                    'Severity': 'Medium'
                })
        
        # Issue 4: Pallet not divisible by Layers (not whole number)
        pallet_layer_divisible = row.get('Is Pallet divisible by Layers (whole number y/n)', 0)
        if pd.notna(pallet_layer_divisible) and pallet_layer_divisible != 0:
            # Check if it's not a whole number (has decimal places)
            if abs(pallet_layer_divisible - round(pallet_layer_divisible)) > 0.01:
                audit_issues.append({
                    'SKU': sku,
                    'Description': description,
                    'Velocity Code': velocity_code,
                    'Issue Type': 'Pallet/Layer Not Whole Number',
                    'Issue Description': f'Pallet quantity is not evenly divisible by Layer quantity',
                    'Current Value': f'Pallet ÷ Layer = {pallet_layer_divisible:.2f}',
                    'Severity': 'Medium'
                })
        
        # Issue 5: Temp Disable is not null/empty (SKU is temporarily disabled)
        temp_disable = row.get('Temp Disable', None)
        if pd.notna(temp_disable) and temp_disable is not None and str(temp_disable).strip() != '':
            audit_issues.append({
                'SKU': sku,
                'Description': description,
                'Velocity Code': velocity_code,
                'Issue Type': 'Temporarily Disabled',
                'Issue Description': f'SKU is temporarily disabled until {temp_disable}',
                'Current Value': f'Temp Disable: {temp_disable}',
                'Severity': 'High'
            })
        
        # Issue 6: Eaches per Pallet = 1 (indicates incorrect setup)
        eaches_per_pallet = row.get('Eaches per Pallet', None)
        if pd.notna(eaches_per_pallet) and eaches_per_pallet == 1:
            audit_issues.append({
                'SKU': sku,
                'Description': description,
                'Velocity Code': velocity_code,
                'Issue Type': 'Eaches per Pallet = 1',
                'Issue Description': 'Eaches per Pallet is set to 1, indicating incorrect pallet configuration',
                'Current Value': f'Eaches per Pallet: {eaches_per_pallet}',
                'Severity': 'Medium'
            })
    
    # Convert to DataFrame
    if audit_issues:
        audit_df = pd.DataFrame(audit_issues)
        
        # Define sorting order for issue types within each severity level
        severity_order = {'High': 1, 'Medium': 2}
        issue_type_order = {
            # High Severity (in desired order)
            'Order Multiple > MOQ': 1,
            'Temporarily Disabled': 2, 
            'Not Published': 3,
            # Medium Severity (in desired order)
            'Pallet/MOQ Not Whole Number': 4,
            'Pallet/Layer Not Whole Number': 5,
            'Eaches per Pallet = 1': 6
        }
        # Define velocity code priority (A = highest priority)
        velocity_order = {'A': 1, 'B': 2, 'C': 3, 'Unknown': 4}
        
        # Add sorting columns
        audit_df['Severity_Sort'] = audit_df['Severity'].map(severity_order)
        audit_df['Issue_Type_Sort'] = audit_df['Issue Type'].map(issue_type_order)
        audit_df['Velocity_Sort'] = audit_df['Velocity Code'].map(velocity_order)
        
        # Sort by severity first, then by issue type, then by velocity code (A first), then by SKU
        audit_df = audit_df.sort_values(['Severity_Sort', 'Issue_Type_Sort', 'Velocity_Sort', 'SKU'])
        
        # Remove sorting columns from display
        audit_df = audit_df.drop(['Severity_Sort', 'Issue_Type_Sort', 'Velocity_Sort'], axis=1)
        
        # Add row numbers starting from 1
        audit_df.index = range(1, len(audit_df) + 1)
        return audit_df
    else:
        return pd.DataFrame()

